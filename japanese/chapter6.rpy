# TODO: Translation updated at 2026-03-11 21:02

# game/chapter6.rpy:9
translate japanese chapter6_1e5f59c8:

    # "뒤따라 나온 현지와 함께 복도를 걷던 나는 저편에서 이쪽을 향해 걸어오는 여학생 한 명과 마주쳤다. "
    "後から出てきたヒョンジと一緒に廊下を歩いていると、向こうからこちらに向かってくる女の子と目が合った。"

# game/chapter6.rpy:10
translate japanese chapter6_0060aa54:

    # "이상한 나라로 향하는 백색 토끼처럼 급히 어디론가 향하는 한 여학생. "
    "不思議の国へ向かう白ウサギのように、急いでどこかへ向かう一人の女の子。"

# game/chapter6.rpy:11
translate japanese chapter6_559c4626:

    # "온몸에 바쁜 기색을 잔뜩 칠하고 복도를 걷던 그 여학생이 유미였음은, 그저 우연에서 비롯된 일이었을 것이다. "
    "全身に忙しそうな気配を纏わせて廊下を歩くその女の子がユミだったのは、ただの偶然だったのだろう。"

# game/chapter6.rpy:16
translate japanese chapter6_0cefa662:

    # voice "voices/yf1.ogg"
    # 유미 "“아, 학예제 준비하고 있었던 거야?”"
    voice "voices/yf1.ogg"
    유미 "「あ、文化祭の準備してたの？」"

# game/chapter6.rpy:19
translate japanese chapter6_99f45723:

    # voice ""
    # "나를 발견하자마자 가던 길을 멈추고선 내게 말을 걸어오는 유미. "
    voice ""
    "俺を見つけるなり足を止めて話しかけてくるユミ。"

# game/chapter6.rpy:21
translate japanese chapter6_e1ff17fc:

    # "나는 그렇다고 말하며 가볍게 고개를 끄덕였다. "
    "そうだと言いながら軽くうなずいた。"

# game/chapter6.rpy:22
translate japanese chapter6_d2e74970:

    # "유미는 나의 옆에 서 있던 현지를 가볍게 스캔하고선 이야기를 이어갔다. "
    "ユミは俺の隣に立っていたヒョンジをさっと見てから話を続けた。"

# game/chapter6.rpy:24
translate japanese chapter6_900d9eec:

    # voice "voices/yf2.ogg"
    # 유미 "“학교에서 보는 건 또 오랜만이네.”"
    voice "voices/yf2.ogg"
    유미 "「学校で会うのも久しぶりだね。」"

# game/chapter6.rpy:26
translate japanese chapter6_011858a5:

    # voice ""
    # 나 "“그러게. 넌 어디 가는 거야?”"
    voice ""
    나 "「そうだな。どこ行くんだ？」"

# game/chapter6.rpy:29
translate japanese chapter6_a0d9f79c:

    # voice "voices/yf3.ogg"
    # 유미 "“응, 잠시 교무실 들렀다 오는 길.”"
    voice "voices/yf3.ogg"
    유미 "「うん、ちょっと職員室に寄ってきたところ。」"

# game/chapter6.rpy:31
translate japanese chapter6_71d926ea:

    # voice ""
    # 나 "“이래저래 바빠 보이네.”"
    voice ""
    나 "「いろいろ忙しそうだな。」"

# game/chapter6.rpy:34
translate japanese chapter6_5b934613:

    # voice "voices/yf4.ogg"
    # 유미 "“뭐어, 매번 그렇지.”"
    voice "voices/yf4.ogg"
    유미 "「まあ、いつものことだけどね。」"

# game/chapter6.rpy:40
translate japanese chapter6_1b4f2c99:

    # voice ""
    # "별일 아니라는 듯 대답하는 유미의 얼굴에는 어딘가 껄끄러운 표정이 덧대져 있었다. "
    voice ""
    "大したことないように答えるユミの顔には、どこか気まずそうな表情が浮かんでいた。"

# game/chapter6.rpy:43
translate japanese chapter6_daae159f:

    # voice "voices/hf1.ogg"
    # 현지 "“무슨 일 있었던 거예요?”"
    voice "voices/hf1.ogg"
    현지 "「何かあったんですか？」"

# game/chapter6.rpy:48
translate japanese chapter6_8416d8c3:

    # voice "voices/yf5.ogg"
    # 유미 "“아니, 별일은 아니고. 올해 학예제 폐회식때 불꽃놀이 하기로 했었잖아. 그런데 며칠 전에 불꽃놀이를 담당할 불꽃부에 갑자기 문제가 생겼다지 뭐야. 그래서 불꽃놀이를 담당할 사람이 새로 필요하다나…….”"
    voice "voices/yf5.ogg"
    유미 "「ううん、大したことじゃないんだけど。今年の文化祭の閉会式で花火をやることになってたでしょ。それが何日か前に花火を担当する花火部に急に問題が起きたんだって。だから花火を担当する人が新しく必要になったらしくて……。」"

# game/chapter6.rpy:50
translate japanese chapter6_a0c652d0:

    # voice "voices/hf2.ogg"
    # 현지 "“그거 큰일 아니에요?”"
    voice "voices/hf2.ogg"
    현지 "「それ大変じゃないですか？」"

# game/chapter6.rpy:53
translate japanese chapter6_c19dd623:

    # voice "voices/yf6.ogg"
    # 유미 "“으음, 학예제때 쓸 불꽃은 다 만들어 놓아서 완전 큰일난 정도까진 아닌데, 일이 귀찮아진 거지. 누군가가 불꽃놀이 진행 순서도 짜야 하고, 당일날 불꽃도 다뤄야 하니까. 그리고 어쩌다 보니 그 일을 내가 맡게 된 거고.”"
    voice "voices/yf6.ogg"
    유미 "「うーん、文化祭で使う花火は全部作ってあるから完全に大事ってほどじゃないんだけど、面倒なことになったのよ。誰かが花火の進行順も組まなきゃいけないし、当日花火も扱わなきゃいけないから。それでなんだかんだその仕事を私が引き受けることになったの。」"

# game/chapter6.rpy:55
translate japanese chapter6_1158965a:

    # voice ""
    # 나 "“지금도 엄청 바쁘면서, 그런 일까지 맡게 된 거야?”"
    voice ""
    나 "「今だってめちゃくちゃ忙しいのに、そんな仕事まで引き受けたのか？」"

# game/chapter6.rpy:58
translate japanese chapter6_9c2a150b:

    # voice "voices/yf7.ogg"
    # 유미 "“그러게 말야……. 그치만 하려는 사람도 없었던 데다가 다들 내가 했으면 하는 눈치였기도 해서. 앗, 이제 가봐야겠다. 다음에 봐~”"
    voice "voices/yf7.ogg"
    유미 "「ほんとにね……。でもやろうとする人もいなかったし、みんな私にやってほしそうな雰囲気だったから。あ、もう行かなきゃ。またね〜」"

# game/chapter6.rpy:64
translate japanese chapter6_8baeb176:

    # voice ""
    # "나와 현지에게 손을 흔들어 보이고선 복도 저편으로 총총 사라지는 유미. "
    voice ""
    "俺とヒョンジに手を振って見せると、廊下の向こうへぱたぱたと消えていくユミ。"

# game/chapter6.rpy:66
translate japanese chapter6_6ae61fdf:

    # "현지는 그런 유미를 조금은 안쓰러운 티를 내비치며 바라보고 있었다. "
    "ヒョンジはそんなユミを少し気の毒そうに見つめていた。"

# game/chapter6.rpy:68
translate japanese chapter6_91ec9f79:

    # voice "voices/hf3.ogg"
    # 현지 "“유미 언니 많이 피곤해 보이죠?”"
    voice "voices/hf3.ogg"
    현지 "「ユミ姉さん、すごく疲れてるように見えましたよね？」"

# game/chapter6.rpy:70
translate japanese chapter6_085c8575:

    # voice ""
    # 나 "“그러게.”"
    voice ""
    나 "「そうだな。」"

# game/chapter6.rpy:73
translate japanese chapter6_44b754b8:

    # "마음에 걸리긴 했지만, 텅 빈 복도를 걷는 것밖엔 달리 할 수 있는 일이 없었다. "
    "気にはなったけれど、がらんとした廊下を歩くことしかできなかった。"

# game/chapter6.rpy:78
translate japanese chapter6_b8b795c9:

    # "집으로 돌아가는 길도 현지와 함께였다. "
    "下校もヒョンジと一緒だった。"

# game/chapter6.rpy:79
translate japanese chapter6_8a45cb11:

    # "불어오는 바람은 점점 투명해지고 있는 것 같았다. "
    "吹いてくる風はだんだん透明になっていくようだった。"

# game/chapter6.rpy:80
translate japanese chapter6_5ed74aea:

    # "한여름의 바람이 무언가를 잔뜩 머금고 느릿느릿 다가오는 것과 달리, 한겨울의 바람은 쌩하는 소리와 함께 가벼이 불어오니 말이다. "
    "真夏の風が何かをたっぷり含んでのろのろと近づいてくるのとは違い、真冬の風はびゅうという音とともに軽く吹いてくる。"

# game/chapter6.rpy:81
translate japanese chapter6_1a2b3736:

    # "학교 앞 신호등에 멈춰 서, 나는 버릇처럼 옆을 바라보다 말고 현지와 눈을 마주쳤다. "
    "学校前の信号で立ち止まり、癖のように横を見ると、ヒョンジと目が合った。"

# game/chapter6.rpy:82
translate japanese chapter6_5a76bc5c:

    # "마침 현지도 나를 기웃기웃 바라보고 있었던 모양이었다. "
    "ちょうどヒョンジも俺のことをちらちら見ていたらしい。"

# game/chapter6.rpy:87
translate japanese chapter6_3eaaa421:

    # voice "voices/hf4.ogg"
    # 현지 "“이제 학예제 준비도 다 끝났는데, 남아있는 방학은 어떻게 보낼 생각이에요?”"
    voice "voices/hf4.ogg"
    현지 "「もう文化祭の準備も全部終わりましたけど、残りの休みはどう過ごすつもりですか？」"

# game/chapter6.rpy:89
translate japanese chapter6_9af39a92:

    # voice ""
    # "나와 눈을 마주친 현지가 곧장 내게 말을 걸어왔다. "
    voice ""
    "俺と目が合ったヒョンジがすぐに話しかけてきた。"

# game/chapter6.rpy:92
translate japanese chapter6_c6f2bd67:

    # 나 "“글쎄. 생각 안 해봤는데.”"
    나 "「さあ。考えてなかった。」"

# game/chapter6.rpy:94
translate japanese chapter6_7108cd7a:

    # "열흘 정도의 이 시간을 어떻게 보낼지는, 나도 잘 모르겠다고 생각하던 터였다. "
    "十日ほどのこの時間をどう過ごすか、自分でも決めかねていた。"

# game/chapter6.rpy:98
translate japanese chapter6_c3a77247:

    # voice "voices/hf5.ogg"
    # 현지 "“유령은 다시 찾을 생각 없어요?”"
    voice "voices/hf5.ogg"
    현지 "「幽霊をもう一度探す気はないんですか？」"

# game/chapter6.rpy:100
translate japanese chapter6_548de1a5:

    # voice ""
    # 나 "“찾으려고 해도 찾을 수 있어야 말이지. 어딨는지도 모르고, 연락할 방법도 없고.”"
    voice ""
    나 "「探そうにもアテがないとどうにもならないだろ。どこにいるかもわからないし、連絡する方法もないし。」"

# game/chapter6.rpy:103
translate japanese chapter6_f53f6d6c:

    # "나는 잠시 생각에 잠겼다가, 이야기를 계속했다. "
    "俺は少し考え込んでから、話を続けた。"

# game/chapter6.rpy:107
translate japanese chapter6_cf60e2de:

    # 나 "“그나저나, 왜 내 눈에만 그 유령이 보였던 걸까?”"
    나 "「そういえば、なんで俺にだけあの幽霊が見えたんだろう？」"

# game/chapter6.rpy:109
translate japanese chapter6_2a6a4da3:

    # "혼잣말처럼 내뱉은 그 질문에 아무도 대답을 할 수 없다는 것을 깨달은 건 몇 초 정도 뒤의 일이었다. "
    "独り言のようにこぼしたその問いに誰も答えられないことに気づいたのは、数秒後のことだった。"

# game/chapter6.rpy:110
translate japanese chapter6_8ad8a370:

    # "신호등을 건너며, 나는 적당히 그 질문에 대한 대답을 중얼거렸다. "
    "信号を渡りながら、俺は適当にその問いへの答えをつぶやいた。"

# game/chapter6.rpy:112
translate japanese chapter6_1a4132d4:

    # 나 "“역시 그저 우연이었던 거겠지?”"
    나 "「やっぱりただの偶然だったのかな？」"

# game/chapter6.rpy:113
translate japanese chapter6_e8784004:

    # voice "voices/hf6.ogg"
    # 현지 "“어쩌면 운명일지도 모르죠. 필연적이었던 건 아니었을까요?”"
    voice "voices/hf6.ogg"
    현지 "「もしかしたら運命かもしれませんよ。必然だったんじゃないでしょうか？」"

# game/chapter6.rpy:116
translate japanese chapter6_908db3dd:

    # voice ""
    # "다시 한번 옆을 바라보았다. "
    voice ""
    "もう一度横を見た。"

# game/chapter6.rpy:118
translate japanese chapter6_bdf0a763:

    # "횡단보도를 절반쯤 걸었을까, 초록빛을 발하는 보행자 신호가 깜빡이기 시작했다. "
    "横断歩道を半分ほど渡ったところで、青く光る歩行者信号が点滅し始めた。"

# game/chapter6.rpy:119
translate japanese chapter6_37b01358:

    # 나 "“그럼, 내가 여기로 오게 된 것도 필연이었을까?”"
    나 "「じゃあ、俺がここに来たのも必然だったのかな？」"

# game/chapter6.rpy:120
translate japanese chapter6_42531847:

    # voice "voices/hf7.ogg"
    # 현지 "“글쎄요.”"
    voice "voices/hf7.ogg"
    현지 "「さあ。」"

# game/chapter6.rpy:122
translate japanese chapter6_4d7ec6a4:

    # voice ""
    # 나 "“내가 유미와 마주치고, 너와 같은 동아리가 된 것도?”"
    voice ""
    나 "「俺がユミと出会って、おまえと同じ部活になったのも？」"

# game/chapter6.rpy:125
translate japanese chapter6_7860e254:

    # voice "voices/hf8.ogg"
    # 현지 "“하지만 단순한 우연일 뿐이라도 상관없잖아요?”"
    voice "voices/hf8.ogg"
    현지 "「でも、ただの偶然でも構わないじゃないですか？」"

# game/chapter6.rpy:127
translate japanese chapter6_41e5359b:

    # voice ""
    # "우연이라든가, 운명이라든가 하는 단어를 곱씹는 사이 횡단보도가 끝이 났다. "
    voice ""
    "偶然とか、運命とか、そんな言葉を噛みしめているうちに横断歩道が終わった。"

# game/chapter6.rpy:129
translate japanese chapter6_369267ab:

    # "세 방향의 갈림길에서, 나와 현지는 같은 길목으로 접어든다. "
    "三方向の分かれ道で、俺とヒョンジは同じ道に入る。"

# game/chapter6.rpy:130
translate japanese chapter6_cbf77111:

    # "잠시 생각할 시간을 주었다는 듯, 현지가 이야기를 이어갔다. "
    "少し考える時間を与えたとでもいうように、ヒョンジが話を続けた。"

# game/chapter6.rpy:132
translate japanese chapter6_1a34454c:

    # voice "voices/hf9.ogg"
    # 현지 "“사람은 우연과 필연을 구분하지 못하니까요. 그러니까 우연이든, 필연이든 모두 소중한 거 아닐까요.”"
    voice "voices/hf9.ogg"
    현지 "「人は偶然と必然を区別できませんから。だから偶然だろうと必然だろうと、どちらも大切なんじゃないかなと思います。」"

# game/chapter6.rpy:134
translate japanese chapter6_80c1608b:

    # voice ""
    # 나 "“그렇긴 하네.”"
    voice ""
    나 "「確かにそうだな。」"

# game/chapter6.rpy:136
translate japanese chapter6_cec7dd60:

    # "다시금 옆을 돌아보며, 현지의 눈동자를 마주한다. "
    "もう一度横を振り返り、ヒョンジの瞳を見つめる。"

# game/chapter6.rpy:139
translate japanese chapter6_4deb43f1:

    # "눈동자는 눈동자일 뿐, 다른 것은 보이지 않았다. "
    "瞳は瞳でしかなく、他には何も見えなかった。"

# game/chapter6.rpy:140
translate japanese chapter6_dedec9f0:

    # "죽음의 색이라거나, 인간의 운명이라거나. "
    "死の色だとか、人間の運命だとか。"

# game/chapter6.rpy:141
translate japanese chapter6_005d5129:

    # "어쩌면 우연과 필연을 구분하지 못하는 것은 인간에게 주어진 일종의 축복이 아닐까, 그런 생각이 들었다. "
    "偶然と必然を区別できないことは、人間に与えられた一種の祝福ではないだろうか、そんな思いが浮かんだ。"

# game/chapter6.rpy:143
translate japanese chapter6_ed160ace:

    # 나 "“기억 나? 그 유령이 네 눈에서 강렬한 죽음의 색이 보인다고 했던 거.”"
    나 "「覚えてるか？あの幽霊がおまえの目に強烈な死の色が見えるって言ってたこと。」"

# game/chapter6.rpy:145
translate japanese chapter6_029482a5:

    # "나의 말을 듣자마자 현지는 가볍게 고개를 끄덕였다. "
    "俺の言葉を聞くなり、ヒョンジは軽くうなずいた。"

# game/chapter6.rpy:146
translate japanese chapter6_947cd515:

    # "현지도 나와 같은 생각을 하고 있었던 걸까. "
    "ヒョンジも俺と同じことを考えていたのだろうか。"

# game/chapter6.rpy:150
translate japanese chapter6_38c8df40:

    # "자그마한 목소리로, 현지가 털어놓듯 말을 꺼냈다. "
    "小さな声で、ヒョンジが打ち明けるように口を開いた。"

# game/chapter6.rpy:152
translate japanese chapter6_08d20d76:

    # voice "voices/hf10.ogg"
    # 현지 "“선배는 이미 죽었어야 할 저를 구해준 거예요.”"
    voice "voices/hf10.ogg"
    현지 "「先輩はもう死んでいたはずの私を助けてくれたんです。」"

# game/chapter6.rpy:154
translate japanese chapter6_5ac18094:

    # voice ""
    # 나 "“애초에 나 때문에 위험에 빠진 거잖아. 내가 아니었으면 텔레이도스코프를 만들 일도 없었을 테고.”"
    voice ""
    나 "「そもそも俺のせいで危険に陥ったんだろ。俺がいなければテレイドスコープを作ることもなかったはずだし。」"

# game/chapter6.rpy:157
translate japanese chapter6_a5112dd3:

    # voice "voices/hf11.ogg"
    # 현지 "“반대로 생각해보면, 선배가 제 운명에 휘말린 거라고 말할 수도 있지 않을까요?”"
    voice "voices/hf11.ogg"
    현지 "「逆に考えれば、先輩が私の運命に巻き込まれたとも言えるんじゃないですか？」"

# game/chapter6.rpy:159
translate japanese chapter6_150dff88:

    # voice ""
    # "그건 운명에 휘말린 게 아니라 서로의 운명이 얽혀있는 거라는 말장난같은 이야기를 꺼내려다 말고, 나는 그대로 그 말을 삼켜버렸다. "
    voice ""
    "運命に巻き込まれたんじゃなくて互いの運命が絡み合っているんだ、なんて言葉遊びのような話を持ち出そうとしてやめ、そのまま飲み込んだ。"

# game/chapter6.rpy:161
translate japanese chapter6_00074634:

    # "현지의 말이 맞다는 것을 어렴풋이 짐작하고 있었다. "
    "ヒョンジの言う通りなのだとうっすら察していた。"

# game/chapter6.rpy:162
translate japanese chapter6_208a1cc1:

    # "의아했던 사건들이 하나둘씩 머릿속에서 그것 나름대로의 이유와 함께 맞아 떨어져가고 있었다. "
    "不思議だった出来事が一つまた一つと、それなりの理由とともに頭の中で合点がいき始めていた。"

# game/chapter6.rpy:171
translate japanese chapter6_cc3a9992:

    # voice "voices/ef1.ogg"
    # 소녀 "“왜 당신의 눈에서는 '죽음'이 보이지 않는 거죠?”"
    voice "voices/ef1.ogg"
    소녀 "「なぜあなたの目には「死」が見えないんでしょう？」"

# game/chapter6.rpy:176
translate japanese chapter6_4dd20225:

    # voice "voices/ef2.ogg"
    # 소녀 "“혹시 당신도 저와 같은 유령인가요?”"
    voice "voices/ef2.ogg"
    소녀 "「もしかしてあなたも私と同じ幽霊なんですか？」"

# game/chapter6.rpy:181
translate japanese chapter6_4db9ea51:

    # voice ""
    # "존재하지 않으니까. "
    voice ""
    "存在しないからだ。"

# game/chapter6.rpy:183
translate japanese chapter6_b376726d:

    # "내 눈동자에는 운명이 존재하지 않으니까, 보이지 않았던 것뿐이다. "
    "俺の瞳には運命が存在しないから、見えなかっただけだ。"

# game/chapter6.rpy:187
translate japanese chapter6_f68cfae0:

    # voice "voices/ef3.ogg"
    # 유미 "“아니, 그게 아니라. 이미 고장 나 있었다고. 이 일이 있기 전부터.”"
    voice "voices/ef3.ogg"
    유미 "「違う、そうじゃなくて。もう壊れてたんだよ。この件が起きる前から。」"

# game/chapter6.rpy:191
translate japanese chapter6_fc585373:

    # voice ""
    # "운명이라는 태엽이 모두 풀린 인형같은 존재. "
    voice ""
    "運命というゼンマイがすべてほどけた人形のような存在。"

# game/chapter6.rpy:193
translate japanese chapter6_bc3a1256:

    # "나는 그 인형 속에 깃든 소라게임이 분명했다. "
    "俺はその人形の中に宿ったヤドカリに違いなかった。"

# game/chapter6.rpy:200
translate japanese chapter6_b99ad139:

    # "그리고 그 인형은, 말 그대로 현지의 운명 속에 휘말려버린 것이고 말이다. "
    "そしてその人形は、文字通りヒョンジの運命に巻き込まれてしまったというわけだ。"

# game/chapter6.rpy:203
translate japanese chapter6_58d38792:

    # voice "voices/hf12_1.ogg"
    # 현지 "“아마도 선배와 같이 있던 그 유령이 제 눈에서 봤던 건, 제 운명이 아니었을까 해요. 끔찍한, 유령이 기겁을 할 정도로 아주 끔찍한 운명이요.”"
    voice "voices/hf12_1.ogg"
    현지 "「おそらく先輩と一緒にいたあの幽霊が私の目に見たのは、私の運命だったんじゃないかと思うんです。おぞましい、幽霊が腰を抜かすほどおぞましい運命です。」"

# game/chapter6.rpy:205
translate japanese chapter6_7480b2d0:

    # voice "voices/hf12_2.ogg"
    # 현지 "“하지만 제 운명에는 없던 사람이 나타나서, 우연하게도 제 운명의 마지막 페이지가 변해 버린 거죠.”"
    voice "voices/hf12_2.ogg"
    현지 "「でも私の運命にはいなかった人が現れて、偶然にも私の運命の最後のページが変わってしまったんですよね。」"

# game/chapter6.rpy:208
translate japanese chapter6_e96f6b4d:

    # voice ""
    # 나 "“그렇구나. 우연이네.”"
    voice ""
    나 "「そうか。偶然だな。」"

# game/chapter6.rpy:210
translate japanese chapter6_39e3979c:

    # voice "voices/hf13.ogg"
    # 현지 "“맞아요, 우연이죠.”"
    voice "voices/hf13.ogg"
    현지 "「そうです、偶然ですよね。」"

# game/chapter6.rpy:212
translate japanese chapter6_1d749fcb:

    # voice ""
    # "나쁘지 않은 우연이라 생각하고는 하늘을 올려다보았다. "
    voice ""
    "悪くない偶然だと思い、空を見上げた。"

# game/chapter6.rpy:214
translate japanese chapter6_d98dc446:

    # "구름 한 점 없는 맑은 날씨였다. "
    "雲一つない澄んだ天気だった。"

# game/chapter6.rpy:215
translate japanese chapter6_f35a4f93:

    # "마치 그날처럼 나쁜 일이라고는 생길 것 같지 않은 그런 날씨. "
    "まるであの日のように、悪いことなど起きそうにないような天気。"

# game/chapter6.rpy:220
translate japanese chapter6_bb1e1fae:

    # voice "voices/hf14.ogg"
    # 현지 "“선배는 그 유령이 돌아오지 않을 거라 생각하는 거예요?”"
    voice "voices/hf14.ogg"
    현지 "「先輩はあの幽霊がもう戻ってこないと思ってるんですか？」"

# game/chapter6.rpy:222
translate japanese chapter6_0e9f78bb:

    # voice ""
    # 나 "“아마도 그렇겠지.”"
    voice ""
    나 "「たぶんそうだろうな。」"

# game/chapter6.rpy:224
translate japanese chapter6_03d1467f:

    # voice "voices/hf15.ogg"
    # 현지 "“선배, 선배가 그 유령을 만난 건 그냥 우연일까요?”"
    voice "voices/hf15.ogg"
    현지 "「先輩、先輩があの幽霊に出会ったのはただの偶然でしょうか？」"

# game/chapter6.rpy:226
translate japanese chapter6_520ed44d:

    # voice ""
    # 나 "“우연과 필연을 구분하지 못하는 게 사람이라면서?”"
    voice ""
    나 "「偶然と必然を区別できないのが人間だって言ってたじゃないか？」"

# game/chapter6.rpy:229
translate japanese chapter6_76f0e601:

    # voice "voices/hf16.ogg"
    # 현지 "“구분은 못 하겠지만, 추측은 할 수 있으니까요. 너무나도 잘 맞아떨어지는 우연은 필연일 수도 있는 거라고요. 마치 잘 설계된 시계 톱니바퀴가 돌아가듯 딱딱 맞아떨어지는 일은요.”"
    voice "voices/hf16.ogg"
    현지 "「区別はできませんけど、推測はできますから。あまりにもぴったり噛み合う偶然は必然かもしれないんですよ。よくできた時計の歯車がかちかちと噛み合うような偶然は。」"

# game/chapter6.rpy:231
translate japanese chapter6_2292a48a:

    # voice ""
    # 나 "“그런가.”"
    voice ""
    나 "「そうか。」"

# game/chapter6.rpy:237
translate japanese chapter6_7618cfc0:

    # "그렇다고는 해도, 복잡해진 생각들이 눌러앉은 사고 회로는 어느 순간부터 헛바퀴만을 빙빙 돌고 있었다. "
    "とはいえ、複雑になった考えが居座った思考回路は、いつからか空回りばかりしていた。"

# game/chapter6.rpy:239
translate japanese chapter6_c6724c64:

    # voice "voices/hf17.ogg"
    # 현지 "“그나저나, 운명이라거나 하는 이야기. 유미 언니는 별로 안 좋아하겠죠? 뭔가에 끌려다닌다는 거, 유미 언니는 엄청 싫어할 것 같아요.”"
    voice "voices/hf17.ogg"
    현지 "「そういえば、運命とかそういう話。ユミ姉さんはあんまり好きじゃなさそうですよね？何かに引きずられるっていうの、ユミ姉さんはすごく嫌がりそう。」"

# game/chapter6.rpy:245
translate japanese chapter6_0feee570:

    # voice ""
    # 나 "“으응……? 그 반대일지도 몰라. 생각보다 여린 애니까.”"
    voice ""
    나 "「ん……？逆かもしれないぞ。思ったより繊細なやつだから。」"

# game/chapter6.rpy:247
translate japanese chapter6_74c86e80:

    # voice "voices/hf18.ogg"
    # 현지 "“정말요? 유미 언니가요?”"
    voice "voices/hf18.ogg"
    현지 "「本当ですか？ユミ姉さんが？」"

# game/chapter6.rpy:252
translate japanese chapter6_5b6feb68:

    # voice ""
    # "갑작스러운 화제 전환에, 나는 여분의 사고 회로를 써가며 현지의 물음에 대답했다. "
    voice ""
    "唐突な話題の転換に、俺は余分の思考回路を使いながらヒョンジの問いに答えた。"

# game/chapter6.rpy:258
translate japanese chapter6_c707a384:

    # 나 "“여태껏 궁금했는데, 유미랑은 언제 친해진 거야?”"
    나 "「ずっと気になってたんだけど、ユミとはいつ仲良くなったんだ？」"

# game/chapter6.rpy:260
translate japanese chapter6_41bb06d0:

    # voice "voices/hf19.ogg"
    # 현지 "“어쩌다 보니까요. 선배랑 같은 동아리라고 유미 언니가 이것저것 챙겨준 거 있죠.”"
    voice "voices/hf19.ogg"
    현지 "「なんとなくです。先輩と同じ部活だからって、ユミ姉さんがいろいろ面倒見てくれたんですよ。」"

# game/chapter6.rpy:262
translate japanese chapter6_b0629a1d:

    # voice ""
    # 나 "“그런가. 역시 누구에게나 친절하네.”"
    voice ""
    나 "「そうか。やっぱり誰にでも親切だな。」"

# game/chapter6.rpy:265
translate japanese chapter6_601835e2:

    # voice "voices/hf20.ogg"
    # 현지 "“그런데 그건 갑자기 왜요?”"
    voice "voices/hf20.ogg"
    현지 "「ところでそれ急にどうしたんですか？」"

# game/chapter6.rpy:267
translate japanese chapter6_2bb25a5f:

    # voice ""
    # 나 "“아니, 별건 아냐. 언니라고 부르길래 이제서야 물어보는 거니까.”"
    voice ""
    나 "「いや、大したことじゃない。姉さんって呼んでるから今さら聞いてみただけだよ。」"

# game/chapter6.rpy:273
translate japanese chapter6_c20fd83f:

    # "집 앞에 도착한 나는 걸음을 멈추고는, 현지에게 인사를 건네려는 참이었다. "
    "家の前に着いた俺は足を止め、ヒョンジに挨拶をしようとしていた。"

# game/chapter6.rpy:274
translate japanese chapter6_810f29d7:

    # "손을 흔들기 위해 몸을 돌리려는데, 현지가 나의 앞에 폴짝 다가와서는 눈을 동그랗게 뜨고선 나를 올려다보았다. "
    "手を振ろうと振り返ろうとしたら、ヒョンジがぴょんと目の前に飛び出してきて、目を丸くして俺を見上げた。"

# game/chapter6.rpy:278
translate japanese chapter6_46d4e123:

    # voice "voices/hf21.ogg"
    # 현지 "“아하. 오빠라고 불러 줬으면 좋겠다는 거죠?”"
    voice "voices/hf21.ogg"
    현지 "「あはは。お兄ちゃんって呼んでほしいってことですよね？」"

# game/chapter6.rpy:280
translate japanese chapter6_0b716b72:

    # voice ""
    # 나 "“아, 아니. 그런 뜻은 아니었는데.”"
    voice ""
    나 "「い、いや。そういう意味じゃなかったんだけど。」"

# game/chapter6.rpy:283
translate japanese chapter6_cd86d268:

    # "당황한 듯 손사래를 치는 나에게, 현지가 웃음을 지어 보였다. "
    "慌てた様子で手を振る俺に、ヒョンジが笑みを浮かべた。"

# game/chapter6.rpy:284
translate japanese chapter6_06511722:

    # "엉성하게 손을 흔들며 집으로 들어가는 나의 뒤로 인삿말이 들려왔다. "
    "ぎこちなく手を振りながら家に入る俺の背中に、別れの挨拶が聞こえた。"

# game/chapter6.rpy:285
translate japanese chapter6_6fd60189:

    # "평소에 들었던 작별 인사와는 조금 다른 투의 목소리가, 오랫동안 귓가에 머물러 나를 간지럽혔다. "
    "いつもとは少し違う調子の声が、長いこと耳元に残って俺をくすぐった。"

# game/chapter6.rpy:294
translate japanese chapter6_fa4e44fe:

    # "석양이 비치고, 어둠이 차츰 하늘을 잠식하고 있었다."
    "夕陽が差し、闇が少しずつ空を蝕んでいた。"

# game/chapter6.rpy:295
translate japanese chapter6_9ba52d03:

    # "이대로 가만히 하루가 저무는 걸까."
    "このまま静かに一日が暮れていくのだろうか。"

# game/chapter6.rpy:296
translate japanese chapter6_4385beff:

    # "게임이나 영화 감상같은 시간을 죽이는 일이 너무나도 무의미하게 느껴져서였는지, 침대에 누워 하릴없이 시간을 보내는 수밖엔 달리 할 일이 없어 보였다. "
    "ゲームや映画鑑賞のような時間潰しがあまりにも無意味に感じられたからか、ベッドに横になってぼんやり過ごすしかなさそうだった。"

# game/chapter6.rpy:297
translate japanese chapter6_e9082b0b:

    # "이러고 있자니 정말 태엽이 다 풀려버린 인형처럼 보이는구나, 그런 생각이 들었다. "
    "こうしていると本当にゼンマイが全部ほどけた人形みたいだな、とそんなことを思った。"

# game/chapter6.rpy:302
translate japanese chapter6_2c1e71f4:

    # "몸을 비틀어 베개에 얼굴을 파묻으려다 말고, 나는 침대와 탁자 사이에 떨어져 있던 인형 하나를 발견했다. "
    "体をひねって枕に顔を埋めようとして、ベッドと机の間に落ちていた人形を一つ見つけた。"

# game/chapter6.rpy:303
translate japanese chapter6_95b64f29:

    # "어느새 시간은 소녀의 흔적에 먼지가 묻을 만큼 흘러가 있었다. "
    "いつの間にか、少女の痕跡に埃が積もるほど時間が過ぎていた。"

# game/chapter6.rpy:305
translate japanese chapter6_6ee221d5:

    # "팔을 뻗어 인형을 주워들었다. "
    "腕を伸ばして人形を拾い上げた。"

# game/chapter6.rpy:306
translate japanese chapter6_5bf0bb41:

    # "깔끔하게 마감이 된 테루테루인형. "
    "きれいに仕上げられたてるてる坊主。"

# game/chapter6.rpy:307
translate japanese chapter6_0d9c5d41:

    # "분명 내가 만든 인형이었다. "
    "確かに俺が作った人形だった。"

# game/chapter6.rpy:308
translate japanese chapter6_540f39d2:

    # "소녀는 그때, 내가 만든 인형을 보기 좋게 골랐던 것이다. "
    "少女はあの時、きれいに仕上がった俺の人形を選んでくれていたのだ。"

# game/chapter6.rpy:310
translate japanese chapter6_77762b54:

    # 나 "‘뿌듯해해야 하는 건가.’"
    나 "(誇らしく思うべきなのか。)"

# game/chapter6.rpy:315
translate japanese chapter6_2cdb0b9d:

    # "탁자 위에 인형을 올려두고선, 멍하니 그것을 바라보았다. "
    "机の上に人形を置いて、ぼんやりとそれを眺めた。"

# game/chapter6.rpy:316
translate japanese chapter6_3070e5a4:

    # "소녀도 이 인형처럼 어딘가에 홀로 남겨져 시간을 죽이고 있겠지. "
    "少女もこの人形のようにどこかに独り残されて時間を潰しているのだろう。"

# game/chapter6.rpy:318
translate japanese chapter6_bc9a78e8:

    # "어제도, 그제도, 소녀는 시간을 죽이고 있었을 것이다. "
    "昨日も、一昨日も、少女は時間を潰していたことだろう。"

# game/chapter6.rpy:320
translate japanese chapter6_c013382c:

    # "내일도, 모레도, 소녀는 시간을 죽일 것이다. "
    "明日も、明後日も、少女は時間を潰すのだろう。"

# game/chapter6.rpy:321
translate japanese chapter6_264527ae:

    # "어쩌면 내년도, 내후년도……. "
    "もしかしたら来年も、再来年も……。"

# game/chapter6.rpy:334
translate japanese chapter6_7f4f56d0:

    # "바로 옆에서 들려오는 진동 소리에 눈길을 옮겼다. "
    "すぐ横から聞こえる振動音に目を向けた。"

# game/chapter6.rpy:335
translate japanese chapter6_0cdcefdf:

    # "휴대용 태블릿에 문자 한 통이 방금 막 도착해 있었다. "
    "タブレットにメッセージが一通、ちょうど届いたところだった。"

# game/chapter6.rpy:336
translate japanese chapter6_0db6fbd2:

    # "이런 시간에 내게 문자를 보낼 사람이 현지 말고 있었던가. "
    "こんな時間に俺にメッセージを送る人間がヒョンジ以外にいただろうか。"

# game/chapter6.rpy:337
translate japanese chapter6_ee9d7471:

    # "손을 뻗어 태블릿을 집어 들고선 문자 내용을 확인했다. "
    "手を伸ばしてタブレットを取り上げ、メッセージの内容を確認した。"

# game/chapter6.rpy:339
translate japanese chapter6_0f10a9d9:

    # shnvl_yu "혹시 지금 학교로 와 줄 수 있어?"
    shnvl_yu "今から学校に来てもらえる？"

# game/chapter6.rpy:342
translate japanese chapter6_23856611:

    # "문자를 확인한 나는 고개를 돌려 베란다 쪽을 힐긋 바라보았다. "
    "メッセージを確認して首を回し、ベランダの方をちらりと見た。"

# game/chapter6.rpy:343
translate japanese chapter6_b67240f2:

    # "땅거미가 진 어스레한 지금, 갑자기 유미가 내게 문자로 이런 부탁을 건네왔다는 게 신기해서였을까. "
    "薄暗くなった今、急にユミがこんなお願いをメッセージで送ってきたのが不思議だったのか。"

# game/chapter6.rpy:344
translate japanese chapter6_37dc80d6:

    # "고개를 갸웃거리면서도 침대에서 일어나 학교로 향할 채비를 하며, 나는 유미에게 답장을 보냈다. "
    "首を傾げながらもベッドから起き上がり、学校へ向かう支度をしつつユミに返信を送った。"

# game/chapter6.rpy:346
translate japanese chapter6_9b493016:

    # shnvl_me "이 시간에 갑자기 학교는 무슨 일로?"
    shnvl_me "こんな時間に学校って何の用？"

# game/chapter6.rpy:348
translate japanese chapter6_5a885210:

    # "신발을 신고 현관문을 나서려는데, 다시금 문자가 도착했다. "
    "靴を履いて玄関を出ようとしたところに、またメッセージが届いた。"

# game/chapter6.rpy:352
translate japanese chapter6_7ba21180:

    # shnvl_yu "어쩌다 보니 1층 창고에 갇힌 것 같아서."
    shnvl_yu "なんか1階の倉庫に閉じ込められちゃったみたいで。"

# game/chapter6.rpy:353
translate japanese chapter6_82be3d3f:

    # shnvl_me "갇혔다고? 어쩌다가?"
    shnvl_me "閉じ込められた？どうやって？"

# game/chapter6.rpy:354
translate japanese chapter6_c928864d:

    # shnvl_yu "학예제 비품 정리하고 있었는데, 밖에서 안에 사람이 없는 줄 알고 잠가버렸나 봐."
    shnvl_yu "文化祭の備品を整理してたんだけど、外から中に人がいないと思って鍵かけちゃったみたい。"

# game/chapter6.rpy:355
translate japanese chapter6_42f27ebe:

    # shnvl_me "그럼 이 시간까지 학교에 남아 있었던 거야?"
    shnvl_me "じゃあこんな時間まで学校に残ってたのか？"

# game/chapter6.rpy:363
translate japanese chapter6_629a54aa:

    # "답장을 기다리며 학교를 향해 약간은 빠른 걸음으로 움직이기 시작했다. "
    "返信を待ちながら学校に向かって少し早足で歩き始めた。"

# game/chapter6.rpy:364
translate japanese chapter6_cb610c52:

    # "태블릿을 들여다보며 길을 걷고 있었지만, 이상하게도 유미의 답장이 늦는 것 같았다. "
    "タブレットを覗き込みながら歩いていたが、妙にユミの返信が遅い気がした。"

# game/chapter6.rpy:366
translate japanese chapter6_14c7631d:

    # shnvl_me "금방 갈게. 조금만 기다려."
    shnvl_me "すぐ行くから。もう少し待ってて。"

# game/chapter6.rpy:368
translate japanese chapter6_df48d4f7:

    # "이상하다고 느낀 건 그런 내용의 문자를 보내고 난 뒤였다. "
    "おかしいと感じたのは、そのメッセージを送った後だった。"

# game/chapter6.rpy:369
translate japanese chapter6_55d15fcc:

    # "몇 분을 더 기다려도 답장은커녕 내가 보낸 문자를 유미가 확인조차 하지 못하고 있다는 것을 알아채고선, 나는 발걸음을 서두르기 시작했다. "
    "数分待っても返信どころか、送ったメッセージをユミが既読にすらしていないことに気づき、足を速め始めた。"

# game/chapter6.rpy:371
translate japanese chapter6_19c8d88e:

    # "‘무슨 일이라도 있는 건 아니겠지…….’"
    "(何かあったわけじゃないよな……。)"

# game/chapter6.rpy:373
translate japanese chapter6_7497a5e9:

    # "평소 같았다면 별일 아닐 거라 여기며 천천히 학교로 걸어갔을 테지만, 나도 모르는 새 비현실에 물들어버린 걸까. "
    "いつもなら大したことないだろうとのんびり学校へ歩いて行ったはずだが、気づかないうちに非日常の空気に染まってしまったのだろうか。"

# game/chapter6.rpy:374
translate japanese chapter6_ec06036a:

    # "십여 분 정도를 뛰어 학교에 도착한 나는 교무실에서 열쇠를 챙겨 곧장 아래층의 비품 창고로 향했다. "
    "十数分ほど走って学校に着くと、職員室で鍵を取ってまっすぐ下の階の備品倉庫へ向かった。"

# game/chapter6.rpy:380
translate japanese chapter6_86297097:

    # "서투른 손길로 비품 창고의 열쇠를 꺼내 들고선 열쇠 구명에 욱여넣자 덜컥이는 소리와 함께 문이 열렸다. "
    "不慣れな手つきで備品倉庫の鍵を取り出し、鍵穴にねじ込むとがちゃりという音とともにドアが開いた。"

# game/chapter6.rpy:382
translate japanese chapter6_fe74be26:

    # 나 "“거기 있어?”"
    나 "「そこにいるか？」"

# game/chapter6.rpy:384
translate japanese chapter6_27f09ea8:

    # "분명 이곳에 있다고 했었을 텐데, 어째서인지 비품 창고는 불도 켜지지 않은 채 정적에 잠겨있었다. "
    "ここにいると言っていたはずなのに、どういうわけか備品倉庫は電気もついておらず静まり返っていた。"

# game/chapter6.rpy:389
translate japanese chapter6_166a2d01:

    # "손을 더듬어 스위치를 켜자, 순식간에 비품 창고의 윤곽이 드러났다. "
    "手探りでスイッチを入れると、一瞬で備品倉庫の輪郭が浮かび上がった。"

# game/chapter6.rpy:394
translate japanese chapter6_e76ebc0c:

    # "유미의 흔적을 찾아 주변을 훑어보았다. "
    "ユミの気配を探して辺りを見回した。"

# game/chapter6.rpy:395
translate japanese chapter6_5039d94d:

    # "어렴풋이 느껴지는 그녀의 온기를 좇아 시선이 향한 곳은 비품이 잔뜩 쌓여있는 박스 더미 뒤편이었다. "
    "かすかに感じる温もりを追って視線が向いた先は、備品がうず高く積まれた段ボールの山の裏側だった。"

# game/chapter6.rpy:399
translate japanese chapter6_68047eb0:

    # 나 "“다 보이거든, 뒤에 숨어 있는 거.”"
    나 "「全部見えてるぞ、後ろに隠れてるの。」"

# game/chapter6.rpy:401
translate japanese chapter6_afda8454:

    # "혹시나 큰일이 일어난 건 아닐까 하는 생각에 심장이 조금은 평소보다 빠르게 뛰고 있었던 것 같기도 했다. "
    "何か大変なことがあったのではないかという思いに、心臓がいつもより少し速く脈打っていた気もした。"

# game/chapter6.rpy:402
translate japanese chapter6_3b9ec35a:

    # "박스 더미 뒤편에서 자신의 갈색빛 머리카락을 미처 숨기지 못하고 쪼그려 앉아있던 유미가 나의 목소리를 듣고 천천히 몸을 일으켰다. "
    "段ボールの山の裏で茶色い髪を隠しきれずにしゃがんでいたユミが、俺の声を聞いてゆっくりと立ち上がった。"

# game/chapter6.rpy:407
translate japanese chapter6_8f9e8531:

    # voice "voices/yf8.ogg"
    # 유미 "“에이, 놀래켜주려고 했는데. 벌써 도착해 버렸네.”"
    voice "voices/yf8.ogg"
    유미 "「えー、驚かそうと思ったのに。もう着いちゃったの。」"

# game/chapter6.rpy:409
translate japanese chapter6_7abc2c84:

    # voice ""
    # 나 "“그래서 일부러 문자도 안 받고 있었던 거야?”"
    voice ""
    나 "「だからわざとメッセージも見なかったのか？」"

# game/chapter6.rpy:412
translate japanese chapter6_2271d4ce:

    # "허무한 듯한 목소리와 불만이 묻어나는 투의 목소리가 서로에게 교차한다. "
    "呆れたような声と不満のにじむ声が交差する。"

# game/chapter6.rpy:414
translate japanese chapter6_0a0ce40a:

    # voice "voices/yf9.ogg"
    # 유미 "“응? 아아, 일부러 그런 건 아니고. 하필 그때 태블릿 배터리가 방전되어 버렸지 뭐야.”"
    voice "voices/yf9.ogg"
    유미 "「ん？ああ、わざとじゃないよ。よりによってあの時タブレットのバッテリーが切れちゃったんだよ。」"

# game/chapter6.rpy:416
translate japanese chapter6_dc50300a:

    # voice ""
    # "멋쩍은 웃음과 함께, 유미는 주머니에서 작동하지 않는 태블릿을 꺼내 내게 보여주었다. "
    voice ""
    "照れくさそうに笑いながら、ユミはポケットから動かなくなったタブレットを取り出して見せた。"

# game/chapter6.rpy:418
translate japanese chapter6_7cd7e9a2:

    # "나는 반쯤은 어이없다는 표정과 함께 안도의 한숨을 내쉬었다. "
    "半ば呆れた顔をしながら安堵のため息をついた。"

# game/chapter6.rpy:419
translate japanese chapter6_d40665f9:

    # "나의 표정을 유심히 살피고 있던 유미가 내게 한 발짝 더 가까이 다가왔다. "
    "俺の表情をじっと窺っていたユミが、一歩近づいてきた。"

# game/chapter6.rpy:424
translate japanese chapter6_e7360e90:

    # voice "voices/yf10.ogg"
    # 유미 "“왜 그래? 혹시 나 걱정하고 있었어?”"
    voice "voices/yf10.ogg"
    유미 "「どうしたの？もしかして心配してた？」"

# game/chapter6.rpy:426
translate japanese chapter6_fb4acc83:

    # voice ""
    # 나 "“그거야 당연히, 덜컥 연락도 끊겨 버렸으니까…….”"
    voice ""
    나 "「そりゃ当然、急に連絡も途絶えたんだから……。」"

# game/chapter6.rpy:429
translate japanese chapter6_b0d94223:

    # "유미가 내게 한 발짝 더 다가오자 나는 무의식적으로 발걸음을 뒤로 한 발짝 물렸다. "
    "ユミがもう一歩近づいてくると、俺は無意識に一歩後ずさった。"

# game/chapter6.rpy:430
translate japanese chapter6_af890938:

    # "학교까지 뛰어오느라 숨이 차는 바람에 평소보다 빠르게 뛰고 있던 심장이 곡해의 여지를 남길 수도 있지 않을까 하는 생각에서였는지는, 나도 잘 기억이 나지 않는다. "
    "学校まで走ってきて息が上がり、いつもより速く打っている心臓が誤解を生みかねないと思ったからなのかは、自分でもよく覚えていない。"

# game/chapter6.rpy:431
translate japanese chapter6_c0268332:

    # "다만, 걱정이라는 말은 분명히 신경 쓰일 정도로 뛰고 있던 내 심장에 자극적으로 다가왔던 모양이었다. "
    "ただ、\"心配\"という言葉は、気になるほど速く打っていた心臓にやけに刺さったらしい。"

# game/chapter6.rpy:433
translate japanese chapter6_8b390d88:

    # 나 "“이런 기분이었겠구나.”"
    나 "「こんな気持ちだったんだな。」"

# game/chapter6.rpy:435
translate japanese chapter6_5694b623:

    # voice "voices/yf11.ogg"
    # 유미 "“응? 이런 기분이었겠다니?”"
    voice "voices/yf11.ogg"
    유미 "「ん？こんな気持ちって？」"

# game/chapter6.rpy:437
translate japanese chapter6_2bcd6ed5:

    # voice ""
    # 나 "“걱정 끼친다는 거 말이야.”"
    voice ""
    나 "「心配かけるなって気持ちだよ。」"

# game/chapter6.rpy:440
translate japanese chapter6_8b0dea2a:

    # voice "voices/yf12.ogg"
    # 유미 "“뭐야, 걱정해 준 거 맞았네~”"
    voice "voices/yf12.ogg"
    유미 "「なんだ、心配してくれてたんだ～」"

# game/chapter6.rpy:442
translate japanese chapter6_a44e03ca:

    # voice ""
    # 나 "“어쨌거나 다행이다. 별일 없어서.”"
    voice ""
    나 "「とにかく、よかった。何もなくて。」"

# game/chapter6.rpy:457
translate japanese ecg12_label_79f4481a:

    # "긴장이 사그라들자 그대로 다리에 힘이 풀린 나는 그대로 그 자리에 풀썩 주저앉아 버렸다. "
    "緊張がほぐれると、そのまま足から力が抜けてその場にへたり込んでしまった。"

# game/chapter6.rpy:458
translate japanese ecg12_label_cacae80e:

    # "먼지가 적당히 내려앉은 비품 창고에 쪼그려 앉아, 나는 잠시 그곳의 퀘퀘한 공기를 묵묵히 마셨다. "
    "埃がほどよく積もった備品倉庫にしゃがみ込み、しばらくそこの淀んだ空気を黙って吸い込んだ。"

# game/chapter6.rpy:459
translate japanese ecg12_label_3f6153a3:

    # "회색으로 정의될 만한 가라앉은 공기가 조잡하게 뛰고 있던 나의 심장을 조금씩 진정시키고 있었다. "
    "灰色と呼ぶにふさわしい沈んだ空気が、荒く鳴っていた心臓を少しずつ落ち着かせていた。"

# game/chapter6.rpy:468
translate japanese ecg12_label_116adc06:

    # voice "voices/yf13.ogg"
    # 유미 "“밖엔 누구 없었어?”"
    voice "voices/yf13.ogg"
    유미 "「外には誰もいなかった？」"

# game/chapter6.rpy:470
translate japanese ecg12_label_5d85812a:

    # voice ""
    # "바닥에 쪼그려 앉아 캠프파이어에서의 모닥불처럼 유미를 바라보고 있던 나의 곁으로 그녀가 다가왔다. "
    voice ""
    "床にしゃがみ込み、キャンプファイヤーの焚き火のようにユミを眺めていた俺のそばに、彼女が近づいてきた。"

# game/chapter6.rpy:473
translate japanese ecg12_label_87f07574:

    # 나 "“이 시간에 학교에 누가 남아있다고. 아무도 없었거든.”"
    나 "「こんな時間に学校に誰が残ってるんだよ。誰もいなかったよ。」"

# game/chapter6.rpy:475
translate japanese ecg12_label_8e3d6fac:

    # voice "voices/yf14.ogg"
    # 유미 "“그래?”"
    voice "voices/yf14.ogg"
    유미 "「そう？」"

# game/chapter6.rpy:477
translate japanese ecg12_label_3ad45685:

    # voice ""
    # "미묘하게 핀잔 섞인 투의, 걱정하는 차원에서의 대답이 유미에게는 어떻게 건네졌는지는 잘 모르겠다. "
    voice ""
    "微妙に小言交じりの、心配ゆえの返事がユミにどう伝わったのかはよく分からない。"

# game/chapter6.rpy:479
translate japanese ecg12_label_4741b93c:

    # "나의 바로 옆으로 다가선 유미는 그대로 바닥에 몸을 주저앉혔다. "
    "俺のすぐ隣に来たユミは、そのまま床に腰を下ろした。"

# game/chapter6.rpy:480
translate japanese ecg12_label_9a8d4548:

    # "눈을 둘 모닥불이 사그라든 나의 시선이 허공을 뱅뱅 맴돈다. "
    "目をやる焚き火が消えた俺の視線が、宙をぐるぐると彷徨う。"

# game/chapter6.rpy:487
translate japanese ecg12_label_df65c5ad:

    # voice "voices/yf15.ogg"
    # 유미 "“그럼 여긴 우리 둘밖에 안 남은 거네.”"
    voice "voices/yf15.ogg"
    유미 "「じゃあここには私たち二人しか残ってないんだ。」"

# game/chapter6.rpy:490
translate japanese ecg12_label_649ee2ff:

    # voice ""
    # 나 "“…… 갑자기 그게 뭐야.”"
    voice ""
    나 "「……急になんだよ。」"

# game/chapter6.rpy:493
translate japanese ecg12_label_7fbd7d33:

    # "그런 이야기를 꺼내고 얼마가 지났을까. "
    "そんな話を切り出してからどれくらい経っただろう。"

# game/chapter6.rpy:499
translate japanese ecg12_label_32f9e53b:

    # "회색의 공기가 어색함에 힘입어 무게를 더하고 있을 때쯤, 유미가 갑자기 일어서서는 창고 문 쪽으로 다가갔다. "
    "灰色の空気が気まずさに後押しされて重みを増していた頃、ユミが急に立ち上がって倉庫の扉のほうへ向かった。"

# game/chapter6.rpy:501
translate japanese ecg12_label_e8e2c78c:

    # "하긴, 비품 창고 안에서 얼마나 더 앉아있으려는 건지. "
    "まあ、備品倉庫の中にいつまで座っているつもりだったのか。"

# game/chapter6.rpy:504
translate japanese ecg12_label_e0f08e26:

    # "이제 슬슬 밖으로 나가봐야겠다는 생각에 몸을 일으키려는데, 덜컥 하는 소리가 문에서 들려왔다. "
    "そろそろ外に出ようと体を起こしかけたとき、ガチャリという音が扉のほうから聞こえた。"

# game/chapter6.rpy:505
translate japanese ecg12_label_de0743fc:

    # "문이 닫히는 소리였다. "
    "扉が閉まる音だった。"

# game/chapter6.rpy:507
translate japanese ecg12_label_396673fa:

    # 나 "“…….”"
    나 "「……」"

# game/chapter6.rpy:512
translate japanese ecg12_label_6999233e:

    # "유미가 내게 다가온다. "
    "ユミが俺に近づいてくる。"

# game/chapter6.rpy:513
translate japanese ecg12_label_f042693b:

    # "그저 텁텁하게만 느껴졌던 창고의 공기가 한순간에 싸늘한 입김으로 변해 나를 옭아맨다. "
    "ただ淀んでいるだけだった倉庫の空気が、一瞬にして冷たい息吹に変わり、俺を縛りつける。"

# game/chapter6.rpy:514
translate japanese ecg12_label_67f86b31:

    # "온몸이 순식간에 고치가 된 것처럼 칭칭 엉겨붙은 듯한 감각. "
    "全身が一瞬にして繭になったかのように、ぐるぐると絡みつくような感覚。"

# game/chapter6.rpy:515
translate japanese ecg12_label_301d4621:

    # "일전에 엘리베이터에서 느꼈던 그 심상찮은 감각이 나를 죄여왔다. "
    "以前エレベーターで感じたあの尋常でない感覚が、俺を締めつけてきた。"

# game/chapter6.rpy:517
translate japanese ecg12_label_9c90a47f:

    # voice "voices/yf16.ogg"
    # 유미 "“저기―――”"
    voice "voices/yf16.ogg"
    유미 "「あの———」"

# game/chapter6.rpy:519
translate japanese ecg12_label_8f3bc5c4:

    # voice ""
    # "제 궤도를 되찾아가던 심장박동은 여태까지의 호흡이 무색할 정도로 쿵쾅거리고 있었다. "
    voice ""
    "平常に戻りかけた心拍は、それまでの呼吸が無意味に思えるほどにドクドクと脈打っていた。"

# game/chapter6.rpy:521
translate japanese ecg12_label_69730c73:

    # "바닥이 흔들리고, 무너져 내리기 시작했다. "
    "床が揺れ、崩れ落ち始めた。"

# game/chapter6.rpy:524
translate japanese ecg12_label_d9bb548f:

    # "나에게 걸어오던 유미가 사라졌다. "
    "俺に向かって歩いてきていたユミが消えた。"

# game/chapter6.rpy:528
translate japanese ecg12_label_bf81a4e2:

    # "눈앞에서 유미만 사라진 건 아니었지만 말이다. "
    "目の前からユミだけが消えたわけではなかったが。"

# game/chapter6.rpy:529
translate japanese ecg12_label_95b7968e:

    # "시야에 보이던 모든 것들이 사라진 뒤였다. "
    "視界にあったすべてのものが消えた後だった。"

# game/chapter6.rpy:530
translate japanese ecg12_label_30f141ac:

    # "아무것도 보이지 않는 어둠이 눈앞에 펼쳐져 있었다. "
    "何も見えない闇が目の前に広がっていた。"

# game/chapter6.rpy:533
translate japanese ecg12_label_a60f6c27:

    # "호흡이 가빠져 왔다. "
    "息が荒くなってきた。"

# game/chapter6.rpy:534
translate japanese ecg12_label_346c188e:

    # "혹시 이곳에는 호흡할 만한 공기조차 남아있지 않은 걸까. "
    "もしかして、ここには呼吸できる空気すら残っていないのだろうか。"

# game/chapter6.rpy:535
translate japanese ecg12_label_be25e4d1:

    # "그런 생각이 들려는 찰나, 어디에선가 익숙한 목소리가 들려왔다. "
    "そう思いかけた刹那、どこからか聞き覚えのある声が聞こえてきた。"

# game/chapter6.rpy:537
translate japanese ecg12_label_21e8c84e:

    # voice "voices/gf3.ogg"
    # who "“기다리고 있을게.”"
    voice "voices/gf3.ogg"
    who "「待ってるから。」"

# game/chapter6.rpy:540
translate japanese ecg12_label_f557443c:

    # voice ""
    # "그 목소리를 신호로, 나는 깊은 숨을 들이마셨다. "
    voice ""
    "その声を合図に、俺は深く息を吸い込んだ。"

# game/chapter6.rpy:543
translate japanese ecg12_label_4410315a:

    # "그리고 소리가 들려온 곳으로 고개를 돌리자, 그곳에는―――"
    "そして声の聞こえた方へ顔を向けると、そこには———"

# game/chapter6.rpy:546
translate japanese ecg12_label_2e0a9804:

    # 나 "“…… 어째서?”"
    나 "「……どうして？」"

# game/chapter6.rpy:548
translate japanese ecg12_label_99c7d4c2:

    # "그곳에는, 나를 바라보며 싱긋 웃어 보이는 소녀가 있었다. "
    "そこには、俺を見つめてにっこり微笑む少女がいた。"

# game/chapter6.rpy:556
translate japanese ecg12_label_3df01ab6:

    # "오직 그 한 마디를 끝으로, 소녀는 나의 눈앞에서 아스라이 사라져갔다. "
    "その一言だけを残して、少女は俺の目の前からおぼろげに消えていった。"

# game/chapter6.rpy:558
translate japanese ecg12_label_48db3a95:

    # "그녀를 향해 손을 뻗으려는 순간. "
    "彼女に向かって手を伸ばそうとした瞬間。"

# game/chapter6.rpy:567
translate japanese ecg12_label_de36d45c:

    # 나 "“우왓―――”"
    나 "「うわっ———」"

# game/chapter6.rpy:571
translate japanese ecg12_label_5224605f:

    # "정신이 들었다. "
    "我に返った。"

# game/chapter6.rpy:572
translate japanese ecg12_label_724d5915:

    # "그대로였다. "
    "何も変わっていなかった。"

# game/chapter6.rpy:573
translate japanese ecg12_label_a44f3ac9:

    # "퀘퀘한 밀실의 공기도, 나의 곁에 있던 유미도. "
    "淀んだ密室の空気も、俺のそばにいたユミも。"

# game/chapter6.rpy:574
translate japanese ecg12_label_cdfb09ab:

    # "나는 허공을 향해 뻗으려던 손을 아무 일도 없었다는 듯 거두며 유미를 바라보았다. "
    "俺は宙に伸ばしかけた手を何事もなかったかのように引っ込め、ユミを見た。"

# game/chapter6.rpy:576
translate japanese ecg12_label_44967355:

    # voice "voices/yf17.ogg"
    # 유미 "“…… 왜 그래?”"
    voice "voices/yf17.ogg"
    유미 "「……どうしたの？」"

# game/chapter6.rpy:578
translate japanese ecg12_label_b8c804dd:

    # voice ""
    # 나 "“…… 나, 폐소 공포증이 있어서.”"
    voice ""
    나 "「……俺、閉所恐怖症があって。」"

# game/chapter6.rpy:581
translate japanese ecg12_label_e3c4cc5f:

    # voice "voices/yf18.ogg"
    # 유미 "“앗, 정말? 미안, 그런 것도 모르고…….”"
    voice "voices/yf18.ogg"
    유미 "「あ、本当？ ごめん、そんなことも知らないで……」"

# game/chapter6.rpy:583
translate japanese ecg12_label_792ab90a:

    # voice ""
    # 나 "“괜찮아. 일단 밖으로 좀 나가자.”"
    voice ""
    나 "「大丈夫。とりあえず外に出よう。」"

# game/chapter6.rpy:585
translate japanese ecg12_label_f6784bf0:

    # voice "voices/yf19.ogg"
    # 유미 "“으응…….”"
    voice "voices/yf19.ogg"
    유미 "「うん……」"

# game/chapter6.rpy:590
translate japanese ecg12_label_0e6ca84b:

    # voice ""
    # "숨을 크게 두어 번 정도 내쉬었지만, 두 번의 호흡 모두 미묘한 떨림을 이루고 있었다. "
    voice ""
    "大きく二度ほど息を吐いたが、どちらの呼吸も微かに震えていた。"

# game/chapter6.rpy:592
translate japanese ecg12_label_2d652f96:

    # "어째서였을까. "
    "どうしてだったのだろう。"

# game/chapter6.rpy:593
translate japanese ecg12_label_53bd5a24:

    # "그 짤막한 순간 나의 앞에 소녀가 나타났던 건. "
    "あの短い瞬間、俺の前に少女が現れたのは。"

# game/chapter6.rpy:594
translate japanese ecg12_label_250e309e:

    # "그리고, 기다리고 있겠다는 알 수 없는 이야기를 한 건……. "
    "そして、待っていると言った意味の分からない言葉のことも……"

# game/chapter6.rpy:600
translate japanese ecg12_label_64ecc60f:

    # 나 "“그나저나, 이렇게 늦은 시간까지 학교에 남아 있었던 거야?”"
    나 "「それはそうと、こんな遅くまで学校に残ってたのか？」"

# game/chapter6.rpy:601
translate japanese ecg12_label_8f5e8f87:

    # voice "voices/yf20.ogg"
    # 유미 "“그게, 할 일이 너무 많아서 말야. 학예제때 쓸 물건들 정리하다 보니까 그만…….”"
    voice "voices/yf20.ogg"
    유미 "「それが、やることが多すぎてさ。文化祭で使うものを整理してたらつい……」"

# game/chapter6.rpy:603
translate japanese ecg12_label_862b0b44:

    # voice ""
    # 나 "“그렇구나.”"
    voice ""
    나 "「そうか。」"

# game/chapter6.rpy:606
translate japanese ecg12_label_c3113dcd:

    # "단둘만이 남겨진 학교 복도에는 묘한 적막감이 감돌았다. "
    "二人きりになった学校の廊下には、妙な静けさが漂っていた。"

# game/chapter6.rpy:608
translate japanese ecg12_label_cd15a7dc:

    # "평소에는 항상 이런저런 소리로 가득 차 있던 복도는 단 두 사람만의 소리로는 가득 차지 않는구나, 라는 생각이 들려는 즈음이었다. "
    "普段はいつもいろんな音で溢れている廊下は、たった二人の音だけでは満たされないんだな、と思いかけた頃だった。"

# game/chapter6.rpy:619
translate japanese ecg12_label_17ac3b82:

    # voice "voices/yf21.ogg"
    # 유미 "“아, 아니, 그러니까, 이건…….”"
    voice "voices/yf21.ogg"
    유미 "「い、いや、だから、これは……」"

# game/chapter6.rpy:621
translate japanese ecg12_label_704f0056:

    # voice ""
    # "복도를 걷던 유미의 발걸음이 우뚝 멈춰 선다. "
    voice ""
    "廊下を歩いていたユミの足がぴたりと止まる。"

# game/chapter6.rpy:623
translate japanese ecg12_label_d431c0cc:

    # "어디선가 들려온 꼬르륵대는 소리가, 나와 유미의 발걸음을 멈춰 세운 것이다. "
    "どこからか聞こえてきたお腹の鳴る音が、俺とユミの足を止めたのだ。"

# game/chapter6.rpy:625
translate japanese ecg12_label_6b1bd782:

    # 나 "“그러고 보니 여태껏 저녁도 안 먹었겠네.”"
    나 "「そういえば、ずっと晩ご飯も食べてなかったんじゃないか。」"

# game/chapter6.rpy:627
translate japanese ecg12_label_4c4db79e:

    # voice "voices/yf22.ogg"
    # 유미 "“아, 아냐! 그렇게 배 안 고파. 이건 그냥 배가 제멋대로…….”"
    voice "voices/yf22.ogg"
    유미 "「い、いや！ そんなにお腹空いてないから。これはただお腹が勝手に……」"

# game/chapter6.rpy:629
translate japanese ecg12_label_ec958748:

    # voice ""
    # 나 "“그래? 난 배고프던 참이었는데.”"
    voice ""
    나 "「そう？ 俺はちょうど腹減ってたところだけど。」"

# game/chapter6.rpy:632
translate japanese ecg12_label_b8d754f7:

    # "손사래를 치던 유미는 나의 말에 의외라는 표정을 지어 보이며 반응했다. "
    "手を振っていたユミは、俺の言葉に意外そうな表情を見せた。"

# game/chapter6.rpy:634
translate japanese ecg12_label_39659202:

    # voice "voices/yf23.ogg"
    # 유미 "“으응……? 아직 저녁 안 먹었어? 저녁 시간은 한참 지났는데.”"
    voice "voices/yf23.ogg"
    유미 "「ん……？ まだ晩ご飯食べてないの？ とっくに夕飯の時間過ぎてるのに。」"

# game/chapter6.rpy:636
translate japanese ecg12_label_4d0848b2:

    # voice ""
    # 나 "“생각할 게 좀 있어서. 저녁 시간을 그만 놓쳐 버린 거 있지.”"
    voice ""
    나 "「ちょっと考え事があって。それで夕飯の時間を逃しちまったんだよ。」"

# game/chapter6.rpy:639
translate japanese ecg12_label_5f4eab6d:

    # voice "voices/yf24.ogg"
    # 유미 "“생각할 거?”"
    voice "voices/yf24.ogg"
    유미 "「考え事？」"

# game/chapter6.rpy:641
translate japanese ecg12_label_a42cca19:

    # voice ""
    # 나 "“뭐어…… 그런 게 있어.”"
    voice ""
    나 "「まあ……そういうのがあるんだよ。」"

# game/chapter6.rpy:648
translate japanese ecg12_label_7a283d07:

    # "그런 이야기를 하며, 나는 짤막한 웃음을 유미에게 흘려 보였다. "
    "そんな話をしながら、俺はユミに短い笑みを漏らした。"

# game/chapter6.rpy:649
translate japanese ecg12_label_0cd1d338:

    # "웃음에 약간은 멋쩍은 기색이 묻어있던 건, 방금 전 창고에서 보았던 소녀의 허상이 떠올라서였을까. "
    "笑みにわずかなぎこちなさが滲んでいたのは、さっき倉庫で見た少女の幻影が頭をよぎったからだろうか。"

# game/chapter6.rpy:656
translate japanese ecg12_label_a76a8f94:

    # voice "voices/yf25.ogg"
    # 유미 "“그럼 우리 저녁 같이 먹을래?”"
    voice "voices/yf25.ogg"
    유미 "「じゃあ一緒に晩ご飯食べない？」"

# game/chapter6.rpy:658
translate japanese ecg12_label_9d128ec7:

    # voice ""
    # 나 "“그럴까. 뭐 먹고 싶은 거라도 있어?”"
    voice ""
    나 "「そうするか。何か食べたいものでもあるのか？」"

# game/chapter6.rpy:661
translate japanese ecg12_label_2b6901e9:

    # voice "voices/yf26.ogg"
    # 유미 "“음…… 나 갑자기 파스타 먹고 싶어졌어!”"
    voice "voices/yf26.ogg"
    유미 "「うーん……私、急にパスタ食べたくなっちゃった！」"

# game/chapter6.rpy:663
translate japanese ecg12_label_c29599a9:

    # voice ""
    # 나 "“그럼 그러는 걸로.”"
    voice ""
    나 "「じゃあそれで。」"

# game/chapter6.rpy:666
translate japanese ecg12_label_5f4fc900:

    # "한 치의 고민도 없이 메뉴가 정해지고, 나의 앞으로 폴짝 뛰어 앞장서게 된 유미가 내게 손을 불쑥 내밀었다. "
    "一切の迷いなくメニューが決まり、俺の前にぴょんと飛び出して先頭に立ったユミが、ぬっと手を差し出した。"

# game/chapter6.rpy:671
translate japanese ecg12_label_1fed1987:

    # voice "voices/yf27.ogg"
    # 유미 "“배고파, 빨리 가자~”"
    voice "voices/yf27.ogg"
    유미 "「お腹空いた、早く行こ～」"

# game/chapter6.rpy:673
translate japanese ecg12_label_4e0944ab:

    # voice ""
    # "방금 전까지만 해도 괜찮다고 손사래를 치던 여학생은 어디로 간 건지. "
    voice ""
    "さっきまで大丈夫だと遠慮していた女の子はどこへ行ったのやら。"

# game/chapter6.rpy:675
translate japanese ecg12_label_d7cfe839:

    # "가벼운 웃음을 내뱉고선 그대로 걸음을 서두르려는데, 눈앞에 놓인 유미의 손길이 살랑살랑 흔들렸다. "
    "軽く笑って足を速めようとしたが、目の前にあるユミの手がひらひらと揺れていた。"

# game/chapter6.rpy:680
translate japanese ecg12_label_396673fa_1:

    # 나 "“…….”"
    나 "「……」"

# game/chapter6.rpy:682
translate japanese ecg12_label_68f74d0e:

    # "팔 아프다는 무언의 메시지를 전달하려는 듯한 눈치일까. "
    "腕が疲れたという無言のメッセージを伝えようとしているのだろうか。"

# game/chapter6.rpy:683
translate japanese ecg12_label_7562687a:

    # "나는 엉성하게 유미가 건넨 손을 붙잡고는, 그녀의 손에 이끌려 발걸음을 옮기게 되어버렸다. "
    "俺はぎこちなくユミの差し出した手を掴み、彼女の手に引かれるまま歩き出していた。"

# game/chapter6.rpy:687
translate japanese ecg12_label_a8409cf6:

    # "하굣길을 따라 몇 분 정도를 걸었을까, 사거리에서 조금 떨어진 곳에 위치한 식당 하나를 가리키며 유미가 말했다. "
    "下校路を数分ほど歩いただろうか、交差点から少し離れた場所にある食堂を指さしてユミが言った。"

# game/chapter6.rpy:689
translate japanese ecg12_label_598504be:

    # voice "voices/yf28.ogg"
    # 유미 "“아, 저기다, 저기.”"
    voice "voices/yf28.ogg"
    유미 "「あ、あそこだ、あそこ。」"

# game/chapter6.rpy:691
translate japanese ecg12_label_4c6a03e7:

    # voice ""
    # 나 "“분위기 좋아 보이는 레스토랑이네.”"
    voice ""
    나 "「雰囲気よさそうなレストランだな。」"

# game/chapter6.rpy:693
translate japanese ecg12_label_808003de:

    # voice "voices/yf29.ogg"
    # 유미 "“얼른 들어가자~”"
    voice "voices/yf29.ogg"
    유미 "「早く入ろ～」"

# game/chapter6.rpy:696
translate japanese ecg12_label_0ff7b88c:

    # voice ""
    # "어느새 나의 등 뒤에 서 있던 유미에게 떠밀려, 나는 계단을 올라 레스토랑의 문을 열고 있었다. "
    voice ""
    "いつの間にか後ろに立っていたユミに背中を押され、俺は階段を上ってレストランの扉を開けていた。"

# game/chapter6.rpy:703
translate japanese ecg12_label_2474d007:

    # "문을 열자 아늑한 고딕풍의 분위기가 에어컨 바람에 뒤섞여 느껴졌다. "
    "扉を開けると、落ち着いたゴシック調の雰囲気がエアコンの風に混じって感じられた。"

# game/chapter6.rpy:704
translate japanese ecg12_label_eaa31134:

    # "식사 시간이 한참 지나서인지, 식당에는 나와 유미 단둘밖에 없는 듯했다. "
    "ピークタイムをとっくに過ぎていたからか、店には俺とユミの二人しかいないようだった。"

# game/chapter6.rpy:706
translate japanese ecg12_label_c1a80365:

    # voice "voices/yf30.ogg"
    # 유미 "“가족이랑 같이 왔을 땐 사람이 제법 많았었는데, 밥때가 지나서 그런가. 되게 썰렁하네.”"
    voice "voices/yf30.ogg"
    유미 "「前に家族と来たときは結構人がいたんだけど、ご飯時を過ぎたからかな。すごく寂しいね。」"

# game/chapter6.rpy:708
translate japanese ecg12_label_5edb622a:

    # voice ""
    # "식사 시간을 놓쳐 식당을 찾는 일이 요즘 들어 잦아진 것 같다고 속으로 생각하며 주변을 둘러보는 중이었다. "
    voice ""
    "ピークタイムを逃して店を探すことが最近増えた気がすると心の中で思いながら、周りを見回していた。"

# game/chapter6.rpy:711
translate japanese ecg12_label_23974bdb:

    # voice "voices/yf31.ogg"
    # 유미 "“우리 저기 앉자. 어때?”"
    voice "voices/yf31.ogg"
    유미 "「あそこに座ろうよ。どう？」"

# game/chapter6.rpy:713
translate japanese ecg12_label_4b0953b8:

    # voice ""
    # "들려온 목소리에 고개를 돌려 유미의 손가락이 향하던 곳으로 시선을 옮긴다. "
    voice ""
    "聞こえてきた声に振り向き、ユミの指が向いている方へ視線を移す。"

# game/chapter6.rpy:716
translate japanese ecg12_label_54ec1201:

    # 나 "“창가 자리 말하는 거야?”"
    나 "「窓際の席のことか？」"

# game/chapter6.rpy:717
translate japanese ecg12_label_2ffa9a92:

    # voice "voices/yf32.ogg"
    # 유미 "“응, 전에 가족이랑 왔을 땐 항상 저 자리엔 손님이 있어서 못 앉아 봤었거든.”"
    voice "voices/yf32.ogg"
    유미 "「うん、前に家族と来たときはいつもあの席にお客さんがいて座れなかったんだよね。」"

# game/chapter6.rpy:719
translate japanese ecg12_label_56c27d3a:

    # voice ""
    # "분위기에 심취한 듯 들뜬 미소를 흘리는 유미. "
    voice ""
    "雰囲気に酔いしれたような浮かれた笑みを浮かべるユミ。"

# game/chapter6.rpy:721
translate japanese ecg12_label_0699c602:

    # "유미가 가리킨 창가 쪽 테이블은 달빛에 물들어 어스름한 상아색으로 적셔져 있었다. "
    "ユミが指さした窓際のテーブルは、月明かりに照らされて仄かな象牙色に染まっていた。"

# game/chapter6.rpy:722
translate japanese ecg12_label_544405c4:

    # "사뿐사뿐 걸음을 옮기는 유미를 따라 창가 좌석에 자리를 잡고선, 메뉴판을 훑어보기 시작했다. "
    "軽やかに歩くユミに続いて窓際の席に着き、メニューに目を通し始めた。"

# game/chapter6.rpy:726
translate japanese ecg12_label_04407278:

    # 나 "“여긴 뭐가 맛있어?”"
    나 "「ここは何が美味いんだ？」"

# game/chapter6.rpy:728
translate japanese ecg12_label_c5d93642:

    # voice "voices/yf33.ogg"
    # 유미 "“난 이거 좋아하는데, 요것도 맛있고, 이것도 맛있어.”"
    voice "voices/yf33.ogg"
    유미 "「私はこれが好きだけど、これも美味しいし、これも美味しいよ。」"

# game/chapter6.rpy:730
translate japanese ecg12_label_cba054ce:

    # voice ""
    # 나 "“그러게, 다 맛있어 보이네.”"
    voice ""
    나 "「だよな、全部美味そうだ。」"

# game/chapter6.rpy:733
translate japanese ecg12_label_6e485412:

    # "메뉴판을 한 번 훑어보는 것만으로는 결정을 내릴 수 없어 다시금 메뉴를 확인하려는데, 맞은편에서 유리잔이 짤그락대는 소리가 들려왔다. "
    "メニューを一通り見ただけでは決められず、もう一度確認しようとしたところ、向かいからグラスがカチャリと鳴る音が聞こえた。"

# game/chapter6.rpy:734
translate japanese ecg12_label_7ed96ba3:

    # "고개를 들어 바라본 곳에서는, 유미가 호기심 어린 눈빛으로 옆에 얌전히 놓여있던 와인잔을 만지작대는 중이었다. "
    "顔を上げた先では、ユミが好奇心に満ちた目で横にちょこんと置かれていたワイングラスをいじっていた。"

# game/chapter6.rpy:738
translate japanese ecg12_label_9fda500b:

    # voice "voices/yf34.ogg"
    # 유미 "“우리 와인 한 잔 안 할래?”"
    voice "voices/yf34.ogg"
    유미 "「ワイン一杯飲まない？」"

# game/chapter6.rpy:740
translate japanese ecg12_label_cebcfce8:

    # voice ""
    # 나 "“…… 갑자기 웬 와인이야.”"
    voice ""
    나 "「……唐突にワインって。」"

# game/chapter6.rpy:743
translate japanese ecg12_label_ffeb4971:

    # voice "voices/yf35.ogg"
    # 유미 "“왜, 분위기도 좋은데.”"
    voice "voices/yf35.ogg"
    유미 "「なんでよ、雰囲気もいいのに。」"

# game/chapter6.rpy:746
translate japanese ecg12_label_7bd33073:

    # voice ""
    # "어른인 척하고 싶기라도 했던 걸까. "
    voice ""
    "大人ぶりたかったのだろうか。"

# game/chapter6.rpy:748
translate japanese ecg12_label_9115a36f:

    # "그렇다면 목적과는 동떨어져도 너무 동떨어진 어린애같은 웃음을 지은 채, 유미는 내게서 메뉴판을 뺏아 들었다. "
    "だとしたら目的とはかけ離れすぎた子供っぽい笑顔を浮かべたまま、ユミは俺からメニューを奪い取った。"

# game/chapter6.rpy:752
translate japanese ecg12_label_ca3aea4e:

    # voice "voices/yf36.ogg"
    # 유미 "“와아, 하나같이 모르는 이름들투성이네.”"
    voice "voices/yf36.ogg"
    유미 "「わあ、どれもこれも知らない名前ばっかり。」"

# game/chapter6.rpy:754
translate japanese ecg12_label_6ff9d83d:

    # voice ""
    # 나 "“어차피 시키지도 못하는 것들이잖아.”"
    voice ""
    나 "「どうせ頼めないものだろ。」"

# game/chapter6.rpy:757
translate japanese ecg12_label_a2a70197:

    # voice "voices/yf37.ogg"
    # 유미 "“왜?”"
    voice "voices/yf37.ogg"
    유미 "「なんで？」"

# game/chapter6.rpy:759
translate japanese ecg12_label_0231481c:

    # voice ""
    # 나 "“그야 당연히, 우린 학생이고…….”"
    voice ""
    나 "「そりゃ当然、俺たち学生だし……」"

# game/chapter6.rpy:762
translate japanese ecg12_label_3b165d8b:

    # "곁눈질로 눈치를 주듯, 나는 유미의 교복을 바라보았다. "
    "横目で示すように、俺はユミの制服を見た。"

# game/chapter6.rpy:763
translate japanese ecg12_label_61cbee24:

    # "유미는 자신의 옷차림을 훑어보더니 아무렇지도 않은 듯 내게 해결책을 제시했다. "
    "ユミは自分の服装を見下ろすと、何でもないかのように解決策を提示した。"

# game/chapter6.rpy:767
translate japanese ecg12_label_fca83f9e:

    # voice "voices/yf38.ogg"
    # 유미 "“네가 주문하면 되잖아?”"
    voice "voices/yf38.ogg"
    유미 "「あんたが注文すればいいじゃない？」"

# game/chapter6.rpy:769
translate japanese ecg12_label_8b865cfa:

    # voice ""
    # 나 "“나도 학생인데.”"
    voice ""
    나 "「俺も学生なんだけど。」"

# game/chapter6.rpy:772
translate japanese ecg12_label_92d06bae:

    # voice "voices/yf39.ogg"
    # 유미 "“에이, 학생처럼 안 보이는걸? 교복도 안 입고 있구.”"
    voice "voices/yf39.ogg"
    유미 "「えー、学生には見えないって？ 制服も着てないし。」"

# game/chapter6.rpy:774
translate japanese ecg12_label_fcdf704c:

    # voice ""
    # 나 "“누가 봐도 학생이잖아?”"
    voice ""
    나 "「誰が見ても学生だろ？」"

# game/chapter6.rpy:777
translate japanese ecg12_label_bba713a7:

    # voice "voices/yf40.ogg"
    # 유미 "“쉬―――잇, 들리겠어!”"
    voice "voices/yf40.ogg"
    유미 "「しーっ———聞こえちゃうよ！」"

# game/chapter6.rpy:780
translate japanese ecg12_label_e3dd96f8:

    # voice ""
    # "테이블 반대편의 주인 아주머니를 힐긋힐긋 바라본 유미가 눈치를 주며 말했다. "
    voice ""
    "テーブルの向こう側の店主のおばさんをちらちらと見たユミが、目配せしながら言った。"

# game/chapter6.rpy:785
translate japanese ecg12_label_fdfac50f:

    # voice "voices/yf41.ogg"
    # 유미 "“휴, 다행히 여기 말소리는 안 들리는 모양이다.”"
    voice "voices/yf41.ogg"
    유미 "「ふぅ、よかった、ここの話し声は聞こえないみたい。」"

# game/chapter6.rpy:787
translate japanese ecg12_label_a6e4355c:

    # voice ""
    # 나 "“…… 진심으로 주문하려고?”"
    voice ""
    나 "「……本気で注文するつもりか？」"

# game/chapter6.rpy:790
translate japanese ecg12_label_4cc0ccb4:

    # voice "voices/yf42.ogg"
    # 유미 "“그럼, 당연하지. 사고만 안 치면 되는 거잖아? 그리고 요즘 그런 거 별로 신경 안 쓴다고~”"
    voice "voices/yf42.ogg"
    유미 "「もちろん。やらかさなきゃいいんだよ？ それに最近そういうの気にしないんだって～」"

# game/chapter6.rpy:795
translate japanese ecg12_label_d5f30037:

    # voice ""
    # "걱정 말라며 웃음을 흘리는 유미였지만, 불안하지 않을 리가 있나. "
    voice ""
    "心配するなと笑うユミだったが、不安にならないわけがない。"

# game/chapter6.rpy:797
translate japanese ecg12_label_35b968ce:

    # "유미는 그런 나의 심정을 아는지 모르는지, 내게 다시 메뉴판을 내밀며 물었다. "
    "ユミは俺の気持ちを知ってか知らずか、再びメニューを差し出して聞いた。"

# game/chapter6.rpy:799
translate japanese ecg12_label_0b0d9f97:

    # voice "voices/yf43.ogg"
    # 유미 "“뭘로 주문할 건지는 정했어?”"
    voice "voices/yf43.ogg"
    유미 "「何を注文するかは決めた？」"

# game/chapter6.rpy:801
translate japanese ecg12_label_527d73b9:

    # voice ""
    # 나 "“응, 이걸로 하려고.”"
    voice ""
    나 "「ああ、これにしようかと。」"

# game/chapter6.rpy:804
translate japanese ecg12_label_655476e4:

    # voice "voices/yf44.ogg"
    # 유미 "“그럼 난 이걸로 할게. 이거랑 이거, 와인은 요걸로 주문하면 되겠다.”"
    voice "voices/yf44.ogg"
    유미 "「じゃあ私はこれにする。これとこれ、ワインはこれを頼めばいいかな。」"

# game/chapter6.rpy:807
translate japanese ecg12_label_1fbf0303:

    # voice ""
    # 나 "“…….”"
    voice ""
    나 "「……」"

# game/chapter6.rpy:810
translate japanese ecg12_label_1cc69c97:

    # voice "voices/yf45.ogg"
    # 유미 "“헤, 주문 부탁할게!”"
    voice "voices/yf45.ogg"
    유미 "「へへ、注文お願いね！」"

# game/chapter6.rpy:812
translate japanese ecg12_label_020bb8f2:

    # voice ""
    # "부탁한다고는 해도, 뭘 어떻게 해야 하는 건지……. "
    voice ""
    "頼むとは言っても、どうすればいいのか……"

# game/chapter6.rpy:818
translate japanese ecg12_label_18d64563:

    # 나 "“저기요―――”"
    나 "「すみません———」"

# game/chapter6.rpy:820
translate japanese ecg12_label_5bb151cf:

    # "정신을 차려 보니, 나는 어느새 손을 들어 주문을 하고 있었다. "
    "気がつくと、俺はいつの間にか手を上げて注文をしていた。"

# game/chapter6.rpy:822
translate japanese ecg12_label_4dc41e25:

    # 나 "“여기 이거…… 하고, 콜라 한 병 주세요.”"
    나 "「これと……あと、コーラを一本ください。」"

# game/chapter6.rpy:824
translate japanese ecg12_label_660e8c43:

    # "혹시나 하는 생각에 힐긋힐긋 시선을 돌리며 아주머니의 눈치를 살피기도 했지만, 정말 유미의 말대로 주문을 받은 아주머니는 별다른 말도 없이 메뉴판을 들고선 주방 쪽으로 발걸음을 옮길 뿐이었다. "
    "万が一と思いちらちら視線を送っておばさんの様子をうかがったが、ユミの言ったとおり、注文を受けたおばさんは何も言わずにメニューを持って厨房のほうへ歩いていくだけだった。"

# game/chapter6.rpy:828
translate japanese ecg12_label_72c08a16:

    # 나 "“후아, 앞으로 이런 거 시키지 말아줄래.”"
    나 "「ふぅ、今後こういうの頼まないでくれ。」"

# game/chapter6.rpy:830
translate japanese ecg12_label_95a0f30e:

    # "미뤄두었던 호흡을 연달아 내쉬어대는 나를 바라보며, 유미는 뭐가 그리 좋은지 키득거리고만 있었다. "
    "溜め込んでいた息を続けざまに吐き出す俺を見て、ユミは何がそんなに楽しいのかくすくす笑っていた。"

# game/chapter6.rpy:832
translate japanese ecg12_label_f88e7d4b:

    # voice "voices/yf46.ogg"
    # 유미 "“아, 그나저나 콜라는 왜 시킨 거야?!”"
    voice "voices/yf46.ogg"
    유미 "「あ、それはそうとコーラはなんで頼んだの？！」"

# game/chapter6.rpy:834
translate japanese ecg12_label_83a65cd6:

    # voice ""
    # 나 "“나는 술 안 마실 거거든. 마실 거면 혼자 마셔.”"
    voice ""
    나 "「俺はお酒なんか飲まないから。飲みたいなら一人で飲め。」"

# game/chapter6.rpy:837
translate japanese ecg12_label_da5c7182:

    # voice "voices/yf47.ogg"
    # 유미 "“뭐야아아…… 재미없게.”"
    voice "voices/yf47.ogg"
    유미 "「なんだよぉ……つまんないの。」"

# game/chapter6.rpy:839
translate japanese ecg12_label_53726fc7:

    # voice ""
    voice ""

# game/chapter6.rpy:844
translate japanese ecg12_label_08921cb3:

    # "불만 가득한 입모양을 한 채, 양팔에 반쯤 얼굴을 파묻고선 나를 바라보는 유미. "
    "不満いっぱいの口をしたまま、両腕に半分顔を埋めて俺を見るユミ。"

# game/chapter6.rpy:845
translate japanese ecg12_label_aba800a7:

    # "마냥 뾰루퉁한 표정으로 나를 바라보고 있었지만, 조명에 비치는 유미의 얼굴에서는 알게 모르게 피로감이 잔뜩 느껴졌다. "
    "ただふてくされた顔で俺を見ていたが、照明に照らされたユミの顔からは、知らず知らずのうちに疲労感がにじんでいた。"

# game/chapter6.rpy:846
translate japanese ecg12_label_81a63477:

    # "유미의 반쯤 감긴 눈꺼풀은, 티 날 정도로 무거워 보였다. "
    "ユミの半分閉じたまぶたは、見て分かるほど重そうだった。"

# game/chapter6.rpy:850
translate japanese ecg12_label_dcc2546d:

    # 나 "“피곤해보이네.”"
    나 "「疲れてるみたいだな。」"

# game/chapter6.rpy:852
translate japanese ecg12_label_6676b662:

    # voice "voices/yf48.ogg"
    # 유미 "“어라, 그렇게 보여?”"
    voice "voices/yf48.ogg"
    유미 "「あれ、そう見える？」"

# game/chapter6.rpy:854
translate japanese ecg12_label_3da1ef9a:

    # voice ""
    # 나 "“으음…… 조금?”"
    voice ""
    나 "「んー……少し？」"

# game/chapter6.rpy:857
translate japanese ecg12_label_42499a93:

    # "그러자 유미는 곧바로 고개를 들어, 마치 자신은 전혀 피곤하지 않다고 이야기하고 싶은 것처럼 눈을 깜빡였다. "
    "するとユミはすぐに顔を上げ、自分は全然疲れていないと言いたげにまばたきをした。"

# game/chapter6.rpy:860
translate japanese ecg12_label_39533b3f:

    # 나 "“비품 창고 정리는 언제부터 하고 있었던 거야?”"
    나 "「備品倉庫の整理はいつからやってたんだ？」"

# game/chapter6.rpy:861
translate japanese ecg12_label_8bfccf14:

    # voice "voices/yf49.ogg"
    # 유미 "“으음…… 너희랑 마주치고 헤어진 뒤부터?”"
    voice "voices/yf49.ogg"
    유미 "「うーん……あんたたちと会って別れた後から？」"

# game/chapter6.rpy:863
translate japanese ecg12_label_55443ed6:

    # voice ""
    # 나 "“그럼 피곤할 만도 하잖아…….”"
    voice ""
    나 "「じゃあ疲れるのも当然だろ……」"

# game/chapter6.rpy:866
translate japanese ecg12_label_f6b6514a:

    # voice "voices/yf50.ogg"
    # 유미 "“아하핫, 괜찮아, 괜찮아.”"
    voice "voices/yf50.ogg"
    유미 "「あはは、大丈夫、大丈夫。」"

# game/chapter6.rpy:874
translate japanese ecg12_label_f008eb6f:

    # voice ""
    # "알듯 말듯한 표정이 유미의 얼굴을 스친다. "
    voice ""
    "分かるような分からないような表情がユミの顔をよぎる。"

# game/chapter6.rpy:876
translate japanese ecg12_label_275898f3:

    # "잘 모르겠다고 생각하고선, 나는 턱을 괴고는 주문한 음식이 나오기를 기다리는 중이었다. "
    "よく分からないと思いながら、俺は頬杖をついて注文した料理が来るのを待っていた。"

# game/chapter6.rpy:877
translate japanese ecg12_label_0958df8e:

    # "얼핏 고개를 돌려 바라본 창밖에는 반쯤 감긴 달이 하나, 그리고 듬성듬성 빛을 발하는 별이 손에 꼽을 만한 수로 하늘에 매여 있었다. "
    "ふと振り返った窓の外には、半分隠れた月がひとつ、そしてまばらに光る星が数えるほどの数で空にかかっていた。"

# game/chapter6.rpy:878
translate japanese ecg12_label_ffaf9cb7:

    # "원래라면 하늘에 수놓여 있어야 할 별들은 모두 땅에 떨어져 버린 걸까. "
    "本来なら空に散りばめられているはずの星たちは、みんな地上に落ちてしまったのだろうか。"

# game/chapter6.rpy:879
translate japanese ecg12_label_fd671741:

    # "그다지 주의 깊게 바라보지 않은 야경이었지만, 밝다는 인상이나 반짝인다는 느낌은 분명히 내게 전해진 듯했다. "
    "それほど注意深く見たわけではない夜景だったが、明るいという印象やきらめくという感覚は確かに伝わってきたようだった。"

# game/chapter6.rpy:886
translate japanese ecg12_label_b61b12ab:

    # voice "voices/yf51.ogg"
    # 유미 "“분위기 있다. 그렇지 않아?”"
    voice "voices/yf51.ogg"
    유미 "「いい雰囲気。そう思わない？」"

# game/chapter6.rpy:888
translate japanese ecg12_label_d6875666:

    # voice ""
    # 나 "“그러게. 괜찮은 것 같아.”"
    voice ""
    나 "「そうだな。悪くないと思う。」"

# game/chapter6.rpy:891
translate japanese ecg12_label_47457544:

    # voice "voices/yf52.ogg"
    # 유미 "“하늘에 별만 좀 더 밝았으면 좋았을 텐데…….”"
    voice "voices/yf52.ogg"
    유미 "「空の星がもう少し明るかったらよかったのに……」"

# game/chapter6.rpy:896
translate japanese ecg12_label_abe1d53d:

    # voice ""
    # "아쉬운 미소가 유미의 입가에서 새어 나오고, 그녀의 미소에 나 또한 아쉬운 미소로 답장을 전한다. "
    voice ""
    "名残惜しそうな笑みがユミの口元に漏れ、その笑みに俺もまた同じような笑みで返す。"

# game/chapter6.rpy:898
translate japanese ecg12_label_6a5e667d:

    # "각자 다른 이유에서의 아쉬운 미소였겠지만 말이다. "
    "互いに違う理由からの笑みだったのだろうけど。"

# game/chapter6.rpy:902
translate japanese ecg12_label_aa9fd196:

    # "아쉬운 빛이 서려 있던 웃음을 가벼운 말소리로 덮어간다. "
    "惜しむ光を帯びた笑みを、軽い話し声で覆い隠していく。"

# game/chapter6.rpy:903
translate japanese ecg12_label_66ad4b5a:

    # "그 날, E구역에서 보았던 그 별빛을. "
    "あの日、E区域で見たあの星の光を。"

# game/chapter6.rpy:904
translate japanese ecg12_label_e998ff67:

    # "언젠가 유미에게 보여줄 날이 올지도 모르니까. "
    "いつかユミに見せられる日が来るかもしれないから。"

# game/chapter6.rpy:912
translate japanese ecg12_label_9983f9b0:

    # "기다리던 음식이 나오고, 유미의 태블릿에서 찰칵 하는 셔터음이 들려온다. "
    "待っていた料理が運ばれてきて、ユミのタブレットからカシャッとシャッター音が聞こえる。"

# game/chapter6.rpy:916
translate japanese ecg12_label_c57f420a:

    # voice "voices/yf53.ogg"
    # 유미 "“맛있겠다~”"
    voice "voices/yf53.ogg"
    유미 "「美味しそ～」"

# game/chapter6.rpy:919
translate japanese ecg12_label_1a44a1de:

    # voice ""
    # "파스타에 손을 대기 전, 유미는 신성한 의식을 치르기라도 하는 것처럼 손을 쥐었다 폈다 하고선 와인병을 열기 시작했다. "
    voice ""
    "パスタに手をつける前に、ユミはまるで神聖な儀式を執り行うかのように手を握ったり開いたりしてから、ワインのボトルを開け始めた。"

# game/chapter6.rpy:922
translate japanese ecg12_label_6f15f3d4:

    # 나 "“진짜 마시게?”"
    나 "「え、マジで飲むの？」"

# game/chapter6.rpy:923
translate japanese ecg12_label_cf4a6b28:

    # voice "voices/yf54.ogg"
    # 유미 "“이런 곳에 오면 와인 같은 거 꼭 마셔보고 싶었거든.”"
    voice "voices/yf54.ogg"
    유미 "「こういうお店に来たらワインとか飲んでみたかったんだよね。」"

# game/chapter6.rpy:926
translate japanese ecg12_label_2e0390cd:

    # voice ""
    # "와인잔에는 천천히 자색 액체가 꼴꼴대는 소리를 내며 부어져가고 있었다. "
    voice ""
    "ワイングラスには紫色の液体がゆっくりとコポコポと注がれていった。"

# game/chapter6.rpy:928
translate japanese ecg12_label_6f41bd8c:

    # "익숙한 포도향의 끝에는 익숙하지 않은 알코올의 자취가 희미하게 남아 코끝을 간질였다. "
    "馴染みのあるぶどうの香りの奥に、馴染みのないアルコールの痕跡がかすかに残って鼻先をくすぐった。"

# game/chapter6.rpy:930
translate japanese ecg12_label_34cdfc2d:

    # voice "voices/yf55.ogg"
    # 유미 "“그리고…….”"
    voice "voices/yf55.ogg"
    유미 "「それから……」"

# game/chapter6.rpy:933
translate japanese ecg12_label_ca70fb26:

    # voice ""
    # "뭐라 말할 틈조차 주지 않은 채, 유미는 자신의 입가로 와인잔은 가져댔다. "
    voice ""
    "何か言う隙すら与えず、ユミはワイングラスを唇に運んだ。"

# game/chapter6.rpy:936
translate japanese ecg12_label_d7973520:

    # "붉은 와인 한 모금이 식도를 타고 내려가는 소리가 들려온다. "
    "赤ワインの一口が食道を流れ落ちる音が聞こえる。"

# game/chapter6.rpy:937
translate japanese ecg12_label_1f35632e:

    # "와인잔을 입에서 뗀 유미가 눈을 깜빡였다. "
    "ワイングラスを口から離したユミが目をぱちくりとさせた。"

# game/chapter6.rpy:945
translate japanese ecg12_label_5ebad0fb:

    # voice "voices/yf56.ogg"
    # 유미 "“어라, 이게 어른의 맛인가?”"
    voice "voices/yf56.ogg"
    유미 "「うむ、これが大人の味ってやつ？」"

# game/chapter6.rpy:947
translate japanese ecg12_label_69c0e42b:

    # voice ""
    # 나 "“…… 어떤 맛인데?”"
    voice ""
    나 "「……どんな味なんだ？」"

# game/chapter6.rpy:950
translate japanese ecg12_label_9dda9db3:

    # voice "voices/yf57.ogg"
    # 유미 "“궁금하면 너도 마셔봐~”"
    voice "voices/yf57.ogg"
    유미 "「気になるならあんたも飲んでみなよ～」"

# game/chapter6.rpy:952
translate japanese ecg12_label_b39a9901:

    # voice ""
    # 나 "“됐거든요.”"
    voice ""
    나 "「結構です。」"

# game/chapter6.rpy:955
translate japanese ecg12_label_89265c29:

    # "기분 좋은 웃음을 키득키득 내뱉은 유미는 오물오물 파스타를 먹기 시작했다. "
    "上機嫌にくすくす笑ったユミは、もぐもぐとパスタを食べ始めた。"

# game/chapter6.rpy:956
translate japanese ecg12_label_eae628ec:

    # "배가 고팠는지, 평소라면 천천히 비어갔을 유미의 접시는 생각보다 빠른 속도로 바닥을 보여갔다. "
    "お腹が空いていたのか、普段ならゆっくり減っていくユミの皿は、思ったより早いペースで底を見せていった。"

# game/chapter6.rpy:963
translate japanese ecg12_label_e8ecd701:

    # "한 잔째, 두 잔째, 와인 병도 조금씩 비어가고 있었다. "
    "一杯目、二杯目、ワインのボトルも少しずつ空いていった。"

# game/chapter6.rpy:965
translate japanese ecg12_label_942706f6:

    # 나 "“…… 괜찮겠어?”"
    나 "「……大丈夫か？」"

# game/chapter6.rpy:967
translate japanese ecg12_label_5f07f26c:

    # voice "voices/yf58.ogg"
    # 유미 "“에이, 와인 한 병으로 취하게써?”"
    voice "voices/yf58.ogg"
    유미 "「えー、ワイン一本で酔うわけないじゃん？」"

# game/chapter6.rpy:969
translate japanese ecg12_label_3040d05d:

    # voice ""
    # 나 "“이미 조금 취한 것 같아 보이는데…….”"
    voice ""
    나 "「もう酔ってるように見えるんだけど……」"

# game/chapter6.rpy:971
translate japanese ecg12_label_ab6b3c98:

    # voice "voices/yf59.ogg"
    # 유미 "“에헤헤, 전혀요~”"
    voice "voices/yf59.ogg"
    유미 "「えへへ、全然よ～」"

# game/chapter6.rpy:974
translate japanese ecg12_label_5938884f:

    # voice ""
    # "와인 한 잔을 다시 비운 유미는 테이블에 얼굴을 파묻고선, 반쯤 풀린 눈으로 나를 빤히 바라보았다. "
    voice ""
    "もう一杯ワインを注いだユミは、テーブルに顔を埋めて半分とろんとした目で俺をじっと見つめた。"

# game/chapter6.rpy:977
translate japanese ecg12_label_00039c99:

    # voice "voices/yf60.ogg"
    # 유미 "“정말로 안 마실 거야? 이제 반도 안 나맛는데…….”"
    voice "voices/yf60.ogg"
    유미 "「ほんとに飲まないの？ まだ半分も残ってるのに……」"

# game/chapter6.rpy:979
translate japanese ecg12_label_b76acc1b:

    # voice ""
    # 나 "“안 마셔요.”"
    voice ""
    나 "「飲みません。」"

# game/chapter6.rpy:981
translate japanese ecg12_label_6cd4140f:

    # voice "voices/yf61.ogg"
    # 유미 "“겁쟁이다, 겁쟁이~”"
    voice "voices/yf61.ogg"
    유미 "「やーい、ビビリ～」"

# game/chapter6.rpy:984
translate japanese ecg12_label_3607cf5a:

    # voice ""
    # "어른스럽지 못한 웃음을 키득대며, 유미는 와인잔에 자색 액체를 다시금 채워갔다. "
    voice ""
    "大人げない笑いをくすくすと漏らしながら、ユミはワイングラスに紫色の液体を再び注いでいった。"

# game/chapter6.rpy:990
translate japanese ecg12_label_f73a48e7:

    # voice "voices/yf62.ogg"
    # 유미 "“나도 그런데 말이야.”"
    voice "voices/yf62.ogg"
    유미 "「私もそうなんだけどさ。」"

# game/chapter6.rpy:992
translate japanese ecg12_label_dddb8f94:

    # voice ""
    # "그러고는 잔에 가득 든 와인을 단번에 꿀꺽꿀꺽 삼켜버리고는, 붉게 변한 얼굴을 내게 가까이 가져댔다. "
    voice ""
    "そしてグラスいっぱいのワインを一気にごくごくと飲み干すと、赤くなった顔を俺に近づけた。"

# game/chapter6.rpy:994
translate japanese ecg12_label_a5422b93:

    # "흐릿한 조명에 비치는 유미의 얼굴은 마치 와인이 가득 담긴 잔에 비친 것처럼 불그스름한 빛을 띠고 있었다. "
    "ぼんやりとした照明に照らされたユミの顔は、まるでワインの満ちたグラスに映ったかのように赤みを帯びていた。"

# game/chapter6.rpy:996
translate japanese ecg12_label_cbf763ab:

    # voice "voices/yf63.ogg"
    # 유미 "“나도 겁쟁이라서, 용기가 없어서 맨정신에는 하고 싶은 이야기도 제대로 못 하거든.”"
    voice "voices/yf63.ogg"
    유미 "「私もビビリだから、勇気がなくてシラフじゃ言いたいことも言えないんだよね。」"

# game/chapter6.rpy:998
translate japanese ecg12_label_1fbf0303_1:

    # voice ""
    # 나 "“…….”"
    voice ""
    나 "「……」"

# game/chapter6.rpy:1001
translate japanese ecg12_label_e9658bb4:

    # voice "voices/yf64.ogg"
    # 유미 "“난 왜 이렇게 겁이 많은 걸까? 하고 싶은 이야기도 제대로 못 하고…….”"
    voice "voices/yf64.ogg"
    유미 "「私、なんでこんなに臆病なんだろ。言いたいことも言えなくて……」"

# game/chapter6.rpy:1004
translate japanese ecg12_label_2f9cae84:

    # voice ""
    # "알코올에 잠겨가듯, 유미는 말을 끝맺지 못하고 다시금 얼굴을 팔 속으로 푹 파묻어버렸다. "
    voice ""
    "アルコールに沈んでいくように、ユミは言葉を最後まで言えず、再び腕の中に顔を埋めてしまった。"

# game/chapter6.rpy:1007
translate japanese ecg12_label_40aea342:

    # 나 "“저기, 완전 취한 것 같은데.”"
    나 "「あのさ、完全に酔ってるだろ。」"

# game/chapter6.rpy:1013
translate japanese ecg12_label_6d6927cd:

    # voice "voices/yf65.ogg"
    # 유미 "“갠차는걸……? 아직 와인도 남아있고…….”"
    voice "voices/yf65.ogg"
    유미 "「だいじょぶだし……？ まだワインも残ってるし……」"

# game/chapter6.rpy:1015
translate japanese ecg12_label_8a2937e9:

    # voice ""
    # "팔을 뻗어 와인병을 찾으려는 유미. "
    voice ""
    "腕を伸ばしてワインのボトルを探ろうとするユミ。"

# game/chapter6.rpy:1017
translate japanese ecg12_label_2d99313c:

    # "나는 유미의 손에 붙잡힐 뻔한 와인병을 구해내고는 유미로부터 닿지 않는 거리에 옮겨두었다. "
    "俺はユミの手に掴まれそうになったボトルを救い出し、ユミの手が届かない場所に移した。"

# game/chapter6.rpy:1019
translate japanese ecg12_label_7ac3c9f8:

    # voice "voices/yf66.ogg"
    # 유미 "“와앗, 돌려줘어어―――”"
    voice "voices/yf66.ogg"
    유미 "「わあっ、返してよぉ———」"

# game/chapter6.rpy:1021
translate japanese ecg12_label_e68ff51e:

    # voice ""
    # 나 "“엄청 취해 보여. 이제 슬슬 나가 보는 게…….”"
    voice ""
    나 "「すごく酔ってるぞ。そろそろ出たほうが……」"

# game/chapter6.rpy:1024
translate japanese ecg12_label_ac983f60:

    # voice "voices/yf67.ogg"
    # 유미 "“그 와인 다 마시기 전까진 안 나갈 거거든?”"
    voice "voices/yf67.ogg"
    유미 "「そのワイン全部飲むまで出ないからね？」"

# game/chapter6.rpy:1027
translate japanese ecg12_label_c9052ef1:

    # voice ""
    # 나 "“야아.”"
    voice ""
    나 "「おい。」"

# game/chapter6.rpy:1030
translate japanese ecg12_label_1a50bcf1:

    # voice "voices/yf68.ogg"
    # 유미 "“흐으으음――― 어떡할 거야?”"
    voice "voices/yf68.ogg"
    유미 "「ふーん———どうするの？」"

# game/chapter6.rpy:1032
translate japanese ecg12_label_a4b40973:

    # voice ""
    # 나 "“어떡하긴 뭘 어떡해.”"
    voice ""
    나 "「どうするって、どうしろってんだよ。」"

# game/chapter6.rpy:1035
translate japanese ecg12_label_cf889daa:

    # voice "voices/yf69.ogg"
    # 유미 "“나 그 병에 있는 와인 다 마시기 전까지는 안 움직일 거라니까~?”"
    voice "voices/yf69.ogg"
    유미 "「あのボトルのワイン全部飲むまでは動かないからね～？」"

# game/chapter6.rpy:1037
translate japanese ecg12_label_d8547307:

    # voice ""
    # "넌센스 퀴즈를 내고 싶기라도 한 건지. "
    voice ""
    "なぞなぞでも出したいのだろうか。"

# game/chapter6.rpy:1039
translate japanese ecg12_label_212cecd3:

    # "아무래도 유미는 알코올 기운에 완전히 잠식된 것 같아 보였다. "
    "どうやらユミはアルコールに完全に飲まれてしまったようだった。"

# game/chapter6.rpy:1040
translate japanese ecg12_label_9bfdc60c:

    # "더 이상 마시는 건 위험하지 않을까 하는 생각이 들 정도로 유미의 얼굴은 새빨개 보이기도 했다. "
    "これ以上飲むのは危ないんじゃないかと思うほど、ユミの顔は真っ赤に見えた。"

# game/chapter6.rpy:1042
translate japanese ecg12_label_0460b06d:

    # voice "voices/yf70.ogg"
    # 유미 "“이대로 공주님 안기로 집까지 바래다주는 건 어때?”"
    voice "voices/yf70.ogg"
    유미 "「このままお姫様抱っこで家まで送るってのはどう？」"

# game/chapter6.rpy:1044
translate japanese ecg12_label_52d5ceab:

    # voice ""
    # 나 "“…… 그건 기각.”"
    voice ""
    나 "「……却下。」"

# game/chapter6.rpy:1047
translate japanese ecg12_label_e32e9165:

    # voice "voices/yf71.ogg"
    # 유미 "“왜애에?”"
    voice "voices/yf71.ogg"
    유미 "「なんでぇ？」"

# game/chapter6.rpy:1049
translate japanese ecg12_label_5aa1dd95:

    # voice ""
    # 나 "“무겁단 말이야――― 아야, 발로 차지 마.”"
    voice ""
    나 "「重いって———いてっ、蹴るなよ。」"

# game/chapter6.rpy:1052
translate japanese ecg12_label_9e34b93a:

    # voice "voices/yf72.ogg"
    # 유미 "“안 움직일 거야. 알아서 해.”"
    voice "voices/yf72.ogg"
    유미 "「動かない。好きにして。」"

# game/chapter6.rpy:1054
translate japanese ecg12_label_9b4f1925:

    # voice ""
    # 나 "“후, 정말…….”"
    voice ""
    나 "「はぁ、まったく……」"

# game/chapter6.rpy:1057
translate japanese ecg12_label_f7ae268f:

    # "토라진 티를 잔뜩 내며, 유미는 테이블에 얼굴을 찰싹 붙였다. "
    "すねた態度を全開にして、ユミはテーブルに顔をぺたりと押し付けた。"

# game/chapter6.rpy:1059
translate japanese ecg12_label_6ed7b398:

    # 나 "“이 와인병만 다 비우면 되는 거지?”"
    나 "「このワインを全部空ければいいんだろ？」"

# game/chapter6.rpy:1063
translate japanese ecg12_label_5f530c79:

    # voice "voices/yf73.ogg"
    # 유미 "“와아, 흑기사 출동~”"
    voice "voices/yf73.ogg"
    유미 "「わあ、騎士様出動～」"

# game/chapter6.rpy:1066
translate japanese ecg12_label_77fd5305:

    # voice ""
    # "눈을 질끈 감고선, 그대로 한 잔 가득 따른 와인을 꿀꺽꿀꺽 마셔 버렸다. "
    voice ""
    "目をぎゅっとつむり、そのままグラスいっぱいに注いだワインをごくごくと飲み干した。"

# game/chapter6.rpy:1069
translate japanese ecg12_label_031105db:

    # voice "voices/yf74.ogg"
    # 유미 "“어때?”"
    voice "voices/yf74.ogg"
    유미 "「どう？」"

# game/chapter6.rpy:1071
translate japanese ecg12_label_88d9025c:

    # voice ""
    # 나 "“아무렇지도 않은데.”"
    voice ""
    나 "「なんともないけど。」"

# game/chapter6.rpy:1073
translate japanese ecg12_label_d3412d42:

    # voice "voices/yf75.ogg"
    # 유미 "“그럼 한 잔 더~”"
    voice "voices/yf75.ogg"
    유미 "「じゃあもう一杯～」"

# game/chapter6.rpy:1076
translate japanese ecg12_label_5f40ddf0:

    # voice ""
    # "순식간에 병에 들어있던 와인이 모두 사라졌다. "
    voice ""
    "あっという間にボトルのワインがすべてなくなった。"

# game/chapter6.rpy:1078
translate japanese ecg12_label_c4129dd7:

    # "나는 두 번째 잔을 비우고선 멍한 얼굴로 유미를 바라보았다. "
    "俺は二杯目を飲み干すと、ぼんやりした顔でユミを見た。"

# game/chapter6.rpy:1080
translate japanese ecg12_label_2db412be:

    # voice "voices/yf76.ogg"
    # 유미 "“지금은?”"
    voice "voices/yf76.ogg"
    유미 "「今は？」"

# game/chapter6.rpy:1082
translate japanese ecg12_label_0a03d2bc:

    # voice ""
    # 나 "“괜찮은 것 같아.”"
    voice ""
    나 "「大丈夫そうだ。」"

# game/chapter6.rpy:1085
translate japanese ecg12_label_01be10b6:

    # voice "voices/yf77.ogg"
    # 유미 "“에이, 뭐야아. 재미없게.”"
    voice "voices/yf77.ogg"
    유미 "「えー、なんだよぉ。つまんないの。」"

# game/chapter6.rpy:1087
translate japanese ecg12_label_80f1ba26:

    # voice ""
    # "뭔가 김이 새어버렸다는 듯 투덜대는 유미. "
    voice ""
    "何か拍子抜けしたとでもいうようにぶつぶつ言うユミ。"

# game/chapter6.rpy:1089
translate japanese ecg12_label_d0ad7abb:

    # "나는 그런 유미를 여전히 멍한 시선으로 응시할 뿐이었다. "
    "俺はそんなユミをまだぼんやりした目で見つめているだけだった。"

# game/chapter6.rpy:1091
translate japanese ecg12_label_7a157f8d:

    # voice "voices/yf78.ogg"
    # 유미 "“여태껏 술 마셔본 적 있었어?”"
    voice "voices/yf78.ogg"
    유미 "「今までお酒飲んだことある？」"

# game/chapter6.rpy:1093
translate japanese ecg12_label_7cb9e961:

    # voice ""
    # 나 "“아니, 한 번도 없는데.”"
    voice ""
    나 "「いや、一度もないけど。」"

# game/chapter6.rpy:1096
translate japanese ecg12_label_805c1fae:

    # voice "voices/yf79.ogg"
    # 유미 "“그럼 이번이 처음인 거네?”"
    voice "voices/yf79.ogg"
    유미 "「じゃあ今回が初めてなんだ？」"

# game/chapter6.rpy:1098
translate japanese ecg12_label_f897d660:

    # voice ""
    # 나 "“으응, 그렇지.”"
    voice ""
    나 "「ああ、そうだな。」"

# game/chapter6.rpy:1101
translate japanese ecg12_label_f51a9372:

    # voice "voices/yf80.ogg"
    # 유미 "“헤헤, 어쨌거나 공범이다. 공. 범.”"
    voice "voices/yf80.ogg"
    유미 "「へへ、とにかく共犯だね。きょ・う・は・ん。」"

# game/chapter6.rpy:1103
translate japanese ecg12_label_9a26cb09:

    # voice ""
    # 나 "“이거, 나쁜 짓은 아니라고 하지 않았었나…… 공범이라는 말은 너무한데.”"
    voice ""
    나 "「悪いことじゃないって言ってたのに……共犯はひどくないか。」"

# game/chapter6.rpy:1105
translate japanese ecg12_label_cb5d3230:

    # voice "voices/yf81.ogg"
    # 유미 "“그치만 왠지 나쁜 짓 잔뜩 하고 싶은 기분인걸?”"
    voice "voices/yf81.ogg"
    유미 "「でもぉ、悪いことたくさんしたい気分なんだけど？」"

# game/chapter6.rpy:1110
translate japanese ecg12_label_2f8fe926:

    # voice ""
    # "슬슬 일어나 봐야 할 것 같다는 생각에 몸을 일으키려는 순간. "
    voice ""
    "そろそろ立ち上がるべきだと思い、体を起こそうとした瞬間。"

# game/chapter6.rpy:1113
translate japanese ecg12_label_2baa8fce:

    # voice "voices/yf82.ogg"
    # 유미 "“아까 내가 이야기했던 거 기억해?”"
    voice "voices/yf82.ogg"
    유미 "「さっき私が言ってたこと覚えてる？」"

# game/chapter6.rpy:1118
translate japanese ecg12_label_05350052:

    # voice ""
    # "유미의 목소리가 나의 몸을 붙잡았다. "
    voice ""
    "ユミの声が俺の体を引き留めた。"

# game/chapter6.rpy:1120
translate japanese ecg12_label_21cc9cf4:

    # voice "voices/yf83.ogg"
    # 유미 "“맨정신에는 이야기 못 하는 거, 지금 하고 싶은데.”"
    voice "voices/yf83.ogg"
    유미 "「シラフじゃ言えないこと、今言いたいんだけど。」"

# game/chapter6.rpy:1122
translate japanese ecg12_label_732508b0:

    # voice ""
    # "그 목소리를 신호로 삼기라도 한 것처럼, 머릿속이 아득해졌다. "
    voice ""
    "その声を合図にしたかのように、頭の中がぼうっとなった。"

# game/chapter6.rpy:1125
translate japanese ecg12_label_396673fa_2:

    # 나 "“…….”"
    나 "「……」"

# game/chapter6.rpy:1126
translate japanese ecg12_label_c035fedb:

    # voice "voices/yf84.ogg"
    # 유미 "“있지, 나 말이야. 너를―――”"
    voice "voices/yf84.ogg"
    유미 "「あのね、私ね。あんたのこと———」"

# game/chapter6.rpy:1131
translate japanese ecg12_label_dad993df:

    # voice ""
    # "심장이 유별나게 뛰는 것도, 감각이 하나하나 사라져가는 것도 방금 전 비품 창고에서 겪었던 것과 꼭 같은 현상이었다. "
    voice ""
    "心臓がひどく脈打つのも、感覚がひとつひとつ消えていくのも、さっき備品倉庫で経験したのと全く同じ現象だった。"

# game/chapter6.rpy:1133
translate japanese ecg12_label_a0ec5964:

    # "다만, 그 순간 느끼는 감각만큼은 무언가가 다른 것 같다는 느낌이 들었다. "
    "ただ、その瞬間感じる感覚だけは何かが違うような気がした。"

# game/chapter6.rpy:1134
translate japanese ecg12_label_750c8eaf:

    # "단지 두려움에 쿵쿵댔던 심장이, 지금은 또 다른 무언가의 감정에 의해 뛰고 있었다. "
    "ただ恐怖でドキドキしていた心臓が、今は別の何かの感情で高鳴っていた。"

# game/chapter6.rpy:1135
translate japanese ecg12_label_efecdf90:

    # "나의 눈과 귀가 그 감각에 의해 멀어가고 있었지만, 나는 모호하기 짝이 없는 그 감정을 끝까지 붙잡을 수 없었다. "
    "俺の目と耳がその感覚によって遠のいていったが、俺はこの上なく曖昧なその感情を最後まで掴むことができなかった。"

# game/chapter6.rpy:1136
translate japanese ecg12_label_40bfaf1a:

    # "그 감각이 급작스럽게 뇌에 투여된 알코올과 함께 이루어낸 허상이 나의 눈앞에 펼쳐지고 난 뒤에도 말이다. "
    "その感覚が、急に脳に注入されたアルコールとともに作り出した幻影が目の前に広がった後でさえも。"

# game/chapter6.rpy:1141
translate japanese ecg12_label_350f74a2:

    # voice "voices/gf1.ogg"
    # whoso "“있지, 나 말이야. 너를―――”"
    voice "voices/gf1.ogg"
    whoso "「あのね、私ね。あなたのこと———」"

# game/chapter6.rpy:1143
translate japanese ecg12_label_74984260:

    # voice ""
    # "모호한 목소리로부터 시작되는 허상이었다. "
    voice ""
    "曖昧な声から始まる幻覚だった。"

# game/chapter6.rpy:1145
translate japanese ecg12_label_71b4a2cf:

    # "무슨 의미인지도, 누구의 목소리인지도 확실치 않은 그 목소리는 흐릿해졌던 기억들과 어울려 들뜬 화음을 이룬다. "
    "何を意味するのかも、誰の声なのかも定かでないその声は、霞んだ記憶と混ざり合って浮ついた和音を奏でる。"

# game/chapter6.rpy:1146
translate japanese ecg12_label_84f58cf0:

    # "유미가 내게 건넸던 말의 조각과 내 기억의 조각이 어울려 자아낸 화음인 걸까. "
    "ユミが俺に投げかけた言葉の欠片と、俺の記憶の欠片が混ざり合って生み出した和音なのだろうか。"

# game/chapter6.rpy:1147
translate japanese ecg12_label_88e94ddf:

    # "하지만 그 화음은 끝내 마침표에 달하지 못하고 연주를 멈춘다. "
    "だがその和音はついに終止符に辿り着けず、演奏を止める。"

# game/chapter6.rpy:1148
translate japanese ecg12_label_f4c75db7:

    # "그리고 화음이 그려낸, 알코올의 이상한 가역반응이 만들어낸 허상 속의 누군가가 나에게――― "
    "そして和音が描き出した、アルコールの奇妙な可逆反応が作り出した幻影の中の誰かが俺に———"

# game/chapter6.rpy:1152
translate japanese ecg12_label_1f809570:

    # voice "voices/gf3.ogg"
    # 소녀 "“기다리고 있을게.”"
    voice "voices/gf3.ogg"
    소녀 "「待ってるから。」"

# game/chapter6.rpy:1154
translate japanese ecg12_label_d9696087:

    # voice ""
    # "나에게, 연주의 끝을 기다리고 있겠다는 말을 건넸다. "
    voice ""
    "俺に、演奏の終わりを待っていると告げた。"

# game/chapter6.rpy:1156
translate japanese ecg12_label_ab31b571:

    # "허상이었지만, 너무나도 또렷한 장면이었다. "
    "幻覚だったが、あまりにも鮮明な光景だった。"

# game/chapter6.rpy:1157
translate japanese ecg12_label_8b915bc8:

    # "너무나도 진실되고 따뜻한 한 마디였다. "
    "あまりにも真実味のある、温かい一言だった。"

# game/chapter6.rpy:1158
translate japanese ecg12_label_7b14794f:

    # "하지만 소녀가 내게 기다리고 있겠다고 말하는 그 모습을. "
    "だが少女が俺に待っていると言うその姿を。"

# game/chapter6.rpy:1159
translate japanese ecg12_label_94f5ed6c:

    # "나는 어째서 지금 이 순간 그려내고 있는 것일까? "
    "俺はなぜ今この瞬間に思い描いているのだろう？"

# game/chapter6.rpy:1163
translate japanese ecg12_label_c59d3ccd:

    # "그리고 내게 건네진 그 목소리는 미처 끝까지 닿지 못했던 연주의 끝을 대신 장식하기라도 하듯 나를 검고 꽉 막힌 공간으로 안내했다. "
    "そして俺に届いたその声は、最後まで届かなかった演奏の終わりを代わりに飾るかのように、俺を暗く閉ざされた空間へと導いた。"

# game/chapter6.rpy:1165
translate japanese ecg12_label_1535ed49:

    # "손을 뻗었다. "
    "手を伸ばした。"

# game/chapter6.rpy:1166
translate japanese ecg12_label_aa0cc200:

    # "아무것도 만져지지 않을 거라 생각했다. "
    "何にも触れないだろうと思った。"

# game/chapter6.rpy:1167
translate japanese ecg12_label_0b46aad4:

    # "허공을 붙잡듯 내저은 나의 손은, 잃어버렸던 기억의 한 조각을 붙잡으려 하고 있었다. "
    "虚空を掴むように振った俺の手は、失われた記憶の欠片を掴もうとしていた。"

# game/chapter6.rpy:1168
translate japanese ecg12_label_0a49d633:

    # "하지만 어째서, 그 기억의 조각은 소녀를 가리키고 있는 걸까. "
    "だがなぜ、その記憶の欠片は少女を指しているのだろう。"

# game/chapter6.rpy:1172
translate japanese ecg12_label_e8a65618:

    # "소녀에 대한 미련이라 생각하고 고개를 가로저으려는 순간. "
    "少女への未練だと思い、首を横に振ろうとした瞬間。"

# game/chapter6.rpy:1179
translate japanese ecg12_label_9c350b05:

    # voice "voices/yf85.ogg"
    # 유미 "“야아, 고작 그거 마시고 취한 거야~? 난 아직 안 취했는데…….”"
    voice "voices/yf85.ogg"
    유미 "「ちょっと、たったあれだけ飲んで酔ったの～？ 私はまだ酔ってないのに……」"

# game/chapter6.rpy:1181
translate japanese ecg12_label_ada80b23:

    # voice ""
    # 나 "“아, 그게…….”"
    voice ""
    나 "「あ、あれは……」"

# game/chapter6.rpy:1184
translate japanese ecg12_label_d7f513b0:

    # "알코올이 만들어낸 환상에서 깨어나 버렸다. "
    "アルコールが作り出した幻覚から覚めてしまった。"

# game/chapter6.rpy:1186
translate japanese ecg12_label_e6401cee:

    # voice "voices/yf86.ogg"
    # 유미 "“중요한 거 이야기하려 했다고―――”"
    voice "voices/yf86.ogg"
    유미 "「大事なこと話そうとしてたのに———」"

# game/chapter6.rpy:1188
translate japanese ecg12_label_f60b8e48:

    # voice ""
    # 나 "“일단 일어나자. 돌아가는 길에 이야기하는 게 좋을 것 같아.”"
    voice ""
    나 "「とりあえず立とう。帰り道に話したほうがいいと思う。」"

# game/chapter6.rpy:1191
translate japanese ecg12_label_3c715c60:

    # "계산서를 챙겨 자리에서 먼저 일어나자, 유미도 '어쩔 수 없네'라는 표정을 짓고선 나를 따라 몸을 일으켰다. "
    "伝票を持って先に席を立つと、ユミも\"しょうがないな\"という表情で俺に続いて立ち上がった。"

# game/chapter6.rpy:1197
translate japanese ecg12_label_da09a3bd:

    # 나 "“계단 내려갈 수 있겠어?”"
    나 "「階段降りられる？」"

# game/chapter6.rpy:1198
translate japanese ecg12_label_4b3d88eb:

    # voice "voices/yf87.ogg"
    # 유미 "“으응……? 당연하지?”"
    voice "voices/yf87.ogg"
    유미 "「ん……？ 当然でしょ？」"

# game/chapter6.rpy:1200
translate japanese ecg12_label_d7a61236:

    # voice ""
    # "당연하다고 말하기엔 유미의 휘청이는 걸음걸이가 너무 위험해 보였다. "
    voice ""
    "当然とは言うものの、ユミのふらつく足取りはあまりに危なっかしく見えた。"

# game/chapter6.rpy:1203
translate japanese ecg12_label_c92e483e:

    # voice "voices/yf88.ogg"
    # 유미 "“나 하나도 안 취했다니까아앗―――”"
    voice "voices/yf88.ogg"
    유미 "「私ぜんっぜん酔ってないってばぁ———」"

# game/chapter6.rpy:1205
translate japanese ecg12_label_08600523:

    # voice ""
    # 나 "“…… 부축해 줄게. 조심해서 내려가자.”"
    voice ""
    나 "「……支えてやるから。気をつけて降りよう。」"

# game/chapter6.rpy:1208
translate japanese ecg12_label_79c9c75f:

    # voice "voices/yf89.ogg"
    # 유미 "“흐으으음~”"
    voice "voices/yf89.ogg"
    유미 "「ふぅーん～」"

# game/chapter6.rpy:1211
translate japanese ecg12_label_c0bc28b9:

    # voice ""
    # "다행이라고 해야 할까, 유미는 군소리 없이 나의 어깨에 붙어 부축을 받아 주었다. "
    voice ""
    "幸いというべきか、ユミは文句も言わず俺の肩にもたれかかった。"

# game/chapter6.rpy:1213
translate japanese ecg12_label_74babc7f:

    # "한 가지 문제점이라면 계단이 끝나고 거리로 나온 뒤에도, 나의 어깨에서 떨어질 생각을 하지 않았다는 것. "
    "ひとつ問題があるとすれば、階段を降りて通りに出た後も、俺の肩から離れる気配がなかったこと。"

# game/chapter6.rpy:1214
translate japanese ecg12_label_6f938967:

    # "그 정도겠지. "
    "まあ、その程度だろう。"

# game/chapter6.rpy:1219
translate japanese ecg12_label_7f709a58:

    # "유미는 잔뜩 취한 몸을 나의 어깨에 기댄 채 밤거리를 걸었다. "
    "ユミはすっかり酔った体を俺の肩に預けたまま夜の街を歩いた。"

# game/chapter6.rpy:1221
translate japanese ecg12_label_d2d93a4f:

    # voice "voices/yf90.ogg"
    # 유미 "“저기, 저기 좀 봐~”"
    voice "voices/yf90.ogg"
    유미 "「ねえ、あれ見て～」"

# game/chapter6.rpy:1223
translate japanese ecg12_label_72af741c:

    # voice ""
    # "집을 향해 걷던 도중, 유미는 난데없이 하늘을 손가락으로 가리켰다. "
    voice ""
    "家に向かって歩く途中、ユミは突然空を指さした。"

# game/chapter6.rpy:1226
translate japanese ecg12_label_6b6d53fb:

    # voice "voices/yf91.ogg"
    # 유미 "“저 별 말이야. 되게 특이하지 않아?”"
    voice "voices/yf91.ogg"
    유미 "「あの星のことなんだけど。すごく変わってない？」"

# game/chapter6.rpy:1228
translate japanese ecg12_label_50bd52d2:

    # voice ""
    # "유미가 가리킨 곳을 향해 시선을 옮긴 나는 그리 어렵지 않게 유미가 가리킨 별을 찾을 수 있었다. "
    voice ""
    "ユミが指した方へ視線を向けると、それほど苦もなくユミの指す星を見つけることができた。"

# game/chapter6.rpy:1230
translate japanese ecg12_label_b05419cc:

    # "무미건조한 밤하늘에는 수수하다는 단어가 어울릴 정도로 고작 몇 개의 별만이 어렴풋이 빛을 발하고 있을 뿐이었으니까. "
    "味気のない夜空には、地味という言葉がふさわしいほど、わずか数個の星だけがぼんやりと光を放っていたのだから。"

# game/chapter6.rpy:1231
translate japanese ecg12_label_c07c2d07:

    # "나는 그리 특별할 것 없어 보이는 이름 모를 별 하나를, 잘 모르겠다는 듯 유미와 번갈아가며 바라보았다. "
    "俺はそれほど特別には見えない名も知らぬ星を、よく分からないというようにユミと交互に見た。"

# game/chapter6.rpy:1232
translate japanese ecg12_label_4bd2b538:

    # "곧이어 유미의 들뜬 목소리가 들려왔다. "
    "間もなくユミの弾んだ声が聞こえた。"

# game/chapter6.rpy:1234
translate japanese ecg12_label_241fc4bf:

    # voice "voices/yf92.ogg"
    # 유미 "“저거 말이야, 쌍성 아닐까?”"
    voice "voices/yf92.ogg"
    유미 "「あれってさ、連星じゃない？」"

# game/chapter6.rpy:1236
translate japanese ecg12_label_306aca9d:

    # voice ""
    # 나 "“쌍성?”"
    voice ""
    나 "「連星？」"

# game/chapter6.rpy:1242
translate japanese ecg12_label_8a4be98d:

    # voice "voices/yf93.ogg"
    # 유미 "“으응. 하늘에 떠있는 별 중에는 짝이 있는 별이 있댔거든~ 그냥 그런 줄로만 알고 있었는데, 직접 보는 건 처음이야!”"
    voice "voices/yf93.ogg"
    유미 "「うん。空に浮かんでる星の中には、対になってる星があるんだって～ 知識としては知ってたけど、実際に見るのは初めて！」"

# game/chapter6.rpy:1244
translate japanese ecg12_label_8c1a71af:

    # voice ""
    # 나 "“으음…….”"
    voice ""
    나 "「ふーん……」"

# game/chapter6.rpy:1250
translate japanese ecg12_label_83d08ca3:

    # "잠깐 발걸음을 멈추고선 유미가 가리킨 별을 빤히 응시했다. "
    "少し足を止めて、ユミが指した星をじっと見つめた。"

# game/chapter6.rpy:1251
translate japanese ecg12_label_bde8f5b3:

    # "쌍성이라면 아주 가까이 붙어 있는 두 별을 의미하는 걸까? "
    "連星というのは、ごく近くに寄り添う二つの星のことだろうか？"

# game/chapter6.rpy:1252
translate japanese ecg12_label_22616fdf:

    # "밤하늘에 시선을 고정시킨 채, 나는 별빛의 갈래를 찾아 눈을 찡그렸다. "
    "夜空に視線を据えたまま、俺は星の光の分かれ目を探して目を細めた。"

# game/chapter6.rpy:1253
translate japanese ecg12_label_67aafbda:

    # "하지만 미간이 아파 올 정도로 눈을 찡그려 별빛을 뚫어져라 관찰해 보아도 유미가 가리킨 별은 밤하늘에 홀로 덩그러니 놓인 것만 같아 보였다. "
    "だが眉間が痛くなるほど目を細めて星を凝視しても、ユミが指した星は夜空にぽつんと一つだけ浮かんでいるようにしか見えなかった。"

# game/chapter6.rpy:1255
translate japanese ecg12_label_c2b0b471:

    # 나 "“…… 이거 몇 개로 보여?”"
    나 "「……これ何本に見える？」"

# game/chapter6.rpy:1257
translate japanese ecg12_label_93799d0d:

    # "하늘을 바라보며 들뜬 목소리로 이야기를 이어가던 유미에게, 나는 손가락 하나를 펼쳐 들고선 흔들어 보였다. "
    "空を眺めながら弾んだ声で話を続けるユミに、俺は指を一本立てて見せた。"

# game/chapter6.rpy:1261
translate japanese ecg12_label_48c2e6fb:

    # voice "voices/yf94.ogg"
    # 유미 "“히, 두 개 아니야?”"
    voice "voices/yf94.ogg"
    유미 "「えっ、二本じゃない？」"

# game/chapter6.rpy:1263
translate japanese ecg12_label_b28fdd1a:

    # voice ""
    # 나 "“많이 취한 것 같네…….”"
    voice ""
    나 "「だいぶ酔ってるみたいだな……」"

# game/chapter6.rpy:1266
translate japanese ecg12_label_429be5ea:

    # voice "voices/yf95.ogg"
    # 유미 "“많이 취한 거 아냐~ 그냥 조금 들뜬 거라니까?”"
    voice "voices/yf95.ogg"
    유미 "「酔ってないって～ ちょっとテンション上がってるだけだってば？」"

# game/chapter6.rpy:1268
translate japanese ecg12_label_081c7956:

    # voice ""
    # 나 "“집까지 데려다 줄 테니까, 조심해서 걸어.”"
    voice ""
    나 "「家まで送ってやるから、気をつけて歩けよ。」"

# game/chapter6.rpy:1271
translate japanese ecg12_label_3da117a7:

    # voice "voices/yf96.ogg"
    # 유미 "“에헤헤…….”"
    voice "voices/yf96.ogg"
    유미 "「えへへ……」"

# game/chapter6.rpy:1276
translate japanese ecg12_label_c5995e4c:

    # voice ""
    # "그 말을 듣자, 유미는 기다렸다는 듯 나의 어깨에 몸을 조금 더 기대왔다. "
    voice ""
    "その言葉を聞くと、ユミは待ってましたとばかりに俺の肩にもう少し体を預けてきた。"

# game/chapter6.rpy:1282
translate japanese ecg12_label_2ef74ee0:

    # "재잘거리던 유미의 목소리가 어느 순간부터 들리지 않았다. "
    "はしゃいでいたユミの声が、いつの間にか聞こえなくなっていた。"

# game/chapter6.rpy:1283
translate japanese ecg12_label_b3de8598:

    # "언젠가부터 나의 등에 업혀있던 누군가를 흔들어 깨우며, 나는 유미에게 일어나라는 이야기를 몇 번이고 반복했다. "
    "いつからか俺の背中におぶさっていた誰かを揺り起こしながら、俺は起きろとユミに何度も繰り返した。"

# game/chapter6.rpy:1285
translate japanese ecg12_label_9dd93ad7:

    # 나 "“야아. 집에 다 왔어. 정신 차려.”"
    나 "「おい。家に着いたぞ。しっかりしろ。」"

# game/chapter6.rpy:1287
translate japanese ecg12_label_520dbd44:

    # voice "voices/yf97.ogg"
    # 유미 "“으응?! 내가 언제 정신 놓았다고 그래?”"
    voice "voices/yf97.ogg"
    유미 "「んぇ？！ いつ意識飛んだの？」"

# game/chapter6.rpy:1289
translate japanese ecg12_label_eb925aeb:

    # voice ""
    # 나 "“드디어 일어났구만.”"
    voice ""
    나 "「やっと起きたか。」"

# game/chapter6.rpy:1292
translate japanese ecg12_label_e2726c29:

    # "여덟 번째 외침이 드디어 귀에 닿았는지, 유미는 화들짝 놀라 눈을 동그랗게 뜨고선 나를 빤히 바라보았다. "
    "八度目の呼びかけがようやく届いたのか、ユミは驚いて目を丸くし、俺をじっと見つめた。"

# game/chapter6.rpy:1294
translate japanese ecg12_label_05cabcfe:

    # voice "voices/yf98.ogg"
    # 유미 "“여긴 어디야?”"
    voice "voices/yf98.ogg"
    유미 "「ここどこ？」"

# game/chapter6.rpy:1296
translate japanese ecg12_label_69a0842b:

    # voice ""
    # 나 "“어디긴, 네 집 앞이지.”"
    voice ""
    나 "「どこって、お前の家の前だろ。」"

# game/chapter6.rpy:1299
translate japanese ecg12_label_7622f931:

    # "꿈 속을 헤매기라도 하듯 주변을 두리번거리는 유미. "
    "夢の中をさまようように周りをきょろきょろ見回すユミ。"

# game/chapter6.rpy:1300
translate japanese ecg12_label_b760a3c8:

    # "유미는 휘청거리는 발걸음으로 근처를 이리저리 배회하더니 이윽고 나의 앞에 멈춰 섰다. "
    "ユミはふらつく足取りで辺りをうろうろした後、やがて俺の前に立ち止まった。"

# game/chapter6.rpy:1302
translate japanese ecg12_label_30792643:

    # voice "voices/yf99.ogg"
    # 유미 "“신기하다. 꿈 속을 걸어다니는 것 같아.”"
    voice "voices/yf99.ogg"
    유미 "「不思議。夢の中を歩いてるみたい。」"

# game/chapter6.rpy:1304
translate japanese ecg12_label_58d7200b:

    # voice ""
    # 나 "“꿈 아니거든…….”"
    voice ""
    나 "「夢じゃないから……」"

# game/chapter6.rpy:1309
translate japanese ecg12_label_15722310:

    # voice "voices/yf100.ogg"
    # 유미 "“그러게. 아쉽다. 꿈이었으면 지금 바로 이야기했을 텐데.”"
    voice "voices/yf100.ogg"
    유미 "「そうだよね。残念。夢だったら今すぐ言えたのに。」"

# game/chapter6.rpy:1315
translate japanese ecg12_label_efc010ee:

    # voice ""
    # "알듯 말듯한 이야기를 내뱉은 유미는 방향을 틀어 건물 입구로 향했다. "
    voice ""
    "意味深な言葉を残したユミは、向きを変えて建物の入口に向かった。"

# game/chapter6.rpy:1317
translate japanese ecg12_label_107c3aa7:

    # "하늘하늘 손을 양옆으로 흔든 유미가, 이에 발맞춰 나에게서 멀어져갔다. "
    "ひらひらと手を左右に振ったユミが、それに合わせて俺から遠ざかっていった。"

# game/chapter6.rpy:1318
translate japanese ecg12_label_14dccc76:

    # "나는 유미가 자동문 너머로 사라지는 것을 본 뒤에서야 겨우 발걸음을 돌릴 수 있었다. "
    "俺はユミが自動ドアの向こうに消えるのを見届けてから、ようやく足を向けることができた。"

# game/chapter6.rpy:1320
translate japanese ecg12_label_dd1e66b7:

    # 나 "“으음…….”"
    나 "「んー……」"

# game/chapter6.rpy:1322
translate japanese ecg12_label_151fd4da:

    # "얼굴을 가볍게 찡그리고는 체내에 미묘하게 남아있는 알코올 기운을 가늠하려 했다. "
    "軽く顔をしかめ、体内に微かに残るアルコールの気配を測ろうとした。"

# game/chapter6.rpy:1323
translate japanese ecg12_label_f5aaba23:

    # "생각에 방해되지 않을 정도겠지, 라고 생각하며 길을 걸으려 했지만 옷에 희미하게 남아있는 누군가의 잔재가 생각을 자꾸만 방해하고 있었다. "
    "思考の邪魔にならない程度だろうと思って歩き出そうとしたが、服にかすかに残る誰かの名残が、思考の邪魔をし続けていた。"

# game/chapter6.rpy:1324
translate japanese ecg12_label_73941f93:

    # "한 명의 것이라 생각되었던 잔재는 숨을 들이마시며 생각에 잠기려 하자 단숨에 두 명의 것이 된다. "
    "一人の分だと思っていた名残は、息を吸い込んで考えに沈もうとした途端に二人分になった。"

# game/chapter6.rpy:1328
translate japanese ecg12_label_8361bf31:

    # "마음에 걸리는 것들투성이다. "
    "気になることだらけだ。"

# game/chapter6.rpy:1334
translate japanese ecg12_label_1a2786db:

    # voice "voices/ef10.ogg"
    # 유미 "“그러게. 아쉽다. 꿈이었으면 지금 바로 이야기했을 텐데.”"
    voice "voices/ef10.ogg"
    유미 "「そうだよね。残念。夢だったら今すぐ言えたのに。」"

# game/chapter6.rpy:1337
translate japanese ecg12_label_bae32100:

    # voice ""
    # "걸음을 내디딜 때마다 거꾸로 기억을 이어나간다. "
    voice ""
    "一歩踏み出すたびに、記憶を遡っていく。"

# game/chapter6.rpy:1340
translate japanese ecg12_label_abc52a90:

    # voice "voices/ef11.ogg"
    # 유미 "“중요한 거 이야기하려 했다고―――”"
    voice "voices/ef11.ogg"
    유미 "「大事なこと話そうとしてたのに———」"

# game/chapter6.rpy:1343
translate japanese ecg12_label_c8ddba21:

    # voice ""
    # "유미가 이야기하려 했던 중요한 것이라니. "
    voice ""
    "ユミが話そうとしていた大事なこととは。"

# game/chapter6.rpy:1346
translate japanese ecg12_label_697db50f:

    # voice "voices/ef12.ogg"
    # 유미 "“맨정신에는 이야기 못 하는 거, 지금 하고 싶은데.”"
    voice "voices/ef12.ogg"
    유미 "「シラフじゃ言えないこと、今言いたいんだけど。」"

# game/chapter6.rpy:1349
translate japanese ecg12_label_d9be0512:

    # voice ""
    # "몇 걸음 떼지 않았는데, 희미하게 남아있는 알코올 때문이기라도 한 건지. "
    voice ""
    "まだ数歩も歩いていないのに、かすかに残るアルコールのせいだろうか。"

# game/chapter6.rpy:1351
translate japanese ecg12_label_4b8213ac:

    # "발걸음을 멈추었다. "
    "足を止めた。"

# game/chapter6.rpy:1353
translate japanese ecg12_label_68c58650:

    # "멈추어버린 발걸음처럼, 생각도 이어지지 않았다. "
    "止まってしまった足のように、思考も続かなかった。"

# game/chapter6.rpy:1358
translate japanese ecg12_label_b0c55d01:

    # voice "voices/ef13.ogg"
    # 유미 "“있지, 나 말이야.”"
    voice "voices/ef13.ogg"
    유미 "「あのね、私ね。」"

# game/chapter6.rpy:1362
translate japanese ecg12_label_b4573f37:

    # voice "voices/ef14.ogg"
    # whoso "“너를―――”"
    voice "voices/ef14.ogg"
    whoso "「あなたのこと———」"

# game/chapter6.rpy:1370
translate japanese ecg12_label_c38c90fa:

    # voice ""
    # 나 "“아냐, 아냐, 아니라고.”"
    voice ""
    나 "「違う、違う、違うって。」"

# game/chapter6.rpy:1377
translate japanese ecg12_label_1f809570_1:

    # voice "voices/gf3.ogg"
    # 소녀 "“기다리고 있을게.”"
    voice "voices/gf3.ogg"
    소녀 "「待ってるから。」"

# game/chapter6.rpy:1380
translate japanese ecg12_label_1c8a0240:

    # voice ""
    # "머릿속에서 하릴없이 변주된 목소리는 이번에도 소녀를 가리키고 있었고, 나는 그대로 아무도 없는 저편을 향해 소리를 버럭 질렀다. "
    voice ""
    "頭の中でとめどなく変奏された声は今回も少女を指し示していて、俺はそのまま誰もいないあちら側に向かって声を荒げた。"

# game/chapter6.rpy:1383
translate japanese ecg12_label_05946d4b:

    # "두 명째의 잔재가 다시금 나의 앞에 나타난 것이다. "
    "二人目の名残が再び俺の前に現れたのだ。"

# game/chapter6.rpy:1385
translate japanese ecg12_label_2f88580d:

    # "지나가던 사람들 중 한 명이 나를 힐긋 바라보았지만, 나는 그 속에서 더할 나위 없는 익숙함을 느낀다. "
    "通りすがりの人が俺をちらりと見たが、俺はそこにこの上ない親しみを感じる。"

# game/chapter6.rpy:1386
translate japanese ecg12_label_ef471cda:

    # "허무하리만치 느껴질 정도의 편안함이, 나를 감싸안고 있었다. "
    "虚しいほどの安らぎが、俺を包み込んでいた。"

# game/chapter6.rpy:1391
translate japanese ecg12_label_396673fa_3:

    # 나 "“…….”"
    나 "「……」"

# game/chapter6.rpy:1393
translate japanese ecg12_label_5c28dceb:

    # "어째서일까? "
    "どうしてだろう？"

# game/chapter6.rpy:1394
translate japanese ecg12_label_e5b6c04c:

    # "어디에 있는지조차 모르고, 그런 말을 했을 리도 없는 소녀가. "
    "どこにいるかも分からず、そんなことを言うはずもない少女が。"

# game/chapter6.rpy:1395
translate japanese ecg12_label_e128835f:

    # "내게 왜 기다리고 있겠다는 말을 기억 속에서 속삭였던 것일까? "
    "なぜ俺に待っていると、記憶の中でささやいたのだろう？"

# game/chapter6.rpy:1396
translate japanese ecg12_label_68816dab:

    # "골몰하면 골몰할 수록 정답과는 멀어지는 기분이 들었다. "
    "考えれば考えるほど、答えから遠ざかる気がした。"

# game/chapter6.rpy:1398
translate japanese ecg12_label_486911b1:

    # 나 "“우윽…….”"
    나 "「うぅ……」"

# game/chapter6.rpy:1400
translate japanese ecg12_label_6b2246e7:

    # "뒤늦은 술기운이 조금씩 올라오고 있었다. "
    "遅れてきた酔いが少しずつ回り始めていた。"

# game/chapter6.rpy:1401
translate japanese ecg12_label_00e41acd:

    # "알코올의 영향력이 스멀스멀 몸에 퍼지자, 온몸이 느슨해지는 듯했다. "
    "アルコールの影響がじわじわと体に広がると、全身が溶けていくようだった。"

# game/chapter6.rpy:1405
translate japanese ecg12_label_5d7ef893:

    # "그와 동시에, 어쩌면 그럴지도 모르겠다는 생각이 머릿속에서 물감처럼 퍼져 나가기 시작했다. "
    "それと同時に、仮説が頭の中で絵の具のように広がり始めた。"

# game/chapter6.rpy:1407
translate japanese ecg12_label_8fc2070c:

    # "언젠가 나는 소녀에게 약속했던 게 아닐까? "
    "いつか俺は少女に約束したのではないだろうか？"

# game/chapter6.rpy:1408
translate japanese ecg12_label_2c3e2842:

    # "언젠가인지는 알 수 없지만, 내가 기억하지 못하는 어느 순간에. "
    "いつだったかは分からないが、俺が覚えていないどこかの瞬間に。"

# game/chapter6.rpy:1409
translate japanese ecg12_label_3dd782a2:

    # "나는 소녀에게 '기다려 달라'는 이야기를 건넸던 건 아니었을까. "
    "俺は少女に\"待っていてくれ\"と言ったのではないだろうか。"

# game/chapter6.rpy:1411
translate japanese ecg12_label_396673fa_4:

    # 나 "“…….”"
    나 "「……」"

# game/chapter6.rpy:1415
translate japanese ecg12_label_0082fbf2:

    # "하긴, 그럴 리가 없지. "
    "いや、そんなはずはない。"

# game/chapter6.rpy:1416
translate japanese ecg12_label_fb0842ca:

    # "결함투성이 망상을 멈추고는 그와 함께 움직이지 않고 있던 발걸음을 다시 떼었다. "
    "欠陥だらけの妄想を止め、それとともに動かなくなっていた足を再び踏み出した。"

# game/chapter6.rpy:1417
translate japanese ecg12_label_7d1a904b:

    # "단순한 망상일 뿐이다. "
    "ただの妄想に過ぎない。"

# game/chapter6.rpy:1418
translate japanese ecg12_label_e496b066:

    # "집으로 돌아가 흐르는 물에 샤워라도 하고 나면 간단히 씻겨져 내려갈 바보같은 망상. "
    "家に帰ってシャワーを浴びれば簡単に洗い流せるような、馬鹿げた妄想。"

# game/chapter6.rpy:1419
translate japanese ecg12_label_481e01c6:

    # "분명 그럴 터인데 말이다. "
    "きっとそうに違いないのに。"

# game/chapter6.rpy:1420
translate japanese ecg12_label_1df0ca3e:

    # "나는 굳이 이 망상에 가까운 가설의 증명을 소녀에게 맡기고 싶었던 걸까. "
    "俺はあえてこの妄想に近い仮説の証明を、少女に委ねたかったのだろうか。"

# game/chapter6.rpy:1424
translate japanese ecg12_label_446aa348:

    # "소녀를 만나고 싶었다. "
    "少女に会いたかった。"

# game/chapter6.rpy:1425
translate japanese ecg12_label_983c39f2:

    # "행방을 알 수 없는 소녀를 찾아, 나는 자신을 향해 끊임없이 생각을 요구했다. "
    "行方の知れない少女を探して、俺は自分自身に絶え間なく思考を求めた。"

# game/chapter6.rpy:1429
translate japanese ecg12_label_a7f05cda:

    # "소녀는 어디로 사라진 걸까? "
    "少女はどこに消えたのだろう？"

# game/chapter6.rpy:1430
translate japanese ecg12_label_39b67e55:

    # "나는 어디로 가야 하는 걸까? "
    "俺はどこへ行けばいいのだろう？"

# game/chapter6.rpy:1432
translate japanese ecg12_label_55a050e5:

    # "발걸음이 제멋대로 움직이기 시작했다. "
    "足が勝手に動き始めた。"

# game/chapter6.rpy:1438
translate japanese ecg12_label_07372b4f:

    # "정신을 차리자, 나는 어느새 터미널에 도착해 F구역으로 향하는 열차를 기다리고 있었다. "
    "気がつくと、俺はいつの間にかターミナルに着いてF区域行きの列車を待っていた。"

# game/chapter6.rpy:1439
translate japanese ecg12_label_3d7a7efc:

    # "만약, 정말 만에 하나 소녀가 나에게 '기다리고 있겠다'는 말을 남겼다면. "
    "もし、本当に万が一少女が俺に\"待っている\"という言葉を残していたなら。"

# game/chapter6.rpy:1440
translate japanese ecg12_label_082fb477:

    # "어쩌면 소녀는 여전히 E구역에서 나를 기다리고 있지 않을까? "
    "もしかしたら少女はまだE区域で俺を待っているのではないだろうか？"

# game/chapter6.rpy:1441
translate japanese ecg12_label_275e5b4b:

    # "비상식적인 생각이었지만, 비상식적인 행동에는 비상식적인 이유가 따르기 마련이라며 나는 무작정 열차에 탑승해버린 뒤였다. "
    "非常識な考えだったが、非常識な行動には非常識な理由がつきものだと言い聞かせ、俺はがむしゃらに列車に乗り込んだ後だった。"

# game/chapter6.rpy:1442
translate japanese ecg12_label_ec702168:

    # "열차를 타고 F구역에 도착해 E구역으로 향하는 샛길을 찾는 건 단숨이었다. "
    "列車に乗ってF区域に着き、E区域へ向かう脇道を見つけるのはあっという間だった。"

# game/chapter6.rpy:1443
translate japanese ecg12_label_390693d2:

    # "골목길 끄트머리에 위치한 흐트러진 철조망. "
    "路地の突き当たりにある乱れた鉄条網。"

# game/chapter6.rpy:1444
translate japanese ecg12_label_445567b3:

    # "정말 이곳 너머에 소녀가 있는 것일까? "
    "本当にこの向こうに少女がいるのだろうか？"

# game/chapter6.rpy:1445
translate japanese ecg12_label_0a9292f7:

    # "나는 잠시 걸음을 멈춘 채, 찰나의 고민에 빠졌다. "
    "俺はしばし足を止め、一瞬の逡巡に陥った。"

# game/chapter6.rpy:1447
translate japanese ecg12_label_eac01b3a:

    # 나 "“여기까지 와서 고민은 무슨 고민이야.”"
    나 "「ここまで来て迷ってどうする。」"

# game/chapter6.rpy:1449
translate japanese ecg12_label_bfab6831:

    # "왠지 어디선가 나를 향하는 시선이 느껴지는 것 같아 주변을 슬쩍 둘러보았지만, 역시나 소녀의 모습은 전혀 보이지 않았다. "
    "なぜかどこからか俺に向けられた視線を感じた気がして周囲をさっと見回したが、やはり少女の姿はどこにも見えなかった。"

# game/chapter6.rpy:1450
translate japanese ecg12_label_b77af711:

    # "하지만 이곳까지 와서 돌아가는 것도 내키지 않는 일이었다. "
    "だがここまで来て引き返す気にもなれなかった。"

# game/chapter6.rpy:1452
translate japanese ecg12_label_984e3571:

    # "철조망을 넘어 어둠이 짙게 깔린 좁은 길목으로 몇 걸음을 걸어가자, 처음에 왔을 땐 단번에 발견하지 못했던 여러 갈래의 빛이 나를 반겼다. "
    "鉄条網を越えて闇の濃い細い道を数歩進むと、初めて来たときには一目で見つけられなかった幾筋もの光が俺を出迎えた。"

# game/chapter6.rpy:1453
translate japanese ecg12_label_009d6aaf:

    # "별빛이었다. "
    "星の光だった。"

# game/chapter6.rpy:1454
translate japanese ecg12_label_d0ccfe57:

    # "소녀와 함께 보았던, 하늘을 가득 수놓은 별빛. "
    "少女と一緒に見た、空いっぱいに散りばめられた星の光。"

# game/chapter6.rpy:1455
translate japanese ecg12_label_f5d8589b:

    # "그 풍경을 바라보자, 오직 소녀의 생각만으로 가득하던 머릿속에 또 다른 한 명의 이름이 틈을 비집고 들어왔다. "
    "その景色を見つめると、少女のことだけで埋め尽くされていた頭の中に、もう一人の名前が割り込んできた。"

# game/chapter6.rpy:1457
translate japanese ecg12_label_72cf54c3:

    # 나 "‘이럴 줄 알았으면 유미도 같이 데려올 걸 그랬나.’"
    나 "(こうなるならユミも一緒に連れてくればよかったかな。)"

# game/chapter6.rpy:1459
translate japanese ecg12_label_0bbab970:

    # "무수히 많은 저 별빛의 틈 속에는 유미가 가리켰던 그 이름 모를 별도 섞여 있겠지. "
    "あの無数の星の光の間には、ユミが指していた名も知らない星も紛れているだろう。"

# game/chapter6.rpy:1460
translate japanese ecg12_label_45773bc5:

    # "밤하늘을 바라보던 시선을 떨구고는, 등 뒤를 힐긋 바라보았다. "
    "夜空を見つめていた視線を落とし、背後をちらりと振り返った。"

# game/chapter6.rpy:1461
translate japanese ecg12_label_e50d8ed6:

    # "역시, 누가 있을 리가 없을 거라는 생각에 머쓱한 웃음을 흘리려는데. "
    "やはり、誰もいるはずがないと思いバツの悪い笑いを漏らそうとしたとき。"

# game/chapter6.rpy:1466
translate japanese ecg12_label_a69b5754:

    # "그쪽에서 들려온 바스락대는 소리가 나의 신경을 곤두세웠다. "
    "そちらから聞こえてきたガサガサという音が、神経を逆立てた。"

# game/chapter6.rpy:1468
translate japanese ecg12_label_c141198c:

    # 나 "“…… 거기 있어?”"
    나 "「……そこにいるのか？」"

# game/chapter6.rpy:1470
translate japanese ecg12_label_55481454:

    # "대답은 들려오지 않았다. "
    "返事は聞こえなかった。"

# game/chapter6.rpy:1471
translate japanese ecg12_label_0b2339e4:

    # "소리가 들려온 곳으로 한 발짝 걸음을 떼자, 다시금 발자국 소리가 또렷이 들려왔다. "
    "音の聞こえた方へ一歩踏み出すと、再び足音がはっきりと聞こえた。"

# game/chapter6.rpy:1472
translate japanese ecg12_label_0cad45e9:

    # "선명하게 들려온 그 발자국 소리는, 나로부터 조금씩 멀어져가고 있었다. "
    "くっきりと聞こえたその足音は、俺から少しずつ遠ざかっていた。"

# game/chapter6.rpy:1473
translate japanese ecg12_label_5e0884f7:

    # "마치, 나를 피하려는 듯 말이다. "
    "まるで、俺から逃げようとしているかのように。"

# game/chapter6.rpy:1476
translate japanese ecg12_label_2e0260d5:

    # 나 "“잠깐만! 기다려! 할 말이 있어!”"
    나 "「待ってくれ！ 話があるんだ！」"

# game/chapter6.rpy:1478
translate japanese ecg12_label_2e3519e5:

    # "멀어져가는 발자국 소리를 놓치지 않기 위해, 나는 필사적으로 소리가 들려오는 곳을 향해 뛰었다. "
    "遠ざかる足音を見失わないよう、俺は必死に音の聞こえる方へ走った。"

# game/chapter6.rpy:1479
translate japanese ecg12_label_36c9b231:

    # "흐릿하게 흩어져가는 발자국 소리 역시 나에게서 멀어지기 위해 속도를 더 올리고 있는 것 같았다. "
    "ぼんやりと散っていく足音もまた、俺から離れるために速度を上げているようだった。"

# game/chapter6.rpy:1480
translate japanese ecg12_label_4ca30470:

    # "그때와 똑같았다. "
    "あのときと同じだった。"

# game/chapter6.rpy:1481
translate japanese ecg12_label_f23fec11:

    # "소녀와 나의 짧았던 첫만남의 순간처럼. "
    "少女と俺の短い初めての出会いの瞬間のように。"

# game/chapter6.rpy:1482
translate japanese ecg12_label_dfd16bac:

    # "‘괜한 짓을 하고 있는 걸까’라는 생각을 하면서도, 나는 멀어져가는 그녀의 흔적을 뒤쫓았다. "
    "\"無駄なことをしているのだろうか\"と思いながらも、俺は遠ざかる彼女の痕跡を追いかけた。"

# game/chapter6.rpy:1489
translate japanese ecg12_label_bc35272b:

    # "더 이상 불이 들어오지 않는 가로등이 빼곡히 늘어선 좁다란 골목에서 몇 번이고 넘어질 뻔한 뒤에서야, 숨 가쁘게 멀어져가던 발자국 소리가 조금씩 멎어들어갔다. "
    "もう明かりの灯らない街灯がぎっしり並ぶ狭い路地で何度も転びそうになった末に、息苦しく遠ざかっていた足音が少しずつ止みかけていった。"

# game/chapter6.rpy:1490
translate japanese ecg12_label_72a7d218:

    # "골목길을 맴돌고 맴돌아 도착한 곳에서 드디어 발자국 소리가 멈추고, 나는 모퉁이를 돌기 전 숨을 고르며 소녀와 마주치고 난 뒤의 일을 고민했다. "
    "路地を巡りに巡ってたどり着いた場所で、ようやく足音が止まり、俺は角を曲がる前に息を整えながら少女と向き合った後のことを考えた。"

# game/chapter6.rpy:1491
translate japanese ecg12_label_3a76e95c:

    # "소녀와 마주한다면, 무슨 이야기를 먼저 꺼내야 할까? "
    "少女と向き合ったら、何を最初に切り出せばいいのだろう？"

# game/chapter6.rpy:1492
translate japanese ecg12_label_65834c50:

    # "생각을 정리해보려 했지만 이미 진이 빠질 대로 다 빠져버린 나의 몸은 더 이상의 사고를 거부하는 듯했다. "
    "考えをまとめようとしたが、すでに力を使い果たした俺の体は、これ以上の思考を拒んでいるようだった。"

# game/chapter6.rpy:1493
translate japanese ecg12_label_b9d376d5:

    # "마지막 남은 힘을 짜내어 소녀에게 건넬 첫 마디를 생각하던 순간, 모퉁이 너머에서 가벼운 숨소리가 들려왔다. "
    "最後に残った力を振り絞って少女に投げかける最初の一言を考えていたとき、角の向こうからかすかな息遣いが聞こえた。"

# game/chapter6.rpy:1494
translate japanese ecg12_label_9f7bf409:

    # "이대로 또다시 놓쳐버릴 수는 없었다. "
    "このままもう一度見失うわけにはいかなかった。"

# game/chapter6.rpy:1495
translate japanese ecg12_label_96370057:

    # "생각을 미처 다 정리하지도 못한 채, 나는 그대로 모퉁이를 돌아 그녀와 마주했다. "
    "考えがまとまらないまま、俺はそのまま角を曲がって彼女と向き合った。"

# game/chapter6.rpy:1496
translate japanese ecg12_label_f25f7169:

    # "그저, 이 한 마디를 건네기로 마음 먹은 채. "
    "ただ、この一言を伝えると決めて。"

# game/chapter6.rpy:1499
translate japanese ecg12_label_3f0548a3:

    # 나 "“…… 어라.”"
    나 "「……あれ。」"

# game/chapter6.rpy:1501
translate japanese ecg12_label_e8ed9f64:

    # "하지만 모퉁이를 돌아 바라본 그곳에는. "
    "だが角を曲がった先に見えたのは。"

# game/chapter6.rpy:1503
translate japanese ecg12_label_a46021a6:

    # 나 "“네가 어떻게 여기…….”"
    나 "「お前がなんでここに……」"

# game/chapter6.rpy:1505
translate japanese ecg12_label_118f0f9f:

    # "가쁜 숨을 내쉬는 그녀가 나의 앞에 서 있었다. "
    "荒い息をつく彼女が、俺の前に立っていた。"

# game/chapter6.rpy:1510
translate japanese ecg12_label_c9fc7701:

    # voice "voices/yf101.ogg"
    # 유미 "“그러는 너는, 이 시간에 이런 곳엔 왜 온 거야?!”"
    voice "voices/yf101.ogg"
    유미 "「そういうあんたこそ、なんでこんな時間にこんな場所に来てるの？！」"

# game/chapter6.rpy:1512
translate japanese ecg12_label_36908d87:

    # voice ""
    # "생각하지도 못한 상황 전개에, 아무런 말도 꺼내지 못하고 멍하니 시간이 멈춘 듯 유미를 바라보았다. "
    voice ""
    "思いもよらない展開に、何も言い出せず呆然と、時間が止まったかのようにユミを見つめた。"

# game/chapter6.rpy:1515
translate japanese ecg12_label_9dff9e30:

    # 나 "“어, 음…… 그러니까…….”"
    나 "「あ、えっと……つまり……」"

# game/chapter6.rpy:1519
translate japanese ecg12_label_56a1ee5d:

    # "잠시 상황을 정리할 시간이 필요했다. "
    "しばし状況を整理する時間が必要だった。"

# game/chapter6.rpy:1520
translate japanese ecg12_label_73fee2de:

    # "어째서 유미가 이곳에 있는 건지. "
    "なぜユミがここにいるのか。"

# game/chapter6.rpy:1521
translate japanese ecg12_label_abc46d2f:

    # "지금의 상황을 뭐라고 설명해야 하는 건지. "
    "今の状況をどう説明すればいいのか。"

# game/chapter6.rpy:1522
translate japanese ecg12_label_7b2b435f:

    # "머릿속을 먹구름처럼 가득 메운 혼란스러움을 걷어내어 보려 애썼다. "
    "頭の中を暗雲のように埋め尽くした混乱を払いのけようと努めた。"

# game/chapter6.rpy:1523
translate japanese ecg12_label_0fccd3f0:

    # "어렵사리 입을 뗀 건, 그로부터 제법 긴 침묵이 지나고 난 뒤였다. "
    "ようやく口を開いたのは、かなり長い沈黙が過ぎた後だった。"

# game/chapter6.rpy:1527
translate japanese ecg12_label_60af9736:

    # 나 "“사람을 찾고 있었어.”"
    나 "「人を探してたんだ。」"

# game/chapter6.rpy:1528
translate japanese ecg12_label_4d0c5e19:

    # voice "voices/yf102.ogg"
    # 유미 "“이런 곳에서 사람을 찾고 있었다고……?”"
    voice "voices/yf102.ogg"
    유미 "「こんな場所で人を探してたって……？」"

# game/chapter6.rpy:1530
translate japanese ecg12_label_6a377dfb:

    # voice ""
    # 나 "“정확히는 사람이 아니겠지만.”"
    voice ""
    나 "「正確には人じゃないけど。」"

# game/chapter6.rpy:1532
translate japanese ecg12_label_64add5b8:

    # voice "voices/yf103.ogg"
    # 유미 "“그때 이야기했던 유령을 찾고 있었던 거구나.”"
    voice "voices/yf103.ogg"
    유미 "「あのとき話してた幽霊を探してたんだ。」"

# game/chapter6.rpy:1534
translate japanese ecg12_label_bf92388e:

    # voice ""
    # 나 "“맞아.”"
    voice ""
    나 "「うん。」"

# game/chapter6.rpy:1539
translate japanese ecg12_label_cc9c4202:

    # "이런저런 부연설명이 더 필요할 줄 알았는데. "
    "もっと説明が必要かと思ったが。"

# game/chapter6.rpy:1540
translate japanese ecg12_label_569cd9dd:

    # "유미는 더 이상의 설명은 필요 없다는 듯, 고개를 끄덕였다. "
    "ユミはこれ以上の説明は不要とでもいうように、頷いた。"

# game/chapter6.rpy:1541
translate japanese ecg12_label_b7505b79:

    # "또 한 번의 침묵이 잠깐 나와 유미 사이를 감돌았다. "
    "またひとつの沈黙が、しばし俺とユミの間を漂った。"

# game/chapter6.rpy:1542
translate japanese ecg12_label_2ec24ab9:

    # "이번에도 먼저 침묵을 깬 건 내 쪽이었다. "
    "今回も先に沈黙を破ったのは俺のほうだった。"

# game/chapter6.rpy:1546
translate japanese ecg12_label_e950e11b:

    # 나 "“여긴 어떻게 알고 따라왔어?”"
    나 "「ここにはどうやって来たんだ？」"

# game/chapter6.rpy:1548
translate japanese ecg12_label_8221c352:

    # voice "voices/yf104.ogg"
    # 유미 "“음…… 어쩌다 보니……?”"
    voice "voices/yf104.ogg"
    유미 "「うーん……なりゆきで……？」"

# game/chapter6.rpy:1550
translate japanese ecg12_label_30b9caeb:

    # voice ""
    # 나 "“뭐야, 그게…….”"
    voice ""
    나 "「なんだよ、それ……」"

# game/chapter6.rpy:1553
translate japanese ecg12_label_46f11ff9:

    # voice "voices/yf105.ogg"
    # 유미 "“에, 헤헤헤…….”"
    voice "voices/yf105.ogg"
    유미 "「え、へへへ……」"

# game/chapter6.rpy:1555
translate japanese ecg12_label_08dc4d3f:

    # voice ""
    # 나 "“술은 깬 거고?”"
    voice ""
    나 "「酔いは覚めたのか？」"

# game/chapter6.rpy:1558
translate japanese ecg12_label_0dd4767e:

    # voice "voices/yf106.ogg"
    # 유미 "“취, 취한 적 없다니까?!”"
    voice "voices/yf106.ogg"
    유미 "「よ、酔ってないってば？！」"

# game/chapter6.rpy:1560
translate japanese ecg12_label_e896afdc:

    # voice ""
    # 나 "“네에, 네.”"
    voice ""
    나 "「はいはい。」"

# game/chapter6.rpy:1563
translate japanese ecg12_label_c59e58ac:

    # voice "voices/yf107.ogg"
    # 유미 "“걱정했다고. 갑자기 이상한 곳으로 가길래…….”"
    voice "voices/yf107.ogg"
    유미 "「心配したんだから。急に変な場所に行くから……」"

# game/chapter6.rpy:1568
translate japanese ecg12_label_8ef1cd0a:

    # voice ""
    # "유미는 여전히 나의 눈을 마주치지 않으며 이야기를 이어갔다. "
    voice ""
    "ユミは相変わらず俺と目を合わせないまま話を続けた。"

# game/chapter6.rpy:1571
translate japanese ecg12_label_3ba6c698:

    # voice "voices/yf108.ogg"
    # 유미 "“미안, 방해해버려서.”"
    voice "voices/yf108.ogg"
    유미 "「ごめん、邪魔しちゃって。」"

# game/chapter6.rpy:1573
translate japanese ecg12_label_f5e4d5ab:

    # voice ""
    # 나 "“으응……? 방해라니?”"
    voice ""
    나 "「ん……？ 邪魔って？」"

# game/chapter6.rpy:1575
translate japanese ecg12_label_a584ad36:

    # voice "voices/yf109.ogg"
    # 유미 "“찾고 있었댔잖아. 그 유령 말이야.”"
    voice "voices/yf109.ogg"
    유미 "「探してたんでしょ。あの幽霊のこと。」"

# game/chapter6.rpy:1577
translate japanese ecg12_label_d8761515:

    # voice ""
    # 나 "“아냐. 어차피 찾을 수 있을 거라고 생각도 안 했고.”"
    voice ""
    나 "「いや。どうせ見つかるとも思ってなかったし。」"

# game/chapter6.rpy:1580
translate japanese ecg12_label_328e220c:

    # "어느새 머릿속을 가득 물들였던 먹색 혼란스러움이 완전히 걷힌 건지. "
    "いつの間にか頭の中を染めていた墨色の混乱が完全に晴れたのか。"

# game/chapter6.rpy:1581
translate japanese ecg12_label_543b5691:

    # "나는 차분한 목소리로 유미에게 말을 건네고 있었다. "
    "俺は落ち着いた声でユミに話しかけていた。"

# game/chapter6.rpy:1583
translate japanese ecg12_label_3e29bd21:

    # 나 "“…… 나를 반겨줄 거라고도 생각 안 했어.”"
    나 "「……歓迎してくれるとも思ってなかったし。」"

# game/chapter6.rpy:1584
translate japanese ecg12_label_4bd62253:

    # voice "voices/yf110.ogg"
    # 유미 "“무슨 일이었어?”"
    voice "voices/yf110.ogg"
    유미 "「何があったの？」"

# game/chapter6.rpy:1586
translate japanese ecg12_label_821f3fb1:

    # voice ""
    # 나 "“이야기하자면 긴데.”"
    voice ""
    나 "「話せば長いんだけど。」"

# game/chapter6.rpy:1588
translate japanese ecg12_label_13cf6ae3:

    # voice "voices/yf111.ogg"
    # 유미 "“듣고 싶어. 시간은 많잖아?”"
    voice "voices/yf111.ogg"
    유미 "「聞きたい。時間はあるでしょ？」"

# game/chapter6.rpy:1590
translate japanese ecg12_label_9abd1d5f:

    # voice ""
    # 나 "“그렇네.”"
    voice ""
    나 "「そうだな。」"

# game/chapter6.rpy:1593
translate japanese ecg12_label_3c6e7279:

    # "나는 천천히 걸음을 떼며, 여태껏 유령 소녀와 있었던 이야기를 꺼냈다. "
    "俺はゆっくりと歩き出しながら、これまで幽霊の少女とあったことを話し始めた。"

# game/chapter6.rpy:1594
translate japanese ecg12_label_10e8aae1:

    # "오늘처럼 나와 유미가 어색한 곳에서 마주쳤던 그날의 이야기부터, 소녀가 자신을 살인자라 칭하며 나와 헤어지게 됐던 마지막 날의 이야기까지. "
    "今日のように俺とユミが気まずい場所で出くわしたあの日の話から、少女が自分を人殺しと呼んで俺と別れることになった最後の日の話まで。"

# game/chapter6.rpy:1595
translate japanese ecg12_label_df8bf62b:

    # "그리고 소녀가 사라지고 난 뒤로도 이유를 알 수 없는 목소리가 내 주변을 떠돌던 것까지도. "
    "そして少女が消えた後も、理由の分からない声が俺の周りを漂っていたことまで。"

# game/chapter6.rpy:1596
translate japanese ecg12_label_d1881786:

    # "어디로 향하는지 모를 걸음과 함께, 나는 유미에게 모든 이야기를 정신없이 건네었다. "
    "どこに向かうとも知れない足取りとともに、俺はユミにすべてを夢中で語った。"

# game/chapter6.rpy:1598
translate japanese ecg12_label_9ac10b6d:

    # voice "voices/yf112.ogg"
    # 유미 "“그래서 그랬던 거구나. 비품 창고에서 멍하니 있었던 것도, 내가 뭐라 이야기를 꺼내려는데 멍하니 있던 것도.”"
    voice "voices/yf112.ogg"
    유미 "「あぁ、通りで...備品倉庫でぼーっとしてたのも、私が話そうとしたときにぼーっとしてたのも。」"

# game/chapter6.rpy:1600
translate japanese ecg12_label_5be52426:

    # voice ""
    # 나 "“그렇지.”"
    voice ""
    나 "「そうだな。」"

# game/chapter6.rpy:1603
translate japanese ecg12_label_4f3129a7:

    # "기나긴 이야기가 끝나고 발걸음을 멈춰 세웠을 땐, 어느새 익숙한 장소에 서 있는 나를 발견할 수 있었다. "
    "長い話が終わって足を止めたときには、いつの間にか見覚えのある場所に立っている自分に気がついた。"

# game/chapter6.rpy:1607
translate japanese ecg12_label_314d2407:

    # 나 "“여기, 별 예쁘지 않아?”"
    나 "「ここ、星きれいだろ？」"

# game/chapter6.rpy:1608
translate japanese ecg12_label_5b88e050:

    # voice "voices/yf113.ogg"
    # 유미 "“별……? 와아, 정말이네. 여태껏 모르고 있었어.”"
    voice "voices/yf113.ogg"
    유미 "「星……？ わあ、本当だ。ずっと知らなかった。」"

# game/chapter6.rpy:1610
translate japanese ecg12_label_93db5fb1:

    # voice ""
    # "갑자기 웬 별 이야기냐며 고개를 든 유미도 금세 난생 처음 봤을 무수한 별무리에 매료되어 뚫어져라 밤하늘을 응시했다. "
    voice ""
    "突然何の話かと顔を上げたユミも、おそらく生まれて初めて見たであろう無数の星群に魅了されて、じっと夜空を見つめた。"

# game/chapter6.rpy:1613
translate japanese ecg12_label_0433bee5:

    # 나 "“저 틈에 네가 아까 말했던 그 별도 숨어 있겠지?”"
    나 "「あの星たちの中に、さっきお前が言ってた星も隠れてるんだろ？」"

# game/chapter6.rpy:1615
translate japanese ecg12_label_9611c749:

    # voice "voices/yf114.ogg"
    # 유미 "“저기, 저 별이 아까 내가 말했던 별이야.”"
    voice "voices/yf114.ogg"
    유미 "「ほら、あの星がさっき私が言ってた星だよ。」"

# game/chapter6.rpy:1618
translate japanese ecg12_label_5addef63:

    # voice ""
    # "그 별을 찾아내는 것보다 아침이 밝는 게 더 빠를 줄로만 생각했는데, 유미는 나의 말을 기다렸다는 듯 하늘의 한구석을 가리키며 말했다. "
    voice ""
    "その星を見つけるより朝が来るほうが早いとばかり思っていたのに、ユミは俺の言葉を待っていたかのように空の一角を指さして言った。"

# game/chapter6.rpy:1620
translate japanese ecg12_label_421d78a9:

    # "별을 헤아리던 나는 고개를 돌려 의아한 눈치를 유미에게 보냈다. "
    "星を数えていた俺は振り返って、怪訝そうな視線をユミに送った。"

# game/chapter6.rpy:1622
translate japanese ecg12_label_0ac124ab:

    # voice "voices/yf115.ogg"
    # 유미 "“왜 그래?”"
    voice "voices/yf115.ogg"
    유미 "「どうしたの？」"

# game/chapter6.rpy:1624
translate japanese ecg12_label_fdde6d83:

    # voice ""
    # 나 "“아, 그게…… 저렇게 많은 별들 사이에서 그 별을 어떻게 다시 찾았나 해서.”"
    voice ""
    나 "「あ、いや……あれだけ多い星の中からどうやってまたあの星を見つけたのかと思って。」"

# game/chapter6.rpy:1627
translate japanese ecg12_label_63a90f70:

    # voice "voices/yf116.ogg"
    # 유미 "“저 별은 북극성이니까. 하늘에서 가장 높이 떠 있는 별을 찾으면 돼. 정확히는 북극에 가장 가까운 별이겠지만.”"
    voice "voices/yf116.ogg"
    유미 "「あの星は北極星だから。空で一番高い所にある星を探せばいいの。正確には北極に一番近い星だけどね。」"

# game/chapter6.rpy:1629
translate japanese ecg12_label_27a81de8:

    # voice ""
    # "북극성이라면 들어본 적 있다. "
    voice ""
    "北極星なら聞いたことがある。"

# game/chapter6.rpy:1631
translate japanese ecg12_label_c1700853:

    # "항해사들이 밤에 길을 찾기 위해 이용했던 별이라고 했던가. "
    "航海士たちが夜に道を探すために使っていた星だったか。"

# game/chapter6.rpy:1633
translate japanese ecg12_label_75f48953:

    # 나 "“북극성이라면, 폴라리스를 이야기하는 거겠네.”"
    나 "「北極星なら、ポラリスのことだよな。」"

# game/chapter6.rpy:1637
translate japanese ecg12_label_71798e1b:

    # voice "voices/yf117.ogg"
    # 유미 "“폴라리스? 아냐, 저건 알라이라는 별이라고.”"
    voice "voices/yf117.ogg"
    유미 "「ポラリス？ ううん、あれはアルライっていう星だよ。」"

# game/chapter6.rpy:1639
translate japanese ecg12_label_e0c57277:

    # voice ""
    # 나 "“알라이?”"
    voice ""
    나 "「アルライ？」"

# game/chapter6.rpy:1642
translate japanese ecg12_label_df136b4c:

    # "동시에 나와 유미가 서로를 의아하다는 듯 바라보았다. "
    "同時に俺とユミが怪訝そうに顔を見合わせた。"

# game/chapter6.rpy:1643
translate japanese ecg12_label_e55df454:

    # "그러자 유미가 알았다는 듯, 가볍게 손뼉을 마주치며 해답을 제시했다. "
    "するとユミは合点がいったように、軽く手を叩いて答えを示した。"

# game/chapter6.rpy:1645
translate japanese ecg12_label_3793821e:

    # voice "voices/yf118.ogg"
    # 유미 "“그러고 보니 시간이 지나면 북극성이 바뀌기도 한다는데. 신기하다. 우린 서로 다른 별이 북극성이었을 때의 사람인 거네?”"
    voice "voices/yf118.ogg"
    유미 "「そういえば、時間が経つと北極星が変わることもあるんだって。不思議だよね。多分私たちはそれぞれ違う星が北極星だった時代の人だったんだね？」"

# game/chapter6.rpy:1647
translate japanese ecg12_label_861cab57:

    # voice ""
    # 나 "“북극성이 바뀐다니, 그런 건 처음 들어 봐.”"
    voice ""
    나 "「北極星が変わるなんて、初めて聞いたな。」"

# game/chapter6.rpy:1651
translate japanese ecg12_label_1dc01387:

    # voice "voices/yf119.ogg"
    # 유미 "“가장 가까이 있는 게 늘 같을 수는 없잖아.”"
    voice "voices/yf119.ogg"
    유미 "「一番近くにあるものがいつも同じとは限らないでしょ。」"

# game/chapter6.rpy:1653
translate japanese ecg12_label_29218aba:

    # voice ""
    # 나 "“듣고 보니 그런 것 같기도 하고.”"
    voice ""
    나 "「言われてみればそうかもな。」"

# game/chapter6.rpy:1656
translate japanese ecg12_label_8dade3d1:

    # "넌센스같은 해석이었지만, 그런 유미의 대답은 더 없이 명료하게 와닿았다. "
    "突拍子もない解釈だったが、ユミのその答えはこの上なく明瞭に響いた。"

# game/chapter6.rpy:1661
translate japanese ecg12_label_742356be:

    # voice "voices/yf120.ogg"
    # 유미 "“역시 혼자 빛나고 있구나.”"
    voice "voices/yf120.ogg"
    유미 "「やっぱり一人で光ってるんだ。」"

# game/chapter6.rpy:1663
translate japanese ecg12_label_6c91ae21:

    # voice ""
    # "다시 고개를 들어 북극성을 응시하고 있던 유미가 혼잣말처럼 중얼거렸다. "
    voice ""
    "再び顔を上げて北極星を見つめていたユミが独り言のようにつぶやいた。"

# game/chapter6.rpy:1668
translate japanese ecg12_label_e337c45a:

    # 나 "“이제 술이 좀 깼나 보네.”"
    나 "「ようやく酔いが少し覚めたみたいだな。」"

# game/chapter6.rpy:1669
translate japanese ecg12_label_33765cfd:

    # voice "voices/yf121.ogg"
    # 유미 "“그치만 저 별, 정말로 짝이 있는걸. 쌍성이니까. 물론 여기서 보이진 않지만.”"
    voice "voices/yf121.ogg"
    유미 "「でもあの星、対になる星があるんだよ。連星だから。もちろんここからは見えないけど。」"

# game/chapter6.rpy:1671
translate japanese ecg12_label_c6f086ff:

    # voice ""
    # 나 "“음…… 그런데 쌍성이라는 게 정확히 뭐야?”"
    voice ""
    나 "「ん……ところで連星って正確にはなんなんだ？」"

# game/chapter6.rpy:1674
translate japanese ecg12_label_00c91e1f:

    # voice "voices/yf122.ogg"
    # 유미 "“서로 같은 궤도를 도는 별이라고나 할까?”"
    voice "voices/yf122.ogg"
    유미 "「{cmt=japanese_6A}お互いに同じ軌道を回る星{/cmt}、とでも言うのかな？」"

# game/chapter6.rpy:1677
translate japanese ecg12_label_fd8ce038:

    # voice ""
    # 나 "“신기하네. 별은 항상 그 자리에서 홀로 반짝이는 줄 알았는데.”"
    voice ""
    나 "「不思議だな。星はいつもその場所で一人きりで輝いてるものだと思ってたけど。」"

# game/chapter6.rpy:1679
translate japanese ecg12_label_cafa64ac:

    # voice "voices/yf123.ogg"
    # 유미 "“꼭 유령 같지 않아? 눈에 안 보이면서 언제나 붙어 있다니.”"
    voice "voices/yf123.ogg"
    유미 "「まるで幽霊みたいじゃない？ 目に見えないのにいつもそばにいるなんて。」"

# game/chapter6.rpy:1681
translate japanese ecg12_label_b93ec16d:

    # voice ""
    # 나 "“유령…….”"
    voice ""
    나 "「幽霊……」"

# game/chapter6.rpy:1686
translate japanese ecg12_label_8e23b12c:

    # "그 단어가 꼭 암구호라도 되는 것처럼, 나는 멍하니 유미가 가리켰던 알라이라는 별을 바라보았다. "
    "その言葉がまるで合言葉であるかのように、俺はぼんやりとユミが指していたアルライという星を見つめた。"

# game/chapter6.rpy:1687
translate japanese ecg12_label_ebe76123:

    # "어슴푸레 빛을 발하는 저 별의 뒤편에, 보이지 않는 쌍성이 궤도를 맴돌고 있다. "
    "おぼろげに光を放つあの星の背後に、見えない連星が軌道を巡っている。"

# game/chapter6.rpy:1688
translate japanese ecg12_label_ac561b6e:

    # "마치 유령처럼……. "
    "まるで幽霊のように……"

# game/chapter6.rpy:1689
translate japanese ecg12_label_9cfa4577:

    # "무언가에 홀린 듯 주변을 살폈지만, 텅 빈 공터에는 마른 바람만이 휑하니 불고 있을 뿐이었다. "
    "何かに惹かれるように辺りを見回したが、がらんとした空き地には乾いた風だけがすうすうと吹いているだけだった。"

# game/chapter6.rpy:1691
translate japanese ecg12_label_a211ad8f:

    # "정말 한여름밤의 꿈이었던 것처럼 소녀가 사라지고, 이제까지의 일은 아무것도 아닌 것으로 남게 되는 걸까? "
    "本当に真夏の夜の夢だったかのように少女が消えて、これまでのことは何でもなかったことになるのだろうか？"

# game/chapter6.rpy:1696
translate japanese ecg12_label_8a1f767f:

    # voice "voices/yf124.ogg"
    # 유미 "“그래서, 그 유령 여자애는 더 안 찾을 거야?”"
    voice "voices/yf124.ogg"
    유미 "「それで、あの幽霊の女の子はもう探さないの？」"

# game/chapter6.rpy:1698
translate japanese ecg12_label_0ccb2964:

    # voice ""
    # 나 "“…… 아마.”"
    voice ""
    나 "「……たぶん。」"

# game/chapter6.rpy:1700
translate japanese ecg12_label_246e8934:

    # voice "voices/yf125.ogg"
    # 유미 "“후회할지도 몰라?”"
    voice "voices/yf125.ogg"
    유미 "「後悔するかもよ？」"

# game/chapter6.rpy:1702
translate japanese ecg12_label_880bfe09:

    # voice ""
    # 나 "“직접 만났다간 더 후회할지도 모르지.”"
    voice ""
    나 "「直接会ったらもっと後悔するかもしれないし。」"

# game/chapter6.rpy:1704
translate japanese ecg12_label_ac4ab0d4:

    # voice "voices/yf126.ogg"
    # 유미 "“정말?”"
    voice "voices/yf126.ogg"
    유미 "「本当に？」"

# game/chapter6.rpy:1706
translate japanese ecg12_label_1fbf0303_2:

    # voice ""
    # 나 "“…….”"
    voice ""
    나 "「……」"

# game/chapter6.rpy:1709
translate japanese ecg12_label_e0f05f7d:

    # "유미의 되물음에 명확한 대답을 꺼내지 못한 채, 나는 말을 돌렸다. "
    "ユミの問い返しに明確な答えを出せないまま、俺は話を逸らした。"

# game/chapter6.rpy:1714
translate japanese ecg12_label_481bce99:

    # 나 "“갑자기 그런 이야기는 왜 꺼내는 거야.”"
    나 "「急にそんな話、なんで持ち出すんだよ。」"

# game/chapter6.rpy:1715
translate japanese ecg12_label_0239667a:

    # voice "voices/yf127.ogg"
    # 유미 "“그러게. 나도 잘 모르겠지만, 너도 이유 모를 행동을 할 때 있지 않아?”"
    voice "voices/yf127.ogg"
    유미 "「そうだよね。私にもよく分からないけど、あんただって急に理由なんかない行動をすることあるでしょ？」"

# game/chapter6.rpy:1717
translate japanese ecg12_label_08da5360:

    # voice ""
    # "그런 일이라면 수도 없이 있었다. "
    voice ""
    "そんなこと数えきれないほどあった。"

# game/chapter6.rpy:1719
translate japanese ecg12_label_550ed825:

    # "방금 전까지만 해도 그랬으니까. "
    "ついさっきまでもそうだったのだから。"

# game/chapter6.rpy:1721
translate japanese ecg12_label_00ed3467:

    # 나 "“나도 후회할 거라고는 생각해. 그리고, 이상하다고도 생각해.”"
    나 "「俺も後悔するとは思うよ。それに、おかしいとも思ってる。」"

# game/chapter6.rpy:1722
translate japanese ecg12_label_9108d6d7:

    # 나 "“처음엔 그저 우연일 거라고만 생각했던 모든 일들이 이제 와서 돌이켜 생각해보면 우연을 가장했던 필연이었던 것 같아서.”"
    나 "「最初はただの偶然だと思っていたすべてのことが、今になって振り返ると偶然を装った必然だったような気がして。」"

# game/chapter6.rpy:1723
translate japanese ecg12_label_8e4aa697:

    # 나 "“하지만 여전히 아무것도 모르겠어.”"
    나 "「だけど相変わらず何も分からない。」"

# game/chapter6.rpy:1724
translate japanese ecg12_label_11d0285c:

    # 나 "“누가, 왜 나를 이런 잘 짜여진 각본 속으로 안내했는지, 이 각본의 결말이 무엇일지…….”"
    나 "「誰が、なぜ俺をこんなよくできた脚本の中に導いたのか、この脚本の結末が何なのか……」"

# game/chapter6.rpy:1725
translate japanese ecg12_label_85708de7:

    # voice "voices/yf128.ogg"
    # 유미 "“아직 시간은 있잖아.”"
    voice "voices/yf128.ogg"
    유미 "「まだ時間はあるでしょ。」"

# game/chapter6.rpy:1727
translate japanese ecg12_label_0d7e8824:

    # voice ""
    # 나 "“네가 나였다면 어땠을 것 같아? 아니, 만약 네가 그 유령 여자애였다면…….”"
    voice ""
    나 "「もしお前が俺だったらどうしてたと思う？ いや、もしお前があの幽霊の子だったら……」"

# game/chapter6.rpy:1729
translate japanese ecg12_label_b8150631:

    # voice "voices/yf129.ogg"
    # 유미 "“그건 대답해줄 수 없는걸. 나는 네가 아니고, 그 유령도 아니니까.”"
    voice "voices/yf129.ogg"
    유미 "「それには答えられないよ。私はあんたじゃないし、あの幽霊でもないから。」"

# game/chapter6.rpy:1732
translate japanese ecg12_label_9c943496:

    # voice ""
    # "미궁 속에 빠져 버린 무기력감이 나를 덮쳤다. "
    voice ""
    "迷宮に迷い込んだような無力感が俺を覆った。"

# game/chapter6.rpy:1734
translate japanese ecg12_label_f42f788f:

    # "도대체 누가 이렇게 찝찝한 함정을 애써 만들어서는, 왜 나를 그곳에 밀어넣은 걸까. "
    "一体誰がこんな後味の悪い罠をわざわざ作って、なぜ俺をそこに突き落としたのだろう。"

# game/chapter6.rpy:1735
translate japanese ecg12_label_85299886:

    # "길을 찾아갈만한 실타래를 아무리 찾아보려 해도, 허공에서 잡히는 거라고는 무력함이 전부였다. "
    "出口への糸口をいくら探しても、虚空で掴めるのは無力さだけだった。"

# game/chapter6.rpy:1744
translate japanese ecg13_label_dcd44a6f:

    # 나 "“그렇다고는 해도, 이렇게 이도저도 아닌 채로 끝나는 건 싫다고 말하고 싶지만……. 뭘 어떻게 해야 하는 건지 모르겠어.”"
    나 "「そうは言っても、こんな宙ぶらりんのまま終わるのは嫌だと言いたいけど……どうすればいいのか分からない。」"

# game/chapter6.rpy:1745
translate japanese ecg13_label_4ae8c486:

    # 나 "“모르겠다고. 아무것―――”"
    나 "「分からないんだよ。何も―――」"

# game/chapter6.rpy:1747
translate japanese ecg13_label_524c76d1:

    # "그렇다고 생각했다. "
    "そう思っていた。"

# game/chapter6.rpy:1748
translate japanese ecg13_label_bf636a94:

    # "고개를 돌려, 그곳을 바라보기 전까지는. "
    "顔を向けて、あの場所を見るまでは。"

# game/chapter6.rpy:1754
translate japanese ecg13_label_054940f7:

    # 나 "“도…….”"
    나 "「――も……」"

# game/chapter6.rpy:1758
translate japanese ecg13_label_c6be521b:

    # "알지 못하는 사이, 나는 이미 미궁의 한가운데에 이미 들어서 있었던 걸까. "
    "知らぬ間に、俺はすでに迷宮のど真ん中に足を踏み入れていたのだろうか。"

# game/chapter6.rpy:1759
translate japanese ecg13_label_7a4f6e06:

    # "모든 것이 뒤틀려 인과율이라고는 전혀 상관치 않는 세상을 마주하는 것 같았다. "
    "すべてが歪んで、因果律など一切関係のない世界と向き合っているようだった。"

# game/chapter6.rpy:1761
translate japanese ecg13_label_8524e354:

    # "우연을 가장한 필연. "
    "偶然を装った必然。"

# game/chapter6.rpy:1762
translate japanese ecg13_label_8514c726:

    # "지극히 편의주의적인 전개. "
    "極めてご都合主義的な展開。"

# game/chapter6.rpy:1763
translate japanese ecg13_label_84d246bb:

    # "그렇다고밖에는 생각할 수 없었다. "
    "そうとしか思えなかった。"

# game/chapter6.rpy:1767
translate japanese ecg13_label_701f608c:

    # "그곳에, 소녀가 있었다. "
    "そこに、少女がいた。"

# game/chapter6.rpy:1773
translate japanese ecg13_label_f68315d5:

    # "나를 빤히 바라보고 있던 소녀가, 눈을 마주치고서는 스르륵 발걸음을 돌렸다. "
    "俺をじっと見つめていた少女が、目が合うとするりと踵を返した。"

# game/chapter6.rpy:1774
translate japanese ecg13_label_c5a8ed0b:

    # "눈을 의심하며 멍하니 서 있던 나는, 눈앞에서 사라지려는 소녀에게 다급히 말을 건넸다. "
    "目を疑いながら呆然と立っていた俺は、目の前から消えようとする少女に慌てて声をかけた。"

# game/chapter6.rpy:1776
translate japanese ecg13_label_75730c2b:

    # 나 "“잠깐, 기다려줘!”"
    나 "「待って、待ってくれ！」"

# game/chapter6.rpy:1778
translate japanese ecg13_label_91baa63c:

    # "멀어져가는 소녀를 멈춰야만 했다. "
    "遠ざかっていく少女を止めなければならなかった。"

# game/chapter6.rpy:1779
translate japanese ecg13_label_89cdd2fd:

    # "생각해야만 했다. "
    "考えなければならなかった。"

# game/chapter6.rpy:1780
translate japanese ecg13_label_fe9d75c0:

    # "소녀를 멈춰 세울 한 마디를. "
    "少女を引き止める一言を。"

# game/chapter6.rpy:1782
translate japanese ecg13_label_cdbdabf1:

    # 나 "“기다리고 있겠다고 했잖아?!”"
    나 "「待ってるって言ったじゃないか？！」"

# game/chapter6.rpy:1784
translate japanese ecg13_label_b174e4d2:

    # "소녀를 뒤쫓으며, 반사적으로 생각나는 단어들을 기워 붙여 건넸다. "
    "少女を追いかけながら、反射的に浮かんだ言葉をつなぎ合わせて伝えた。"

# game/chapter6.rpy:1786
translate japanese ecg13_label_e6f9362d:

    # 나 "“네가, 네가 그랬어. 기다리고 있겠다고.”"
    나 "「お前が、お前がそう言ったんだ。待ってるって。」"

# game/chapter6.rpy:1788
translate japanese ecg13_label_1f585338:

    # "나의 목소리가 소녀에게 겨우겨우 전해진 것인지, 앞서가던 발걸음 소리가 조금씩 멎어갔다. "
    "俺の声がかろうじて少女に届いたのか、先を行く足音が少しずつ止まっていった。"

# game/chapter6.rpy:1790
translate japanese ecg13_label_b7d42f7d:

    # 나 "“…… 그래서 너를 찾아 온 거라고.”"
    나 "「……だから会いに来たんだよ。」"

# game/chapter6.rpy:1792
translate japanese ecg13_label_ba762d11:

    # "그 자리에 멈춰 선 소녀가, 천천히 뒤를 돌아 나에게 얼굴을 보였다. "
    "その場に立ち止まった少女が、ゆっくりと振り返って俺に顔を見せた。"

# game/chapter6.rpy:1794
translate japanese ecg13_label_4ff94877:

    # "오랜만이었다. "
    "久しぶりだった。"

# game/chapter6.rpy:1795
translate japanese ecg13_label_5f78cc28:

    # "소녀와 다시 마주하게 된 것도, 소녀의 그 차가운 표정을 보는 것도. "
    "少女と再び向き合うのも、少女のあの冷たい表情を見るのも。"

# game/chapter6.rpy:1796
translate japanese ecg13_label_868aa38e:

    # "소리 죽인 발자국 소리가 나를 향한다. "
    "忍ばせた足音が俺に向かってくる。"

# game/chapter6.rpy:1797
translate japanese ecg13_label_a1c4e21a:

    # "둘 사이의 거리가 좁혀지고, 나는 소녀의 모습을 더욱 또렷이 볼 수 있게 된다. "
    "二人の距離が縮まり、俺は少女の姿をより鮮明に見ることができるようになる。"

# game/chapter6.rpy:1798
translate japanese ecg13_label_9c1503dc:

    # "소녀의 호흡이 미세하게 들려오기 시작할 무렵, 나의 앞에 멈춰 선 소녀가 떨리는 목소리로 먼저 말을 꺼냈다. "
    "少女の息遣いがかすかに聞こえ始めた頃、俺の前に立ち止まった少女が震える声で先に口を開いた。"

# game/chapter6.rpy:1800
translate japanese ecg13_label_cce3e6a3:

    # voice "voices/gf4.ogg"
    # 소녀 "“그게 무슨 소리예요. 제가 기다리고 있겠다고 했다니.”"
    voice "voices/gf4.ogg"
    소녀 "「何を言ってるんですか。私が待ってるなんて言ったって。」"

# game/chapter6.rpy:1802
translate japanese ecg13_label_b7cc849e:

    # voice ""
    # 나 "“정말이야. 네가 내게서 사라진 뒤로, 어떤 목소리가 나를 계속 불렀었어. 여태껏 그 목소리가 과거의 기억인 줄로만 알았는데. 그 목소리는, 네 목소리였어.”"
    voice ""
    나 "「本当だよ。お前が俺の前から消えた後、ある声がずっと俺を呼んでいたんだ。今までその声が過去の記憶だとばかり思っていたけど。あの声は、お前の声だったんだ。」"

# game/chapter6.rpy:1804
translate japanese ecg13_label_91e4ba75:

    # voice "voices/gf5.ogg"
    # 소녀 "“말도 안 돼요.”"
    voice "voices/gf5.ogg"
    소녀 "「そんなはずないです。」"

# game/chapter6.rpy:1806
translate japanese ecg13_label_cd962ca9:

    # voice ""
    # 나 "“아냐, 정말이야. 네가 불렀어. 네가 불렀다고. 그래서 찾아온 거라고. 네가 기다리고 있겠다고 했으니까…….”"
    voice ""
    나 "「いや、本当だ。お前が呼んだんだ。お前が呼んだんだよ。だから会いに来たんだ。お前が待ってるって言ったから……」"

# game/chapter6.rpy:1808
translate japanese ecg13_label_55377590:

    # voice "voices/gf6.ogg"
    # 소녀 "“믿지 못하는 건 아니에요. 그렇지만…….”"
    voice "voices/gf6.ogg"
    소녀 "「信じていないわけじゃないんです。でも……」"

# game/chapter6.rpy:1810
translate japanese ecg13_label_55ce992c:

    # voice ""
    # "떨리는 호흡이 잠시 소녀의 말을 끊어낸다. "
    voice ""
    "震える息が少女の言葉を一瞬途切れさせる。"

# game/chapter6.rpy:1812
translate japanese ecg13_label_a7997ea4:

    # "정적을 삼키던 소녀는 힘겹게 이야기를 이어갔다. "
    "沈黙を飲み込んでいた少女は、苦しそうに話を続けた。"

# game/chapter6.rpy:1814
translate japanese ecg13_label_6f70330b:

    # voice "voices/gf7.ogg"
    # 소녀 "“…… 그럴 리가 없잖아요.”"
    voice "voices/gf7.ogg"
    소녀 "「……そんなはずがないじゃないですか。」"

# game/chapter6.rpy:1816
translate japanese ecg13_label_75b7b1d2:

    # voice ""
    # "나의 바람을 간단히 부정하는 한 마디였다. "
    voice ""
    "俺の願いをあっさりと否定する一言だった。"

# game/chapter6.rpy:1819
translate japanese ecg13_label_cf13ac18:

    # voice "voices/gf8.ogg"
    # 소녀 "“그런 염치 없는 이야기, 했을 리가 없잖아요.”"
    voice "voices/gf8.ogg"
    소녀 "「そんなおこがましいこと、言ったはずがないじゃないですか。」"

# game/chapter6.rpy:1821
translate japanese ecg13_label_07a1da57:

    # voice ""
    # 나 "“하지만 텔레파시처럼 들렸는걸. 네 목소리가…….”"
    voice ""
    나 "「でもテレパシーみたいに聞こえたんだ。お前の声が……」"

# game/chapter6.rpy:1824
translate japanese ecg13_label_6f2e62ee:

    # voice "voices/gf9.ogg"
    # 소녀 "“저한테 그럴 자격 같은 건 없어요.”"
    voice "voices/gf9.ogg"
    소녀 "「私にそんな資格なんてないんです。」"

# game/chapter6.rpy:1826
translate japanese ecg13_label_bb1e3814:

    # voice ""
    # 나 "“자격 같은 게 왜 필요해? 그리고, 그때 이야기했잖아? 헤어질 때 이름 정도는 알려 주겠다면서?!”"
    voice ""
    나 "「資格なんてなんで必要なんだよ？ それに、あのとき言ったじゃないか？ 別れるとき名前くらいは教えるって？！」"

# game/chapter6.rpy:1828
translate japanese ecg13_label_23347852:

    # voice "voices/gf10.ogg"
    # 소녀 "“몰라도 돼요. 살인자의 이름 같은 건.”"
    voice "voices/gf10.ogg"
    소녀 "「知らなくていいんです。人殺しの名前なんて。」"

# game/chapter6.rpy:1830
translate japanese ecg13_label_2952e466:

    # voice ""
    # "소녀의 쌀쌀맞은 목소리가 주변을 얼렸다. "
    voice ""
    "少女のそっけない声が辺りを凍りつかせた。"

# game/chapter6.rpy:1832
translate japanese ecg13_label_3c438b9a:

    # "여름에서 겨울로, 지금의 계절이 뒤바뀐 건 아닐까 하는 생각이 들 정도로 나와 소녀 사이에는 냉혹하기 그지 없는 기류가 흘렀다. "
    "夏から冬へ、今この季節が入れ替わったのではないかと思うほど、俺と少女の間には冷酷極まりない雰囲気が流れていた。"

# game/chapter6.rpy:1834
translate japanese ecg13_label_0ebb5c75:

    # 나 "“아니잖아? 살인자라니…….”"
    나 "「違うだろ？ 人殺しだなんて……」"

# game/chapter6.rpy:1836
translate japanese ecg13_label_0baf6a5a:

    # "정적을 깨기엔 모자랐던 걸까. "
    "静寂を破るには足りなかったのだろうか。"

# game/chapter6.rpy:1837
translate japanese ecg13_label_cf2617c2:

    # "나의 목소리가 소녀에게 닿지 못한 채 튕겨져 나온다. "
    "俺の声が少女に届かないまま弾き返される。"

# game/chapter6.rpy:1838
translate japanese ecg13_label_3feedc7d:

    # "다시 한번, 나는 조심스레 소녀를 향해 말을 건넸다. "
    "もう一度、俺は慎重に少女に向かって声をかけた。"

# game/chapter6.rpy:1840
translate japanese ecg13_label_8583cac6:

    # 나 "“같이 돌아가자. 다시 찾아보는 거야. 분명 뭔가가, 잘못된 무언가가…….”"
    나 "「一緒に戻ろう。もう一度探してみるんだ。きっと何かが、何かが間違って……」"

# game/chapter6.rpy:1842
translate japanese ecg13_label_5079c42e:

    # voice "voices/gf11.ogg"
    # 소녀 "“아뇨. 제가 있을 곳은 아무 데도 없어요.”"
    voice "voices/gf11.ogg"
    소녀 "「いいえ。私が居てもいい場所なんてどこにもないんです。」"

# game/chapter6.rpy:1844
translate japanese ecg13_label_e833ead2:

    # voice ""
    # 나 "“네 기억이 잘못됐을 수도 있잖아?”"
    voice ""
    나 "「お前の記憶が間違ってるかもしれないじゃないか？」"

# game/chapter6.rpy:1849
translate japanese ecg13_label_a00bfa92:

    # "소녀는 고개를 가로저었다. "
    "少女は首を横に振った。"

# game/chapter6.rpy:1851
translate japanese ecg13_label_6c946381:

    # voice "voices/gf12.ogg"
    # 소녀 "“그럴 리 없어요.”"
    voice "voices/gf12.ogg"
    소녀 "「そんなはずないです。」"

# game/chapter6.rpy:1853
translate japanese ecg13_label_797a6e68:

    # voice ""
    # 나 "“어째서 그렇게 쉽게 부정하는 거야?”"
    voice ""
    나 "「なんでそんな簡単に否定するんだよ？」"

# game/chapter6.rpy:1855
translate japanese ecg13_label_b128afbf:

    # voice "voices/gf13.ogg"
    # 소녀 "“그때도 그랬으니까요.”"
    voice "voices/gf13.ogg"
    소녀 "「あのときもそうだったからです。」"

# game/chapter6.rpy:1857
translate japanese ecg13_label_05c7e615:

    # voice ""
    # 나 "“그때……?”"
    voice ""
    나 "「あのとき……？」"

# game/chapter6.rpy:1859
translate japanese ecg13_label_e67b1523:

    # voice "voices/gf14.ogg"
    # 소녀 "“네. '그때'요.”"
    voice "voices/gf14.ogg"
    소녀 "「はい。「あのとき」です。」"

# game/chapter6.rpy:1862
translate japanese ecg13_label_64fc2a91:

    # voice ""
    # "소녀와 함께했던 일련의 시간들이 단편적으로 머릿속에서 흘러갔다. "
    voice ""
    "少女と過ごした一連の時間が断片的に頭の中を流れていった。"

# game/chapter6.rpy:1864
translate japanese ecg13_label_6ad6ede1:

    # "하지만 '그때'라니? "
    "しかし「あのとき」とは？"

# game/chapter6.rpy:1865
translate japanese ecg13_label_149f3daf:

    # "천천히 소녀와 함께했던 모든 장면들을 떠올리기엔 너무나도 차가운 침묵이 이를 허락할 것 같지 않았다. "
    "ゆっくりと少女と過ごしたすべての場面を思い出すには、あまりにも冷たい沈黙がそれを許してくれそうになかった。"

# game/chapter6.rpy:1866
translate japanese ecg13_label_fd4375f2:

    # "감이 잘 잡히지 않아 기억 속을 헤맬 무렵, 소녀의 목소리가 들려왔다. "
    "うまく見当がつかず記憶の中をさまよっていた頃、少女の声が聞こえてきた。"

# game/chapter6.rpy:1868
translate japanese ecg13_label_01a6522f:

    # voice "voices/gf15.ogg"
    # 소녀 "“같은 방법이었어요.”"
    voice "voices/gf15.ogg"
    소녀 "「同じ方法だったんです。」"

# game/chapter6.rpy:1870
translate japanese ecg13_label_a0a09596:

    # voice ""
    # "소녀가 이야기한 그때란, 그날의 일을 이야기하는 것이었다. "
    voice ""
    "少女が言う「あのとき」とは、あの日のことを指していた。"

# game/chapter6.rpy:1873
translate japanese ecg13_label_7e89032c:

    # voice "voices/gf16.ogg"
    # 소녀 "“그런 생각을 할 수 있었던 것도, 기억해냈기 때문이에요.”"
    voice "voices/gf16.ogg"
    소녀 "「そういう考えができたのも、思い出したからなんです。」"

# game/chapter6.rpy:1878
translate japanese ecg13_label_0f65fbdd:

    # voice ""
    # "둔탁한 소리, 그리고 퍼져나가는 붉은색. "
    voice ""
    "鈍い音、そして広がっていく赤。"

# game/chapter6.rpy:1883
translate japanese ecg13_label_3985a4b0:

    # "그리고 그 모든 것이 흔적도 없이 사라지고 남겨진 검정. "
    "そしてそのすべてが跡形もなく消え去り、残されたのは黒。"

# game/chapter6.rpy:1884
translate japanese ecg13_label_01a80a50:

    # "그 잔재가 무엇을 의미하는지는, 돌이켜 생각해보면 간단했다. "
    "その残滓が何を意味するのかは、振り返ってみれば単純だった。"

# game/chapter6.rpy:1890
translate japanese ecg13_label_ca1767ee:

    # 나 "“그 연쇄 살인범을 뒤에서 쓰러트린 것도.”"
    나 "「あの連続殺人犯を背後から倒したのも。」"

# game/chapter6.rpy:1892
translate japanese ecg13_label_0cdc0c02:

    # "하지만 어째서였을까. "
    "しかしなぜだったのだろう。"

# game/chapter6.rpy:1894
translate japanese ecg13_label_94271365:

    # 나 "“그리고 그곳을 흔적도 없이 태워버린 것도.”"
    나 "「そしてあの場所を跡形もなく燃やし尽くしたのも。」"

# game/chapter6.rpy:1898
translate japanese ecg13_label_4f039024:

    # "그 붉은색이 더할 나위 없이 따스하게 느껴졌던 건. "
    "あの赤がこの上なく温かく感じられたのは。"

# game/chapter6.rpy:1902
translate japanese ecg13_label_898490c0:

    # 나 "“…… 역시 너였구나.”"
    나 "「……やっぱりお前だったんだな。」"

# game/chapter6.rpy:1904
translate japanese ecg13_label_68679f38:

    # "…… 어째서였던 걸까? "
    "……なぜだったのだろう？"

# game/chapter6.rpy:1906
translate japanese ecg13_label_396673fa:

    # 나 "“…….”"
    나 "「……」"

# game/chapter6.rpy:1908
translate japanese ecg13_label_cac3ad26:

    # "소녀는 말없이 고개를 끄덕였다. "
    "少女は黙って頷いた。"

# game/chapter6.rpy:1910
translate japanese ecg13_label_affe9c78:

    # 나 "“똑같은 방법이었다는 말은…….”"
    나 "「同じ方法だったってことは……」"

# game/chapter6.rpy:1911
translate japanese ecg13_label_c7121e8d:

    # voice "voices/gf17.ogg"
    # 소녀 "“살아 있었을 때도, 그런 식이었다는 거죠.”"
    voice "voices/gf17.ogg"
    소녀 "「生きていたときも、そういうやり方だった、ということです。」"

# game/chapter6.rpy:1913
translate japanese ecg13_label_1eb75f65:

    # voice ""
    # 나 "“왜 그런 거야?”"
    voice ""
    나 "「なんでそんなことを？」"

# game/chapter6.rpy:1916
translate japanese ecg13_label_0839dede:

    # "더 이상의 시선은 무리라는 듯, 소녀는 고개를 돌려버렸다. "
    "これ以上の視線には耐えられないとでもいうように、少女は顔を背けてしまった。"

# game/chapter6.rpy:1918
translate japanese ecg13_label_207c4b98:

    # "힘없이 돌린 고개를 무기력하게 들어 올린 소녀가 무언가를 중얼거린다. "
    "力なく背けた顔を気だるげに持ち上げた少女が何かをつぶやく。"

# game/chapter6.rpy:1919
translate japanese ecg13_label_1b5656d0:

    # "그 한 마디보다 먼저, 내겐 소녀의 떨리는 숨결이 닿는다. "
    "その一言より先に、俺には少女の震える吐息が届く。"

# game/chapter6.rpy:1922
translate japanese ecg13_label_c1da86bd:

    # voice "voices/gf18.ogg"
    # 소녀 "“모르겠어요.”"
    voice "voices/gf18.ogg"
    소녀 "「分かりません。」"

# game/chapter6.rpy:1924
translate japanese ecg13_label_5f8bb517:

    # voice ""
    # "소녀의 일렁이는 목소리가 힘겹게, 느릿느릿 내게 도착한다. "
    voice ""
    "少女の揺れる声が辛うじて、ゆっくりと俺に届く。"

# game/chapter6.rpy:1926
translate japanese ecg13_label_ade3fbca:

    # "그 한 마디뿐이었다. "
    "その一言だけだった。"

# game/chapter6.rpy:1927
translate japanese ecg13_label_80b87022:

    # "다시금 떨리는 두 명의 숨결만이 텅 빈 공간을 희미하게 메워주고 있었다. "
    "再び震える二人の息遣いだけが、がらんとした空間をかすかに埋めていた。"

# game/chapter6.rpy:1928
translate japanese ecg13_label_5d844eba:

    # "무엇을 모르겠다는 걸까? "
    "何が分からないというのだろう。"

# game/chapter6.rpy:1929
translate japanese ecg13_label_e78c1df6:

    # "자기도 왜 그런 일을 저질렀는지 모르겠다는 후회 섞인 대답인 걸까? "
    "自分でもなぜそんなことをしたのか分からないという、後悔の混じった答えなのだろうか。"

# game/chapter6.rpy:1930
translate japanese ecg13_label_189ac57b:

    # "그게 아니라면, 정말 소녀의 기억 속에 살인의 이유가 남아있지 않다는 뜻일까? "
    "そうでないなら、本当に少女の記憶の中に殺人の理由が残っていないということなのだろうか。"

# game/chapter6.rpy:1931
translate japanese ecg13_label_dbfdb4df:

    # "소녀의 뒷모습을 멍하니 바라보며, 눈을 깜빡였다. "
    "少女の後ろ姿をぼんやりと見つめながら、目を瞬いた。"

# game/chapter6.rpy:1932
translate japanese ecg13_label_2449b375:

    # "한 번, 두 번, 눈동자를 깜빡일 때마다 물들어가는 소녀의 모습이 눈동자에 맺혀갔다. "
    "一度、二度、瞬きするたびに滲んでいく少女の姿が瞳に焼きついていった。"

# game/chapter6.rpy:1934
translate japanese ecg13_label_2993b048:

    # "알고 있었다. "
    "分かっていた。"

# game/chapter6.rpy:1935
translate japanese ecg13_label_59a7b876:

    # "정답이 무엇인가는, 상관없다. "
    "正解が何であるかは、関係ない。"

# game/chapter6.rpy:1938
translate japanese ecg13_label_18b6001e:

    # 나 "“가지 마.”"
    나 "「行くな。」"

# game/chapter6.rpy:1940
translate japanese ecg13_label_149ae2a4:

    # "물방울져가던 소녀의 모습이 뺨을 타고 흘러내리기 직전, 한 발짝 걸음을 떼려던 그녀를 향해 그렇게 말한다. "
    "雫になりかけた少女の姿が頬を伝い落ちる寸前、一歩踏み出そうとした彼女に向かってそう言った。"

# game/chapter6.rpy:1942
translate japanese ecg13_label_d5b3f3c7:

    # 나 "어찌 됐든 괜찮으니까, 이대로 내 앞에서 사라지지만 말아 줘."
    나 "「どうなったっていいから、このまま俺の前から消えないでくれ。」"

# game/chapter6.rpy:1944
translate japanese ecg13_label_f0052175:

    # "이번엔 내가 한 걸음, 소녀를 향해 다가간다. "
    "今度は俺が一歩、少女に向かって近づく。"

# game/chapter6.rpy:1946
translate japanese ecg13_label_939a6491:

    # "바스라지듯 들려온 나의 발걸음 소리에, 어쩔 수 없다는 것처럼 소녀가 고개를 돌린다. "
    "崩れるように響いた俺の足音に、仕方ないとでもいうように少女が顔を向ける。"

# game/chapter6.rpy:1947
translate japanese ecg13_label_bc13dfcd:

    # "그제서야 알 수 있었다. "
    "そこでようやく分かった。"

# game/chapter6.rpy:1948
translate japanese ecg13_label_fda2bb27:

    # "소녀가 내게서 고개를 돌렸던 이유를. "
    "少女が俺から顔を背けていた理由を。"

# game/chapter6.rpy:1952
translate japanese ecg13_label_42d17383:

    # voice "voices/gf19.ogg"
    # 소녀 "“어째서.”"
    voice "voices/gf19.ogg"
    소녀 "「どうして。」"

# game/chapter6.rpy:1954
translate japanese ecg13_label_e71c8af1:

    # voice ""
    # "보여주고 싶지 않았던 건가 보다. "
    voice ""
    "見せたくなかったのだろう。"

# game/chapter6.rpy:1956
translate japanese ecg13_label_ed08f187:

    # voice "voices/gf20.ogg"
    # 소녀 "“어째서 저 같은 살인귀를 붙잡고 있는 건가요?!”"
    voice "voices/gf20.ogg"
    소녀 "「どうして私みたいな殺人鬼を引き止めてるんですか？！」"

# game/chapter6.rpy:1958
translate japanese ecg13_label_e449b8ca:

    # voice ""
    # "쏟아지는 별빛에 휩싸인 소녀의 눈동자가, 조금만 건드려도 울음을 터뜨릴 것처럼 반짝이고 있었다. "
    voice ""
    "降り注ぐ星明かりに包まれた少女の瞳が、少し触れただけで泣き出してしまいそうなほどきらめいていた。"

# game/chapter6.rpy:1960
translate japanese ecg13_label_f6e04bc2:

    # "메말라 버렸을 감정의 자취인지, 쏟아지는 별빛에 휩싸인 빛의 흔적인지 모를 감각의 알갱이가 아른거리며 그녀의 얼굴을 타고 흘러내린다. "
    "枯れ果てたはずの感情の痕跡か、降り注ぐ星明かりに包まれた光の残像か、判別のつかない感覚の粒がゆらめきながら彼女の頬を伝い流れていく。"

# game/chapter6.rpy:1961
translate japanese ecg13_label_8d2414be:

    # "손을 뻗어 닿는다면 알 수 있었을 텐데. "
    "手を伸ばして触れられたなら分かったはずなのに。"

# game/chapter6.rpy:1962
translate japanese ecg13_label_09e4727b:

    # "나는 다만 차분히 숨을 고르며, 소녀의 들려올 목소리를 기다렸다. "
    "俺はただ静かに息を整えながら、少女の声が届くのを待った。"

# game/chapter6.rpy:1964
translate japanese ecg13_label_396673fa_1:

    # 나 "“…….”"
    나 "「……」"

# game/chapter6.rpy:1966
translate japanese ecg13_label_07f9f166:

    # "그녀의 숨결로 가득 찬 이 공간에서, 그 목소리는 아마 어떤 것보다도 빠르게 내게 닿지 않았을까. "
    "彼女の息遣いで満たされたこの空間で、その声はきっと何よりも早く俺に届いたのではないだろうか。"

# game/chapter6.rpy:1967
translate japanese ecg13_label_6392d1c7:

    # "분명 몇 걸음 떨어져있는 소녀로부터의 목소리는 그저 눈앞에서 들려오는 울먹임 같았다. "
    "確かに数歩離れている少女からの声は、まるで目の前から聞こえるすすり泣きのようだった。"

# game/chapter6.rpy:1971
translate japanese ecg13_label_7b34d786:

    # voice "voices/gf21.ogg"
    # 소녀 "“어째서어…….”"
    voice "voices/gf21.ogg"
    소녀 "「どうして……」"

# game/chapter6.rpy:1974
translate japanese ecg13_label_7e60ddef:

    # voice ""
    # "다시 한번 슬그머니 눈을 피하려는 소녀에게 다가가며, 대답을 건넨다. "
    voice ""
    "もう一度そっと目を逸らそうとする少女に近づきながら、答えを返す。"

# game/chapter6.rpy:1977
translate japanese ecg13_label_cbbb6ec1:

    # 나 "“좋아하는 것 같아.”"
    나 "「好きみたいだ。」"

# game/chapter6.rpy:1979
translate japanese ecg13_label_7cdbab3e:

    # voice "voices/gf22.ogg"
    # 소녀 "“네…… 에?”"
    voice "voices/gf22.ogg"
    소녀 "「え……ぇ？」"

# game/chapter6.rpy:1982
translate japanese ecg13_label_66d1475f:

    # voice ""
    # 나 "“…… 좋아해. 너를.”"
    voice ""
    나 "「……好きだ。お前のことが。」"

# game/chapter6.rpy:1985
translate japanese ecg13_label_147e2504:

    # "라고, 말이다. "
    "と、そう言ったのだ。"

# game/chapter6.rpy:1987
translate japanese ecg13_label_08b2f67c:

    # voice "voices/gf23.ogg"
    # 소녀 "“…… 장난치지 마세요.”"
    voice "voices/gf23.ogg"
    소녀 "「……ふざけないでください。」"

# game/chapter6.rpy:1990
translate japanese ecg13_label_e19d090f:

    # voice ""
    # 나 "“그런 거 아냐.”"
    voice ""
    나 "「ふざけてなんかいない。」"

# game/chapter6.rpy:1993
translate japanese ecg13_label_cbf078f1:

    # "어느새 가까워진 둘 사이의 거리가 이번엔 숨소리가 아닌 나의 심장 박동을 허락한다. "
    "いつの間にか近づいた二人の距離が、今度は息遣いではなく俺の心臓の鼓動を許す。"

# game/chapter6.rpy:1994
translate japanese ecg13_label_021b6ea8:

    # "소녀에게 닿은 나의 소리가, 내 목소리와 더해진다. "
    "少女に届いた俺の音が、俺の声と重なる。"

# game/chapter6.rpy:1995
translate japanese ecg13_label_85b93823:

    # "가까워진 거리만큼이나 나의 진심도 소녀에게 가까워졌기를. "
    "近づいた距離の分だけ、俺の本心も少女に近づいていてくれたなら。"

# game/chapter6.rpy:1996
translate japanese ecg13_label_2dc0808d:

    # "그렇게 바랄 뿐이다. "
    "そう願うばかりだ。"

# game/chapter6.rpy:1998
translate japanese ecg13_label_319c2c5c:

    # 나 "“좋아해, 너를. 정말로.”"
    나 "「好きだ、お前のことが。本当に。」"

# game/chapter6.rpy:1999
translate japanese ecg13_label_acbfdb9f:

    # voice "voices/gf24.ogg"
    # 소녀 "“이제 와서 그런 말을 듣는다고 해도…….”"
    voice "voices/gf24.ogg"
    소녀 "「今さらそんなことを言われても……」"

# game/chapter6.rpy:2001
translate japanese ecg13_label_9d89eefc:

    # voice ""
    # 나 "“미안. 이제 와서 이런 말 해서.”"
    voice ""
    나 "「ごめん。こんなこと言って。」"

# game/chapter6.rpy:2004
translate japanese ecg13_label_42eccad4:

    # "전해야 한다고 생각했던 것이 이런 감정이었던 걸까. "
    "伝えなければと思っていたのが、この気持ちだったのだろうか。"

# game/chapter6.rpy:2005
translate japanese ecg13_label_e4bf1f28:

    # "너무 늦지 않았던 거라면 좋겠는데. "
    "遅すぎなかったのならいいのだけど。"

# game/chapter6.rpy:2006
translate japanese ecg13_label_9eb9877e:

    # "시간이 멈춘 것처럼, 나도, 소녀도, 움직임을 멈춘다. "
    "時間が止まったように、俺も、少女も、動きを止める。"

# game/chapter6.rpy:2007
translate japanese ecg13_label_0382d536:

    # "무언가를 이야기하고 싶은 듯 소녀는 연거푸 얕은 숨을 내뱉았지만, 쉽사리 목소리가 나오지 않는 것 같아 보였다. "
    "何かを言いたげに少女は立て続けに浅い息を吐いていたが、なかなか声が出ないようだった。"

# game/chapter6.rpy:2008
translate japanese ecg13_label_ff6ca1da:

    # "하지만 이대로 영원히 시간이 멈춰 있기를 바라고만 있을 수는 없으니까. "
    "けれどこのまま永遠に時間が止まっていてほしいと願っているだけではいられないから。"

# game/chapter6.rpy:2011
translate japanese ecg13_label_76f1db88:

    # 나 "“그렇지만 진심이야. 정말로, 정말 너를 좋아해. 그러니까…… 이대로 끝나는 건 싫어.”"
    나 "「それでも本気だよ。本当に、本当にお前のことが好きだ。だから……このまま終わるのは嫌なんだ。」"

# game/chapter6.rpy:2013
translate japanese ecg13_label_e2937b03:

    # voice "voices/gf25.ogg"
    # 소녀 "“왜일까요?”"
    voice "voices/gf25.ogg"
    소녀 "「どうしてなんでしょう？」"

# game/chapter6.rpy:2016
translate japanese ecg13_label_838d5bcc:

    # voice ""
    # "멈춰 있던 시간이 흐른다. "
    voice ""
    "止まっていた時間が動き出す。"

# game/chapter6.rpy:2019
translate japanese ecg13_label_17dc0823:

    # voice "voices/gf26.ogg"
    # 소녀 "“바보같은 이야기는 그만 두세요―――”"
    voice "voices/gf26.ogg"
    소녀 "「馬鹿なことはやめてください―――」"

# game/chapter6.rpy:2021
translate japanese ecg13_label_c41cdb04:

    # voice ""
    # "본래라면 거절을 나타내야 할 그 한 마디는, 때늦은 철 떨어지는 여린 봄꽃처럼, 힘없이 나풀거렸다. "
    voice ""
    "本来なら拒絶を示すはずのその一言は、時季外れに散る淡い春の花びらのように、力なくはらりと揺れた。"

# game/chapter6.rpy:2025
translate japanese ecg13_label_4ec43dc6:

    # voice "voices/gf27.ogg"
    # 소녀 "“라고, 말해야 하는데 말이죠.”"
    voice "voices/gf27.ogg"
    소녀 "「と、言わなきゃいけないんですけどね。」"

# game/chapter6.rpy:2028
translate japanese ecg13_label_7c2d35e6:

    # voice ""
    # "울고 싶다라고 말하는 듯한 표정 속에 섞인 복잡한 감정. "
    voice ""
    "泣きたいと言っているような表情の中に混じった複雑な感情。"

# game/chapter6.rpy:2030
translate japanese ecg13_label_c43215b0:

    # "소녀의 얼굴에서는 밤하늘의 별을 헤아려야 할 것만 같은, 수많은 감정들이 비쳤다. "
    "少女の顔には、夜空の星を数えなければならないほどの、数えきれない感情が映っていた。"

# game/chapter6.rpy:2033
translate japanese ecg13_label_8dd817a1:

    # voice "voices/gf28.ogg"
    # 소녀 "“그렇게 되면, 저도 붙잡고 싶어져 버리잖아요…….”"
    voice "voices/gf28.ogg"
    소녀 "「そんなことされたら、私だって引き止めたくなっちゃうじゃないですか……」"

# game/chapter6.rpy:2035
translate japanese ecg13_label_8eb1f729:

    # voice ""
    # "해석하기엔 너무 많은 감정들이었다. "
    voice ""
    "読み解くにはあまりに多すぎる感情だった。"

# game/chapter6.rpy:2037
translate japanese ecg13_label_fc85c600:

    # "내가 할 수 있는 일이라고는 한 가지 정도뿐이라는 걸, 나도 잘 알고 있다. "
    "俺にできることといえば一つくらいしかないということを、俺自身よく分かっている。"

# game/chapter6.rpy:2038
translate japanese ecg13_label_ab3c27f0:

    # "멍하니 나를 바라보고만 있던 소녀에게, 나는 손을 내밀었다. "
    "ぼんやりと俺を見つめているだけだった少女に、俺は手を差し出した。"

# game/chapter6.rpy:2039
translate japanese ecg13_label_db3f2d87:

    # voice "voices/gf29.ogg"
    # 소녀 "“이상해요, 이상하다고요.”"
    voice "voices/gf29.ogg"
    소녀 "「おかしいです、おかしいんですよ。」"

# game/chapter6.rpy:2041
translate japanese ecg13_label_a657c40d:

    # voice ""
    # "차가우면서도 부드러운, 한없이 익숙한 손길이 내게 닿는다. "
    voice ""
    "冷たくも柔らかい、限りなく馴染みのある手の感触が俺に触れる。"

# game/chapter6.rpy:2045
translate japanese ecg13_label_2bd5801e:

    # voice "voices/gf30.ogg"
    # 소녀 "“이러고만 있으면 왠지 따뜻해져서…… 살아있는 것 같다고 느껴버리는걸요.”"
    voice "voices/gf30.ogg"
    소녀 "「こうしているだけで何だか温かくなって……生きているみたいだって感じてしまうんですよ。」"

# game/chapter6.rpy:2053
translate japanese ecg13_label_07be8981:

    # voice ""
    # "그런 소녀의 손을, 나는 살며시 어루만져주었다. "
    voice ""
    "そんな少女の手を、俺はそっと撫でた。"

# game/chapter6.rpy:2055
translate japanese ecg13_label_7729dd75:

    # "차갑게 남아있는 상처가, 조금은 따뜻해질 수 있도록. "
    "冷たく残る傷が、少しでも温かくなれるように。"

# game/chapter6.rpy:2056
translate japanese ecg13_label_6141d7b3:

    # "맥박이 느껴지지 않는 차가운 손이 나의 손에 오랫동안 머무른다. "
    "脈のない冷たい手が俺の手の中に長く留まる。"

# game/chapter6.rpy:2059
translate japanese ecg13_label_a828ff8a:

    # "그 차가움이 마음에 들었던 건지, 나는 오랫동안 소녀의 손을 놓지 않고 서 있었다. "
    "その冷たさが心地よかったのか、俺は長い間少女の手を離さずに立っていた。"

# game/chapter6.rpy:2060
translate japanese ecg13_label_c6d1d9ff:

    # "소녀 역시 붙잡은 손에서 느껴지는 따스함이라는 감각이 싫지 않았는지, 그 순간을 놓지 않고 계속 이어갔다. "
    "少女もまた握られた手から伝わる温もりという感覚が嫌ではなかったのか、その瞬間を手放さずに繋ぎ止めていた。"

# game/chapter6.rpy:2065
translate japanese ecg13_label_b53f9120:

    # "얼마나 오랜 시간을 그런 채로 있었던 걸까. "
    "どれほど長い時間をそうしていたのだろう。"

# game/chapter6.rpy:2066
translate japanese ecg13_label_32604ff6:

    # "한 발짝 뒤에서 우리의 그런 모습을 바라보고 있던 유미가 내게 말을 건네왔다. "
    "一歩後ろから俺たちのそんな姿を見ていたユミが声をかけてきた。"

# game/chapter6.rpy:2069
translate japanese ecg13_label_887d4e0c:

    # voice "voices/yf130.ogg"
    # 유미 "“요컨대, 그 유령이 지금 네 눈앞에 있다는 거지?”"
    voice "voices/yf130.ogg"
    유미 "「つまり、その幽霊が今あんたの目の前にいるってこと？」"

# game/chapter6.rpy:2071
translate japanese ecg13_label_bf92388e:

    # voice ""
    # 나 "“맞아.”"
    voice ""
    나 "「ああ。」"

# game/chapter6.rpy:2073
translate japanese ecg13_label_57443a68:

    # voice "voices/yf131.ogg"
    # 유미 "“그 유령 여자애가 뭐래? 같이 돌아간대?”"
    voice "voices/yf131.ogg"
    유미 "「その幽霊の子、なんて言ってる？ 一緒に帰るって？」"

# game/chapter6.rpy:2075
translate japanese ecg13_label_e27cb895:

    # voice ""
    # "잠깐의 간격을 두고 소녀가 고개를 끄덕였다. "
    voice ""
    "少しの間を置いて少女が頷いた。"

# game/chapter6.rpy:2078
translate japanese ecg13_label_ca0e18a3:

    # 나 "“응. 그러겠대.”"
    나 "「うん。そうするって。」"

# game/chapter6.rpy:2079
translate japanese ecg13_label_dcdda40d:

    # voice "voices/yf132.ogg"
    # 유미 "“그럼, 조금만 더 있다 가자.”"
    voice "voices/yf132.ogg"
    유미 "「じゃあ、もう少しだけいてから帰ろう。」"

# game/chapter6.rpy:2081
translate japanese ecg13_label_038fef28:

    # voice ""
    # "여전히 허공을 껴안은 채로 보였을 내게, 유미가 말했다. "
    voice ""
    "相変わらず虚空を抱いているように見えたであろう俺に、ユミが言った。"

# game/chapter6.rpy:2084
translate japanese ecg13_label_4fb2910c:

    # voice "voices/yf133.ogg"
    # 유미 "“여기 별, 되게 예쁘단 말이야.”"
    voice "voices/yf133.ogg"
    유미 "「ここの星、すごくきれいなんだから。」"

# game/chapter6.rpy:2087
translate japanese ecg13_label_9c0610cd:

    # voice ""
    # "그 말을 듣고선, 여태껏 고개를 푹 숙이고만 있던 소녀도 고개를 슬쩍 들어 시선을 별무리 속으로 향했다. "
    voice ""
    "その言葉を聞いて、ずっとうつむいていた少女も顔をそっと上げ、視線を星々の中へと向けた。"

# game/chapter6.rpy:2090
translate japanese ecg13_label_ff4c5b01:

    # voice "voices/gf31.ogg"
    # 소녀 "“정말이네요. 혼자였을 땐 한 번도 본 적 없었는데.”"
    voice "voices/gf31.ogg"
    소녀 "「本当ですね。一人のときは一度も見たことなかったのに。」"

# game/chapter6.rpy:2092
translate japanese ecg13_label_5e1a2d6b:

    # voice ""
    # "어딘가 아련한 눈빛으로 별빛을 응시하는 소녀의 모습에서, 묘한 쓸쓸함이 느껴졌다. "
    voice ""
    "どこか切ない眼差しで星明かりを見つめる少女の姿から、妙な寂しさが感じられた。"

# game/chapter6.rpy:2094
translate japanese ecg13_label_bb94b03e:

    # "그 날 별빛 아래에서 보았던 소녀의 희미한 미소는 마치 신기루였던 것처럼 사라져 메마른 감정만이 남아있는 듯했다. "
    "あの日星明かりの下で見た少女のかすかな微笑みは、まるで蜃気楼だったかのように消えて、乾いた感情だけが残っているようだった。"

# game/chapter6.rpy:2095
translate japanese ecg13_label_f5192ef1:

    # "돌아갈 수 있을까. "
    "取り戻せるだろうか。"

# game/chapter6.rpy:2096
translate japanese ecg13_label_d54daeff:

    # "다시 한번 소녀의 미소를 볼 수 있는 날을, 나는 언젠가 마주할 수 있을까. "
    "もう一度少女の笑顔を見られる日を、俺はいつか迎えることができるのだろうか。"

# game/chapter6.rpy:2098
translate japanese ecg13_label_ad527c70:

    # "소녀와 함께, 그리고 유미와 함께 왔던 길을 돌아 걸어오며 그런 고민에 휩싸였다. "
    "少女と、そしてユミと一緒に来た道を引き返しながら、そんな思いに囚われていた。"

# game/chapter6.rpy:2103
translate japanese ecg13_label_951e67f2:

    # "F구역에 도착해 호버크라프트를 잡아타고선 집으로 돌아오는 길. "
    "F区域に着いてホバークラフトに乗り、家へと帰る道すがら。"

# game/chapter6.rpy:2104
translate japanese ecg13_label_be994f0c:

    # "소녀는 나의 어깨에 기대어 꾸벅꾸벅 졸더니 어느새 스르륵 잠이 들어버린 뒤였다. "
    "少女は俺の肩にもたれてこっくりこっくりと船を漕ぎ、いつの間にかすうっと眠りに落ちていた。"

# game/chapter6.rpy:2108
translate japanese ecg13_label_e322f30e:

    # voice "voices/yf134.ogg"
    # 유미 "“그 유령 여자애랑은 더 이야기 안 해?”"
    voice "voices/yf134.ogg"
    유미 "「あの幽霊の子とはもう話さないの？」"

# game/chapter6.rpy:2110
translate japanese ecg13_label_26637d61:

    # voice ""
    # 나 "“지금 자고 있어. 많이 힘들었나 봐.”"
    voice ""
    나 "「今寝てるんだ。だいぶ疲れたみたいで。」"

# game/chapter6.rpy:2113
translate japanese ecg13_label_aada42f9:

    # "유미는 뒷자리에 홀로 앉아있는 것처럼 보였을 나를 뚫어져라 쳐다보더니, 이내 다시 말을 건네왔다. "
    "ユミは後部座席に一人で座っているように見えたであろう俺をじっと見つめてから、再び話しかけてきた。"

# game/chapter6.rpy:2115
translate japanese ecg13_label_8a0239e2:

    # voice "voices/yf135.ogg"
    # 유미 "“이제 돌아가선 어떡하려고?”"
    voice "voices/yf135.ogg"
    유미 "「これから帰ったらどうするつもり？」"

# game/chapter6.rpy:2117
translate japanese ecg13_label_dcdb0a21:

    # voice ""
    # 나 "“다시 알아봐야지. 이 유령 여자애에 대해서.”"
    voice ""
    나 "「もう一度調べるよ。この幽霊の子のことを。」"

# game/chapter6.rpy:2120
translate japanese ecg13_label_32c3e3c4:

    # voice "voices/yf136.ogg"
    # 유미 "“괜찮겠어? 그 유령 여자애, 사람을 죽였다며.”"
    voice "voices/yf136.ogg"
    유미 "「大丈夫なの？ その幽霊の子、人を殺したって言ってたじゃない。」"

# game/chapter6.rpy:2122
translate japanese ecg13_label_3e28369b:

    # voice ""
    # 나 "“분명 뭔가 이유가 있을 거야. 그런 기억을 갖게 된 이유가.”"
    voice ""
    나 "「きっと何か理由があるはずだ。そんな記憶を持つようになった理由が。」"

# game/chapter6.rpy:2125
translate japanese ecg13_label_1e6213b6:

    # voice "voices/yf137.ogg"
    # 유미 "“다시 알아본다는 건, 계획은 있는 거고?”"
    voice "voices/yf137.ogg"
    유미 "「もう一度調べるって、何か計画はあるの？」"

# game/chapter6.rpy:2127
translate japanese ecg13_label_59840bba:

    # voice ""
    # 나 "“…… 놓친 게 있을 거야.”"
    voice ""
    나 "「……見落としてるものがあるはずだ。」"

# game/chapter6.rpy:2130
translate japanese ecg13_label_9ff747cf:

    # voice "voices/yf138.ogg"
    # 유미 "“놓친 거?”"
    voice "voices/yf138.ogg"
    유미 "「見落としてるもの？」"

# game/chapter6.rpy:2132
translate japanese ecg13_label_ef25539e:

    # voice ""
    # 나 "“잘은 모르겠지만…… 그럴 거라는 생각이 들어.”"
    voice ""
    나 "「よくは分からないけど……そんな気がするんだ。」"

# game/chapter6.rpy:2135
translate japanese ecg13_label_ec14303c:

    # voice "voices/yf139.ogg"
    # 유미 "“참, 대책 없는 건 여전하네.”"
    voice "voices/yf139.ogg"
    유미 "「まったく、無策なのは相変わらずだね。」"

# game/chapter6.rpy:2138
translate japanese ecg13_label_5d3f6a56:

    # voice ""
    # "걱정스러운 표정을 지어 보이는 유미였지만, 나를 말릴 생각은 없어 보였다."
    voice ""
    "心配そうな顔を見せるユミだったが、俺を引き止めるつもりはないようだった。"

# game/chapter6.rpy:2141
translate japanese ecg13_label_367f61d9:

    # 나 "“있지, 만약 무언가를 잊는다고 한다면. 무엇을 가장 먼저 잊을까?”"
    나 "「なあ、もし何かを忘れるとしたら。何を一番先に忘れると思う？」"

# game/chapter6.rpy:2143
translate japanese ecg13_label_ad869864:

    # voice "voices/yf140.ogg"
    # 유미 "“글쎄, 아마 가장 소중한 일이겠지?”"
    voice "voices/yf140.ogg"
    유미 "「さあ、たぶん一番大切なことじゃない？」"

# game/chapter6.rpy:2145
translate japanese ecg13_label_9e965818:

    # voice ""
    # "유미는 내가 불쑥 꺼낸 질문에, 마치 기다리고 있었던 것처럼 즉답을 건넸다. "
    voice ""
    "ユミは俺がふいに投げかけた質問に、まるで待っていたかのように即答を返した。"

# game/chapter6.rpy:2148
translate japanese ecg13_label_645225f2:

    # 나 "“왜? 가장 소중한 일은 오랫동안 기억하지 않아?”"
    나 "「なんで？ 一番大切なことは長いこと覚えてるもんじゃないのか？」"

# game/chapter6.rpy:2150
translate japanese ecg13_label_1d0d7fb8:

    # voice "voices/yf141.ogg"
    # 유미 "“그럼, 가장 소중한 일이라는 게 뭐라고 생각해?”"
    voice "voices/yf141.ogg"
    유미 "「じゃあ、一番大切なことって何だと思う？」"

# game/chapter6.rpy:2152
translate japanese ecg13_label_e9445dd0:

    # voice ""
    # 나 "“그거야, 중요한 일이라거나…….”"
    voice ""
    나 "「そりゃ、重要なことだとか……」"

# game/chapter6.rpy:2155
translate japanese ecg13_label_883879b5:

    # voice "voices/yf142.ogg"
    # 유미 "“난 나에게 가장 소중한 건 항상 곁에 있어서 익숙해진 일이라고 생각하거든.”"
    voice "voices/yf142.ogg"
    유미 "「私は、自分にとって一番大切なのはいつもそばにあって当たり前になったことだと思うんだよね。」"

# game/chapter6.rpy:2157
translate japanese ecg13_label_de750dfe:

    # voice ""
    # 나 "“그런가…….”"
    voice ""
    나 "「そうか……」"

# game/chapter6.rpy:2160
translate japanese ecg13_label_a466fb99:

    # "정론처럼 들리는 유미의 이야기였지만, 곧장 감이 잡히는 건 아니었다. "
    "正論のように聞こえるユミの話だったが、すぐにはピンとこなかった。"

# game/chapter6.rpy:2161
translate japanese ecg13_label_4dc0d08c:

    # "파편처럼 흩어진 생각들을 정리할 시간이 필요했다. "
    "破片のように散らばった考えを整理する時間が必要だった。"

# game/chapter6.rpy:2165
translate japanese ecg13_label_364e70a0:

    # voice "voices/yf143.ogg"
    # 유미 "“그런데 그건 갑자기 왜?”"
    voice "voices/yf143.ogg"
    유미 "「ところで、急にどうして？」"

# game/chapter6.rpy:2167
translate japanese ecg13_label_50b22bad:

    # voice ""
    # 나 "“내가 잊어버린 기억 중에 뭔가 실마리가 있을까 해서.”"
    voice ""
    나 "「俺が忘れてしまった記憶の中に何か手がかりがないかと思って。」"

# game/chapter6.rpy:2169
translate japanese ecg13_label_77cd7506:

    # voice "voices/yf144.ogg"
    # 유미 "“그렇지만, 너는 그 유령 소녀와는 전혀 관계없었던 거 아냐?”"
    voice "voices/yf144.ogg"
    유미 "「でも、あんたはその幽霊の少女とは何の関係もなかったんじゃないの？」"

# game/chapter6.rpy:2171
translate japanese ecg13_label_1c137b3a:

    # voice ""
    # 나 "“…… 마음에 걸리는 게 있어.”"
    voice ""
    나 "「……引っかかることがあるんだ。」"

# game/chapter6.rpy:2177
translate japanese ecg13_label_b07c8398:

    # "나도 알고 있다. "
    "俺にも分かっている。"

# game/chapter6.rpy:2178
translate japanese ecg13_label_a8de505b:

    # "아득한 과거로부터 날아온 망령인 내가 소녀와의 인연을 전혀 주장할 수 없다는 것을. "
    "遥かな過去から飛んできた亡霊である俺が、少女との縁など到底主張できないということを。"

# game/chapter6.rpy:2179
translate japanese ecg13_label_cfb78919:

    # "하지만 매번, 나의 무의식으로부터 들려왔던 목소리의 주인이 다른 누구도 아닌 소녀였다는 점이 유일하게 마음에 걸리는 부분이었다. "
    "だが毎回、俺の無意識から聞こえてきた声の主が他の誰でもない少女だったという点だけが、唯一引っかかる部分だった。"

# game/chapter6.rpy:2180
translate japanese ecg13_label_5c28dceb:

    # "어째서일까? "
    "なぜなのだろう？"

# game/chapter6.rpy:2181
translate japanese ecg13_label_2264c849:

    # "망자로 만난 엇나간 인연의 두 사람이 목소리로 연결되어 있는 건. "
    "亡者として出会った、すれ違った縁の二人が声で繋がっていることが。"

# game/chapter6.rpy:2182
translate japanese ecg13_label_3bd046eb:

    # "단순한 착각이라 치부하기엔 너무나도 따스하게 들려온 소녀의 목소리가 이번에도 머릿속을 빙글빙글 맴돌았다. "
    "単なる思い違いと片付けるにはあまりにも温かく聞こえてきた少女の声が、今回も頭の中をぐるぐると巡っていた。"

# game/chapter6.rpy:2183
translate japanese ecg13_label_275069e6:

    # "긴 아치교를 지나, 익숙한 사거리에 도착할 때까지도 말이다. "
    "長いアーチ橋を渡り、見慣れた十字路に着くまでずっと。"

# game/chapter6.rpy:2188
translate japanese ecg13_label_ed55a362:

    # 나 "“어라, 벌써 도착했구나.”"
    나 "「あれ、もう着いたのか。」"

# game/chapter6.rpy:2190
translate japanese ecg13_label_6af199ec:

    # "목적지로 설정해둔 사거리에 도착하자 호버크라프트의 출입문이 열리고, 나는 익숙한 풍경의 거리를 둘러보았다. "
    "目的地に設定しておいた十字路に着くとホバークラフトの扉が開き、俺は見慣れた風景の街を見渡した。"

# game/chapter6.rpy:2191
translate japanese ecg13_label_afd23e2a:

    # "여전히 새근새근 잠들어 있는 소녀를 흔들어 깨워보려 했지만, 소녀는 힘없이 시트에 몸을 맡길 뿐 잠에서 깨어날 기미가 보이지 않았다. "
    "すやすやと眠り続ける少女を揺り起こそうとしたが、少女は力なくシートに身を預けるばかりで目覚める気配がなかった。"

# game/chapter6.rpy:2193
translate japanese ecg13_label_1614a9b9:

    # 나 "“…… 많이 힘들었는지, 일어날 생각을 안 하네.”"
    나 "「……よほど疲れていたのか、起きる気配がないな。」"

# game/chapter6.rpy:2197
translate japanese ecg13_label_1a18bc88:

    # voice "voices/yf145.ogg"
    # 유미 "“그럼 집 앞까지 타고 갈래? 내가 여기 내려서 걸어갈게.”"
    voice "voices/yf145.ogg"
    유미 "「じゃあ家の前まで乗っていく？ 私はここで降りて歩くから。」"

# game/chapter6.rpy:2199
translate japanese ecg13_label_f9de1a4e:

    # voice ""
    # 나 "“아, 아냐. 그럴 필요 없어.”"
    voice ""
    나 "「あ、いや。そこまでしなくていいよ。」"

# game/chapter6.rpy:2202
translate japanese ecg13_label_041a4cc9:

    # "유미의 말에 손사래를 친 나는 미동조차 하지 않는 소녀를 조심스레 업어 들었다. "
    "ユミの言葉に手を振った俺は、微動だにしない少女をそっと背負い上げた。"

# game/chapter6.rpy:2203
translate japanese ecg13_label_27af8a57:

    # "그러고는 잘 가라는 인사를 건네려다 말고, 잠시 행동을 멈춘 채 유미의 얼굴을 응시했다. "
    "そうしてじゃあなと挨拶をしようとして、ふと動きを止めてユミの顔を見つめた。"

# game/chapter6.rpy:2207
translate japanese ecg13_label_d6ba7654:

    # voice "voices/yf146.ogg"
    # 유미 "“응? 왜 그래?”"
    voice "voices/yf146.ogg"
    유미 "「ん？ どうしたの？」"

# game/chapter6.rpy:2210
translate japanese ecg13_label_ed21913f:

    # voice ""
    # 나 "“…… 매번 고마워.”"
    voice ""
    나 "「……いつもありがとう。」"

# game/chapter6.rpy:2213
translate japanese ecg13_label_0b3b678b:

    # voice "voices/yf147.ogg"
    # 유미 "“뭐야, 부끄럽게 그런 인사는.”"
    voice "voices/yf147.ogg"
    유미 "「もう、照れちゃうようなこと言わないでよ。」"

# game/chapter6.rpy:2215
translate japanese ecg13_label_f7e4e4b2:

    # voice ""
    # 나 "“으음…… 그래야 할 거 같아서 말야.”"
    voice ""
    나 "「うーん……言っておくべきだと思ってさ。」"

# game/chapter6.rpy:2221
translate japanese ecg13_label_ed6225ce:

    # "대답 대신, 유미는 나를 향해 입꼬리를 싱긋 올려 주었다. "
    "答えの代わりに、ユミは俺に向かって口角をにっと上げてくれた。"

# game/chapter6.rpy:2223
translate japanese ecg13_label_c092636b:

    # voice "voices/yf148.ogg"
    # 유미 "“잘 가.”"
    voice "voices/yf148.ogg"
    유미 "「じゃあね。」"

# game/chapter6.rpy:2235
translate japanese ecg14_label_e9f725dd:

    # voice ""
    # "출입문이 닫히고, 나는 사라져가는 호버크라프트를 소녀를 업은 채 모습이 보이지 않을 때까지 바라보았다. "
    voice ""
    "扉が閉まり、俺は少女を背負ったまま、遠ざかるホバークラフトが見えなくなるまで見送った。"

# game/chapter6.rpy:2237
translate japanese ecg14_label_e42bae34:

    # "집으로 돌아가는 길. "
    "家へ帰る道。"

# game/chapter6.rpy:2238
translate japanese ecg14_label_35527011:

    # "하늘에 무수히 흩뿌려져 있던 별들은 어느새 거짓말처럼 사라져 규칙적으로 빛을 내리쬐는 가로등 불빛만이 길을 걷는 나를 비출 뿐이었다. "
    "空に無数に散りばめられていた星々はいつの間にか嘘のように消え、規則正しく光を放つ街灯だけが歩く俺を照らしていた。"

# game/chapter6.rpy:2239
translate japanese ecg14_label_93e90153:

    # "아무래도 좋았다. "
    "どうでもよかった。"

# game/chapter6.rpy:2240
translate japanese ecg14_label_bbc00e44:

    # "흔적으로만 어렴풋이 느낄 수 있었던 소녀의 존재를, 이렇게 눈으로, 피부로, 그리고 소리로 느낄 수 있게 되었으니까 말이다. "
    "痕跡としてかすかにしか感じられなかった少女の存在を、こうして目で、肌で、そして音で感じられるようになったのだから。"

# game/chapter6.rpy:2245
translate japanese ecg14_label_45454ea6:

    # "나의 등에 업혀 잠든 소녀의 숨소리가 귓가를 살살 간질였다. "
    "俺の背中で眠る少女の寝息が耳元をそっとくすぐった。"

# game/chapter6.rpy:2246
translate japanese ecg14_label_8fbb95f9:

    # "그 소리가 여느 음악의 선율보다 달콤하게 느껴져서였을까. "
    "その音がどんな音楽の旋律よりも甘く感じられたからだろうか。"

# game/chapter6.rpy:2247
translate japanese ecg14_label_5b2ee26b:

    # "나는 최대한 천천히, 발걸음을 늦추어 집으로 향하고 있었다. "
    "俺はできるだけゆっくりと、足取りを緩めて家へと向かっていた。"

# game/chapter6.rpy:2252
translate japanese ecg14_label_d9a1c71c:

    # voice "voices/gf32.ogg"
    # 소녀 "“으으으…….”"
    voice "voices/gf32.ogg"
    소녀 "「う、うぅ……」"

# game/chapter6.rpy:2254
translate japanese ecg14_label_96ee93d7:

    # voice ""
    # "달콤하게 들려오던 소녀의 숨소리가 파르르 떨리더니, 이내 불안한 불협화음을 만들어낸다. "
    voice ""
    "甘く聞こえていた少女の寝息がぶるぶると震え出し、やがて不安な不協和音を生み出す。"

# game/chapter6.rpy:2256
translate japanese ecg14_label_f06f6de5:

    # "나의 옷깃을 붙잡는 손길이 느껴졌다. "
    "俺の襟を掴む手の感触があった。"

# game/chapter6.rpy:2257
translate japanese ecg14_label_058d705f:

    # "떨리는 숨결과 차가운 손길. "
    "震える吐息と冷たい手。"

# game/chapter6.rpy:2261
translate japanese ecg14_label_7e672dd9:

    # "이런 비슷한 상황을 언젠가 마주한 적이 있었기에, 나는 천천히 익숙한 음을 읊조렸다. "
    "こんな似たような状況にいつか出くわしたことがあったから、俺はゆっくりと馴染みのある旋律を口ずさんだ。"

# game/chapter6.rpy:2262
translate japanese ecg14_label_8607dfcd:

    # "뭐든지 괜찮아질 거라는. "
    "何もかも大丈夫になると。"

# game/chapter6.rpy:2263
translate japanese ecg14_label_74cbc564:

    # "그런 의미의 선율을 말이다. "
    "そんな意味の旋律を。"

# game/chapter6.rpy:2271
translate japanese ecg14_label_5f4d3435:

    # "허밍을 하다 말고 위화감을 느끼고선 뒤를 돌아보았을 땐, 언제부턴가 눈을 동그랗게 뜨고 있던 소녀가 나를 빤히 바라보고 있었다. "
    "ハミングの途中でふと違和感を覚えて振り返ると、いつからか目を丸く開いていた少女が俺をじっと見つめていた。"

# game/chapter6.rpy:2272
translate japanese ecg14_label_19d4e899:

    # "나와 눈이 마주친 소녀의 얼굴에 붉은 색채가 맴돌기 시작했다. "
    "俺と目が合った少女の顔に赤みが差し始めた。"

# game/chapter6.rpy:2273
translate japanese ecg14_label_14b64b2b:

    # "옷자락 속으로 얼굴을 파묻고선 표정을 숨긴 소녀가, 그녀답지 않은 투로 더듬대며 말을 꺼냈다. "
    "服の裾に顔を埋めて表情を隠した少女が、彼女らしくない口調でたどたどしく話し始めた。"

# game/chapter6.rpy:2275
translate japanese ecg14_label_c07c5bdf:

    # voice "voices/gf33.ogg"
    # 소녀 "“내, 내려오겠다고 말하려고 했는데, 너무 편안해서 그만…….”"
    voice "voices/gf33.ogg"
    소녀 "「お、降りますって言おうとしたんですけど、あんまり心地よくてつい……」"

# game/chapter6.rpy:2277
translate japanese ecg14_label_f940b311:

    # voice ""
    # 나 "“괜찮아. 내 입장에선 오히려 이대로 집까지 업혀 갔으면 하는걸.”"
    voice ""
    나 "「いいよ。俺としてはむしろこのまま家まで背負って行きたいくらいだし。」"

# game/chapter6.rpy:2280
translate japanese ecg14_label_88f14711:

    # voice "voices/gf34.ogg"
    # 소녀 "“…… 정말요? 무겁진 않아요?”"
    voice "voices/gf34.ogg"
    소녀 "「……本当ですか？ 重くないですか？」"

# game/chapter6.rpy:2282
translate japanese ecg14_label_a5efab09:

    # voice ""
    # 나 "“전혀.”"
    voice ""
    나 "「全然。」"

# game/chapter6.rpy:2285
translate japanese ecg14_label_627cb035:

    # "나는 다시 천천히 발걸음을 내디디며 허밍 소리를 중얼댔다. "
    "俺は再びゆっくりと歩き始めながらハミングを口ずさんだ。"

# game/chapter6.rpy:2286
translate japanese ecg14_label_6af82aaf:

    # "낡은 선율의 틈바구니로, 소녀의 목소리가 섞여든다. "
    "古びた旋律の隙間に、少女の声が混じり込む。"

# game/chapter6.rpy:2290
translate japanese ecg14_label_df81f914:

    # voice "voices/gf35.ogg"
    # 소녀 "“신기했어요. 당신과 만나고 난 이후로 언젠가부터 악몽을 꾸지 않게 되었거든요.”"
    voice "voices/gf35.ogg"
    소녀 "「不思議でした。あなたと出会ってからいつの頃からか、悪夢を見なくなっていたんです。」"

# game/chapter6.rpy:2292
translate japanese ecg14_label_96f5077c:

    # voice ""
    # "감상에 잠겼던 소녀가 옅은 웃음소리를 내뱉었다. "
    voice ""
    "感慨に浸っていた少女が薄い笑い声を漏らした。"

# game/chapter6.rpy:2296
translate japanese ecg14_label_8ce97d43:

    # voice "voices/gf36.ogg"
    # 소녀 "“그게 이 노래 덕분이었다니. 이제야 알았어요.”"
    voice "voices/gf36.ogg"
    소녀 "「それがこの歌のおかげだったなんて。今やっと分かりました。」"

# game/chapter6.rpy:2302
translate japanese ecg14_label_96a407d1:

    # voice ""
    # "그렇게 말하고선 소녀는 자신의 뺨을 내 어깨에 푹 기대었다. "
    voice ""
    "そう言って少女は自分の頬を俺の肩にぐっともたせかけた。"

# game/chapter6.rpy:2305
translate japanese ecg14_label_4786f3a9:

    # voice "voices/gf37.ogg"
    # 소녀 "“죄송해요. 여태껏 괜히 밤잠 설치게 해서.”"
    voice "voices/gf37.ogg"
    소녀 "「すみません。ずっと夜中に寝付けなくさせてしまって。」"

# game/chapter6.rpy:2307
translate japanese ecg14_label_3909e6a4:

    # voice ""
    # "대답 대신, 나는 아무 일도 없었다는 듯 연주를 계속해나갔다. "
    voice ""
    "答える代わりに、俺は何事もなかったかのように演奏を続けた。"

# game/chapter6.rpy:2309
translate japanese ecg14_label_8e3d377f:

    # "등에 닿는 그 감촉을 조금 더 느끼고 싶어서였을까. "
    "背中に触れるあの感触をもう少し味わいたかったからだろうか。"

# game/chapter6.rpy:2311
translate japanese ecg14_label_239dc52e:

    # "의식적으로 느려진 걸음걸이에, 아직 집까지는 한참이나 멀었을 텐데 기억 속의 선율이 끝을 보이고 있었다. "
    "意識的に遅くなった歩調に、まだ家までだいぶ遠いはずなのに記憶の中の旋律が終わりを見せ始めていた。"

# game/chapter6.rpy:2312
translate japanese ecg14_label_a6b13556:

    # "기억 속의 오르골이 연주를 끝마쳐갈 무렵, 다시 한번 소녀의 목소리가 섞여들었다. "
    "記憶の中のオルゴールが演奏を終えようとする頃、再び少女の声が混じり込んだ。"

# game/chapter6.rpy:2314
translate japanese ecg14_label_bc188413:

    # voice "voices/gf38.ogg"
    # 소녀 "“잘은 모르겠지만, 목소리에 온도가 있다면 이런 느낌일까요.”"
    voice "voices/gf38.ogg"
    소녀 "「よく分からないんですけど、声に温度があるとしたらこんな感じなのでしょうか。」"

# game/chapter6.rpy:2316
translate japanese ecg14_label_4ee92209:

    # voice ""
    # "소녀는 그 따스함을 만끽하려는 건지 나의 등어리에 조금 더 자신의 무게를 실었다. "
    voice ""
    "少女はその温もりを満喫しようとするかのように、俺の背中にもう少し自分の体重を預けた。"

# game/chapter6.rpy:2319
translate japanese ecg14_label_8eb5ed57:

    # voice "voices/gf39.ogg"
    # 소녀 "“따뜻해요.”"
    voice "voices/gf39.ogg"
    소녀 "「温かいです。」"

# game/chapter6.rpy:2324
translate japanese ecg14_label_160ccb23:

    # voice ""
    # "흥얼대던 허밍에 마침표가 찍히고, 조금씩 속도를 잃어가던 발걸음이 움직임을 멈춘다. "
    voice ""
    "口ずさんでいたハミングに終止符が打たれ、少しずつ速度を失っていた足取りが動きを止める。"

# game/chapter6.rpy:2327
translate japanese ecg14_label_7530018e:

    # 나 "“저기, 있잖아.”"
    나 "「あのさ。」"

# game/chapter6.rpy:2329
translate japanese ecg14_label_67fe732f:

    # "나의 목소리를 듣고선, 등에 파묻혀 있던 소녀가 고개를 살며시 들었다. "
    "俺の声を聞いて、背中に埋もれていた少女がそっと顔を上げた。"

# game/chapter6.rpy:2330
translate japanese ecg14_label_aa39dfbd:

    # "등 뒤에서 느껴지는 소녀의 시선이 나의 목덜미를 간지럽힌다. "
    "背後から感じる少女の視線が俺のうなじをくすぐる。"

# game/chapter6.rpy:2331
translate japanese ecg14_label_04a16fd0:

    # "숨을 가볍게 들이키고는, 나는 소녀에게 나지막이 목소리를 전했다. "
    "軽く息を吸い込んでから、俺は少女に低い声で告げた。"

# game/chapter6.rpy:2333
translate japanese ecg14_label_f3585d29:

    # 나 "“내가 실은 과거에서 왔다고 한다면, 믿어줄 수 있겠어?”"
    나 "「俺が実は過去から来たって言ったら、信じてくれるか？」"

# game/chapter6.rpy:2334
translate japanese ecg14_label_9942a2d1:

    # voice "voices/gf40.ogg"
    # 소녀 "“긴장했잖아요. 무서운 비밀이라도 털어놓는 줄 알고.”"
    voice "voices/gf40.ogg"
    소녀 "「緊張しちゃったじゃないですか。怖い秘密でも打ち明けるのかと思って。」"

# game/chapter6.rpy:2336
translate japanese ecg14_label_a3b9e89f:

    # voice ""
    # 나 "“무서운 비밀이라니…….”"
    voice ""
    나 "「怖い秘密って……」"

# game/chapter6.rpy:2341
translate japanese ecg14_label_598f19e4:

    # voice "voices/gf41.ogg"
    # 소녀 "“사람을 죽였다거나, 하는 거 말이에요.”"
    voice "voices/gf41.ogg"
    소녀 "「人を殺したとか、そういうことです。」"

# game/chapter6.rpy:2343
translate japanese ecg14_label_37bd1014:

    # voice ""
    # 나 "“…… 그런 농담, 재미없거든.”"
    voice ""
    나 "「……そういう冗談、面白くないから。」"

# game/chapter6.rpy:2346
translate japanese ecg14_label_b994beb4:

    # voice "voices/gf42.ogg"
    # 소녀 "“그런가요.”"
    voice "voices/gf42.ogg"
    소녀 "「そうですか。」"

# game/chapter6.rpy:2348
translate japanese ecg14_label_44de1613:

    # voice ""
    # "자조 섞인 한숨 소리가 들려오고, 소녀는 다시 나의 등 속으로 얼굴을 파묻었다. "
    voice ""
    "自嘲混じりのため息が聞こえ、少女は再び俺の背中に顔を埋めた。"

# game/chapter6.rpy:2351
translate japanese ecg14_label_ec1e4817:

    # voice "voices/gf43.ogg"
    # 소녀 "“그런데 왜 여태껏 그런 이야기 안 해줬던 건가요?”"
    voice "voices/gf43.ogg"
    소녀 "「ところで、どうして今まで話してくれなかったんですか？」"

# game/chapter6.rpy:2353
translate japanese ecg14_label_0449391a:

    # voice ""
    # 나 "“이야기할 틈이 없었던 거야. 딱히 이야기하지 않아도 괜찮을 거라 생각했었으니까.”"
    voice ""
    나 "「話す隙がなかったんだよ。別に話さなくても大丈夫だと思ってたから。」"

# game/chapter6.rpy:2355
translate japanese ecg14_label_e2ca3784:

    # voice "voices/gf44.ogg"
    # 소녀 "“그렇겠네요.”"
    voice "voices/gf44.ogg"
    소녀 "「そうですね。」"

# game/chapter6.rpy:2357
translate japanese ecg14_label_14908f79:

    # voice ""
    # "조금은 불만스러움을 표하던 소녀는 이내 내 말에 수긍하고선 자신의 턱을 내 왼편 어깨에 기댔다. "
    voice ""
    "少し不満げだった少女はやがて俺の言葉に納得して、自分の顎を俺の左肩にもたせかけた。"

# game/chapter6.rpy:2359
translate japanese ecg14_label_b811086c:

    # "밀착된 소녀의 시선이 그대로 나의 뺨을 쿡쿡 찔러댔다. "
    "密着した少女の視線がそのまま俺の頬をつんつんとつついた。"

# game/chapter6.rpy:2361
translate japanese ecg14_label_9dca9e2d:

    # voice "voices/gf45.ogg"
    # 소녀 "“시간여행이라면, 타임머신이라도 타고 온 건가요?”"
    voice "voices/gf45.ogg"
    소녀 "「時間旅行なら、タイムマシンにでも乗ってきたんですか？」"

# game/chapter6.rpy:2363
translate japanese ecg14_label_b010f649:

    # voice ""
    # 나 "“그런 건 없어. 시간여행을 한 건, 내 영혼뿐이었거든.”"
    voice ""
    나 "「そんなものはない。時間旅行をしたのは、俺の魂だけだったから。」"

# game/chapter6.rpy:2365
translate japanese ecg14_label_125962de:

    # voice "voices/gf46.ogg"
    # 소녀 "“영혼이요?”"
    voice "voices/gf46.ogg"
    소녀 "「魂ですか？」"

# game/chapter6.rpy:2367
translate japanese ecg14_label_e56f05fc:

    # voice ""
    # 나 "“으응, 아마도.”"
    voice ""
    나 "「うん、たぶん。」"

# game/chapter6.rpy:2370
translate japanese ecg14_label_22b7a5c6:

    # "오른쪽으로 살짝 시선을 틀었지만, 이번엔 소녀의 시선이 나의 목덜미를 찔러댔다. "
    "右に少し視線を向けたが、今度は少女の視線が俺のうなじを刺した。"

# game/chapter6.rpy:2371
translate japanese ecg14_label_b2daedcd:

    # "새까만 밤하늘을 응시하며, 나는 이야기를 이어갔다. "
    "真っ暗な夜空を見つめながら、俺は話を続けた。"

# game/chapter6.rpy:2373
translate japanese ecg14_label_42ff4820:

    # 나 "“잘은 모르겠지만, 유체이탈 같은 거라고 생각했어. 왜, 그런 거 있잖아. 영화 같은 데서 두 사람의 몸이 바뀐다거나 하는 일 말이야.”"
    나 "「よく分からないけど、幽体離脱みたいなものだと思ったんだ。ほら、あるだろ。映画とかで二人の体が入れ替わるとかっていうやつ。」"

# game/chapter6.rpy:2374
translate japanese ecg14_label_8e649c1c:

    # voice "voices/gf47.ogg"
    # 소녀 "“음…… 그래서 제가 유령이라는 말을 단번에 믿었던 거네요.”"
    voice "voices/gf47.ogg"
    소녀 "「ふむ……だから私が幽霊だっていう話をすぐに信じたんですね。」"

# game/chapter6.rpy:2376
translate japanese ecg14_label_a290bd8b:

    # voice ""
    # 나 "“맞아. 영혼이 있을 거라고 짐작했으니까.”"
    voice ""
    나 "「ああ。魂があるだろうと推測してたから。」"

# game/chapter6.rpy:2379
translate japanese ecg14_label_e7a2ba30:

    # "막연하게 시작되었던 이야기는 어느새 풀어둔 실타래를 따라 미궁의 출구로 향하듯 자연스레 이어져가고 있었다. "
    "漠然と始まった話はいつの間にかほどけた糸を辿って迷宮の出口へ向かうように自然と続いていた。"

# game/chapter6.rpy:2383
translate japanese ecg14_label_c9208b99:

    # 나 "“너를 없앨 수 있을지도 모르겠다고 이야기했던 그 텔레이도스코프란 기계도, 원래는 나를 과거로 돌려보내기 위한 기계였어. 아무래도 이젠 그 기계로 너를 없애는 건 어려워 보이지만.”"
    나 "「お前を消せるかもしれないと話したあのテレイドスコープという機械も、本来は俺を過去に送り返すための機械だったんだ。どうやらもうあの機械でお前を消すのは難しそうだけど。」"

# game/chapter6.rpy:2384
translate japanese ecg14_label_42333a74:

    # voice "voices/gf48.ogg"
    # 소녀 "“과거로 돌아가야 하는 거군요.”"
    voice "voices/gf48.ogg"
    소녀 "「過去に帰らなければならないんですね。」"

# game/chapter6.rpy:2386
translate japanese ecg14_label_13183728:

    # voice ""
    # 나 "“…… 언젠간.”"
    voice ""
    나 "「……いつかは。」"

# game/chapter6.rpy:2389
translate japanese ecg14_label_2cd19a40:

    # "대답을 유보하려는 듯한 애매한 한 마디였다. "
    "答えを保留するような曖昧な一言だった。"

# game/chapter6.rpy:2391
translate japanese ecg14_label_28bbbf25:

    # 나 "“이곳에 온 뒤로부터 줄곧 환청처럼 누군가의 목소리가 들려왔어. 너를 만나기 전부터, 그리고 너를 만나고 난 이후로도.”"
    나 "「ここに来てからずっと幻聴のように誰かの声が聞こえていたんだ。お前に会う前から、そしてお前に会った後も。」"

# game/chapter6.rpy:2392
translate japanese ecg14_label_e9d5bd82:

    # voice "voices/gf49.ogg"
    # 소녀 "“어떤 목소리였나요?”"
    voice "voices/gf49.ogg"
    소녀 "「どんな声だったんですか？」"

# game/chapter6.rpy:2394
translate japanese ecg14_label_bf1a144e:

    # voice ""
    # 나 "“글쎄…… 그건 아직도 잘 모르겠어. 그렇지만 그 목소리들이, 분명 너와 연결되어 있었다고 한다면. 이것도 믿어줄 수 있을까?”"
    voice ""
    나 "「さあ……それはまだよく分からない。でもその声が、確かにお前と繋がっていたと言ったら。信じてくれるか？」"

# game/chapter6.rpy:2397
translate japanese ecg14_label_aa01f1ab:

    # voice "voices/gf50.ogg"
    # 소녀 "“…… 저랑요?”"
    voice "voices/gf50.ogg"
    소녀 "「……私とですか？」"

# game/chapter6.rpy:2400
translate japanese ecg14_label_b57ea59c:

    # voice ""
    # "고개를 뒤로 돌리자, 그대로 소녀와 시선이 마주친다. "
    voice ""
    "振り返ると、そのまま少女と目が合った。"

# game/chapter6.rpy:2403
translate japanese ecg14_label_b45db9c0:

    # "잠시 생각에 잠겨 눈을 깜빡이던 소녀가, 넌지시 내게 말을 건넸다. "
    "しばし物思いに沈んで瞬きをしていた少女が、そっと俺に話しかけた。"

# game/chapter6.rpy:2405
translate japanese ecg14_label_480199ab:

    # voice "voices/gf51.ogg"
    # 소녀 "“목소리가 저와 연결되어 있다는 건, 비유적인 표현이겠죠?”"
    voice "voices/gf51.ogg"
    소녀 "「声が私と繋がっているというのは、比喩的な表現ですよね？」"

# game/chapter6.rpy:2407
translate japanese ecg14_label_8bdab4cb:

    # voice ""
    # 나 "“아니, 말 그대로야. 네가 죽음의 색을 볼 수 있는 것처럼, 나는 환청처럼 들려오는 그 목소리를 볼 수 있었어.”"
    voice ""
    나 "「いや、文字通りだよ。お前が死の色を見ることができるように、俺は幻聴のように聞こえるその声を見ることができたんだ。」"

# game/chapter6.rpy:2410
translate japanese ecg14_label_a11d5650:

    # "예상 밖의 대답이었는지, 소녀의 고개가 양옆으로 갸웃댔다. "
    "予想外の答えだったのか、少女の首が左右にかしげた。"

# game/chapter6.rpy:2412
translate japanese ecg14_label_01d7ab81:

    # 나 "“혹시 모르지. 나 혼자만의 망상이거나 착각이었을 수도 있겠지만…….”"
    나 "「もしかしたら、俺だけの妄想か思い違いだったのかもしれないけど……」"

# game/chapter6.rpy:2414
translate japanese ecg14_label_c5fe839d:

    # "기억을 되짚었다. "
    "記憶をたどった。"

# game/chapter6.rpy:2415
translate japanese ecg14_label_6bc90d35:

    # "착각이었다기엔 너무나도 생생한 목소리들이 머릿속에 하나둘씩 그려졌다. "
    "思い違いにしてはあまりに生々しい声が、頭の中に一つまた一つと浮かんできた。"

# game/chapter6.rpy:2421
translate japanese ecg14_label_0284530b:

    # 나 "“내게 보이던 그 목소리는, 헝클어진 털실 모양이었어. 너를 만나기 전까진.”"
    나 "「俺に見えていたあの声は、絡まった毛糸のような形だった。お前に会う前まではな。」"

# game/chapter6.rpy:2423
translate japanese ecg14_label_8e4afeba:

    # "소녀의 대답은 들려오지 않았다. "
    "少女の返事は聞こえなかった。"

# game/chapter6.rpy:2424
translate japanese ecg14_label_fbdae232:

    # "그 대신, 나의 이야기를 조금 더 편안히 경청하려는지 소녀의 턱이 나의 어깨에 사뿐히 닿았다. "
    "その代わり、俺の話をもう少し楽に聞こうとしているのか、少女の顎が俺の肩にそっと触れた。"

# game/chapter6.rpy:2428
translate japanese ecg14_label_c5704aca:

    # 나 "“그리고 너를 만나고 난 뒤로부터, 갈 곳 없이 헝클어져 있던 그 목소리가, 마치 너를 위해 준비되어 있던 붉은 실처럼 네게로 이어졌고…… 이렇게 이야기하니까 정말 거짓말 같네.”"
    나 "「そしてお前に会ってからは、行き場なく絡まっていたあの声が、まるでお前のために用意されていた赤い糸のようにお前へと繋がっていって……こうやって話すと本当に嘘みたいだな。」"

# game/chapter6.rpy:2430
translate japanese ecg14_label_ee9817ed:

    # "머쓱함을 숨기지 못하고, 나는 그만 어색한 웃음을 지어 보였다. "
    "気恥ずかしさを隠しきれず、俺はつい気まずい笑みを浮かべてしまった。"

# game/chapter6.rpy:2432
translate japanese ecg14_label_7a7a8f40:

    # voice "voices/gf52.ogg"
    # 소녀 "“그럼, 혹시 지금도 그 목소리가 보이나요?”"
    voice "voices/gf52.ogg"
    소녀 "「じゃあ、もしかして今もその声が見えるんですか？」"

# game/chapter6.rpy:2434
translate japanese ecg14_label_5c898ace:

    # voice ""
    # 나 "“아니. 지금은 안 보여.”"
    voice ""
    나 "「いいや。今は見えない。」"

# game/chapter6.rpy:2437
translate japanese ecg14_label_732fe166:

    # "오직 나의 귓가에서 속삭이듯 들려오는 소녀의 음성만이, 지금 내가 들을 수 있는 유일한 소리였다. "
    "ただ耳元でささやくように聞こえてくる少女の声だけが、今俺に聞こえる唯一の音だった。"

# game/chapter6.rpy:2439
translate japanese ecg14_label_a13288ef:

    # 나 "“처음으로 네게 그 목소리가 연결됐던 건 아마 화재 사건을 조사하러 갔을 때였을 거야. 그땐 목소리가 너와 이어진다고는 상상도 못 했는데…….”"
    나 "「初めてお前にあの声が繋がったのは、たぶん火災事件を調べに行ったときだと思う。あのときは声がお前と繋がるなんて想像もできなかったけど……」"

# game/chapter6.rpy:2441
translate japanese ecg14_label_de5e6f77:

    # voice "voices/gf53.ogg"
    # 소녀 "“다음번에도 저와 목소리가 이어졌던 거군요.”"
    voice "voices/gf53.ogg"
    소녀 "「次のときも私と声が繋がっていたんですね。」"

# game/chapter6.rpy:2443
translate japanese ecg14_label_b7f9aa3a:

    # voice ""
    # "무언가 알고 있기라도 한 것처럼, 소녀는 중얼댔다. "
    voice ""
    "何か知っているかのように、少女はつぶやいた。"

# game/chapter6.rpy:2446
translate japanese ecg14_label_2e62dbc2:

    # 나 "“맞아. 너랑 같이 학교 옥상에 올라갔을 때. 그날에서야 그 목소리가 너와 이어지고 있었다는 걸 알게 된 거지.”"
    나 "「ああ。お前と一緒に学校の屋上に上がったとき。あの日になってようやく、あの声がお前と繋がっていたことに気づいたんだ。」"

# game/chapter6.rpy:2447
translate japanese ecg14_label_34e15814:

    # voice "voices/gf54.ogg"
    # 소녀 "“…… 그랬군요.”"
    voice "voices/gf54.ogg"
    소녀 "「……そうだったんですね。」"

# game/chapter6.rpy:2449
translate japanese ecg14_label_78b4aef4:

    # voice ""
    # 나 "“정말, 이렇게 말하고 나니까 나 혼자 헛것이라도 본 것 같잖아.”"
    voice ""
    나 "「本当に、こうやって話してみると俺だけ幻でも見ていたみたいだよな。」"

# game/chapter6.rpy:2452
translate japanese ecg14_label_421124af:

    # "차라리 말도 안 되는 이야기 하지 말라는 반응을 보였다면, 훨씬 더 사실처럼 느껴지지 않았을까. "
    "そんなでたらめな話はやめてくれとあしらわれた方が、よっぽど真実味があったのではないだろうか。"

# game/chapter6.rpy:2453
translate japanese ecg14_label_096a27a0:

    # "그저 소녀가 나의 말을 조용히 듣고만 있는 이 상황이, 오히려 너무나도 비현실적이게만 와닿았다. "
    "ただ少女が俺の話を静かに聞いているだけのこの状況が、かえってあまりに非現実的に感じられた。"

# game/chapter6.rpy:2455
translate japanese ecg14_label_51d2bf26:

    # voice "voices/gf55.ogg"
    # 소녀 "“아니에요. 그건 분명…… 헛것이 아니었을 거예요.”"
    voice "voices/gf55.ogg"
    소녀 "「いいえ。それはきっと……幻なんかじゃなかったはずです。」"

# game/chapter6.rpy:2457
translate japanese ecg14_label_a58fa13e:

    # voice ""
    # 나 "“…… 어째서?”"
    voice ""
    나 "「……どうして？」"

# game/chapter6.rpy:2459
translate japanese ecg14_label_52019eca:

    # voice "voices/gf56.ogg"
    # 소녀 "“그건…….”"
    voice "voices/gf56.ogg"
    소녀 "「それは……」"

# game/chapter6.rpy:2461
translate japanese ecg14_label_a75311fb:

    # voice ""
    # "다시금, 소녀의 목소리가 들려오지 않았다. "
    voice ""
    "再び、少女の声が聞こえなくなった。"

# game/chapter6.rpy:2463
translate japanese ecg14_label_ae45f745:

    # "나의 발걸음 소리만이 침묵의 틈을 메운다. "
    "俺の足音だけが沈黙の隙間を埋めていく。"

# game/chapter6.rpy:2464
translate japanese ecg14_label_3c7e4c3d:

    # "일정한 박자를 이루던 발걸음 소리가 집 앞에 도착해 느린 템포로 변해가기 시작할 무렵. "
    "一定のリズムを刻んでいた足音が家の前に着いて緩やかなテンポに変わり始めた頃。"

# game/chapter6.rpy:2465
translate japanese ecg14_label_126934cb:

    # "그 느려진 박자에 소녀의 목소리가 덧대진다. "
    "その遅くなったリズムに少女の声が重なる。"

# game/chapter6.rpy:2467
translate japanese ecg14_label_8a864519:

    # voice "voices/gf57.ogg"
    # 소녀 "“저는 어쩌면 당신이 생각하는 것보다 기대 이하의 사람이었던 걸지도 몰라요.”"
    voice "voices/gf57.ogg"
    소녀 "「私はもしかしたら、あなたが思っているよりずっと期待外れな人間だったのかもしれません。」"

# game/chapter6.rpy:2469
translate japanese ecg14_label_323c8b12:

    # voice ""
    # 나 "“갑자기 그게 무슨 말이야.”"
    voice ""
    나 "「急にどういう意味だよ。」"

# game/chapter6.rpy:2471
translate japanese ecg14_label_2cdf4773:

    # voice "voices/gf58.ogg"
    # 소녀 "“늦었지만, 지금이라도 고백할 게 하나 있어요.”"
    voice "voices/gf58.ogg"
    소녀 "「遅くなりましたけど、隠してたことが一つあるんです。」"

# game/chapter6.rpy:2473
translate japanese ecg14_label_ac8cafd3:

    # voice ""
    # "무덤덤한 목소리와 대조되는 떨리는 손길이 나의 옷자락을 부여잡는다. "
    voice ""
    "淡々とした声とは対照的に震える手が俺の裾を握りしめる。"

# game/chapter6.rpy:2475
translate japanese ecg14_label_c09213ba:

    # "발걸음 소리가 멈추고, 나는 소녀를 향해 슬쩍 고개를 돌렸다. "
    "足音が止まり、俺は少女のほうへそっと顔を向けた。"

# game/chapter6.rpy:2477
translate japanese ecg14_label_6ea42e98:

    # voice "voices/gf59.ogg"
    # 소녀 "“언젠가 저의 집에 불이 났었다고 했었죠.”"
    voice "voices/gf59.ogg"
    소녀 "「以前、私の家が火事になったと話しましたよね。」"

# game/chapter6.rpy:2480
translate japanese ecg14_label_b9656b66:

    # voice ""
    # 나 "“응, 그랬었지.”"
    voice ""
    나 "「ああ、そうだったな。」"

# game/chapter6.rpy:2483
translate japanese ecg14_label_c215e036:

    # voice "voices/gf60.ogg"
    # 소녀 "“그리고 누군가가, 저를 구해줬다고도 말했었죠.”"
    voice "voices/gf60.ogg"
    소녀 "「そして誰かが、私を助けてくれたとも言いましたよね。」"

# game/chapter6.rpy:2485
translate japanese ecg14_label_ec29ec04:

    # voice ""
    # "나는 고개를 끄덕였다. "
    voice ""
    "俺は頷いた。"

# game/chapter6.rpy:2490
translate japanese ecg14_label_81b6c90c:

    # voice "voices/gf61.ogg"
    # 소녀 "“살아있었을 적의 저는, 원망하고 있었어요. 저를 구해줬던 그 사람을요.”"
    voice "voices/gf61.ogg"
    소녀 "「生きていた頃の私は、恨んでいたんです。私を助けてくれたその人を。」"

# game/chapter6.rpy:2492
translate japanese ecg14_label_b78f6bba:

    # voice ""
    # "감정을 배제하려는 듯한 소녀의 목소리는 굴곡 없이 나의 귓가를 맴돌았지만, 그녀의 손은 그렇지 못한 모양이었다. "
    voice ""
    "感情を排除しようとするかのような少女の声は起伏なく俺の耳に漂っていたが、彼女の手はそうもいかないようだった。"

# game/chapter6.rpy:2494
translate japanese ecg14_label_ff9d40a5:

    # "소녀의 손길이, 나의 옷자락 속으로 점점 더 깊이 파고드는 것이 느껴졌다. "
    "少女の手が、俺の裾の中へとどんどん深く食い込んでいくのが感じられた。"

# game/chapter6.rpy:2497
translate japanese ecg14_label_fc88875f:

    # voice "voices/gf62_1.ogg"
    # 소녀 "“불이 났던 그때, 저는 사실 눈을 떴었어요. 하지만 어째서인지, 밖으로 나가야겠다는 생각도, 가족을 구해야겠다는 생각도 하지 않았던 모양이에요.”"
    voice "voices/gf62_1.ogg"
    소녀 "「火事が起きたあのとき、実は私、目を開けていたんです。でもなぜか、外に出なきゃとも、家族を助けなきゃとも思ってなかったみたいなんです。」"

# game/chapter6.rpy:2499
translate japanese ecg14_label_302c91b7:

    # voice "voices/gf62_2.ogg"
    # 소녀 "“아니, 하지 않았어요.”"
    voice "voices/gf62_2.ogg"
    소녀 "「いいえ、思わなかったんです。」"

# game/chapter6.rpy:2501
translate japanese ecg14_label_65fb1bb6:

    # voice ""
    # "처음이었다. "
    voice ""
    "初めてだった。"

# game/chapter6.rpy:2503
translate japanese ecg14_label_fa530265:

    # "소녀가, 자신을 이야기 속에 담은 건. "
    "少女が、自分自身を物語の中に入れたのは。"

# game/chapter6.rpy:2505
translate japanese ecg14_label_4431ea08:

    # voice "voices/gf63.ogg"
    # 소녀 "“그리고 그냥 그 자리에서, 눈을 감아버린 거죠. 이대로 끝났으면 좋겠다고 생각하면서 말이에요.”"
    voice "voices/gf63.ogg"
    소녀 "「そしてただあの場で、目を閉じてしまったんです。このまま終わればいいのにって思いながら。」"

# game/chapter6.rpy:2507
translate japanese ecg14_label_46e9bc53:

    # voice ""
    # "스치듯 지나가는 침묵 뒤로, 소녀의 말이 이어진다. "
    voice ""
    "かすめるように過ぎる沈黙の後に、少女の言葉が続く。"

# game/chapter6.rpy:2510
translate japanese ecg14_label_492ea5f0:

    # voice "voices/gf64.ogg"
    # 소녀 "“이게 제가 그날 미처 말하지 못한 이야기의 뒷부분이에요.”"
    voice "voices/gf64.ogg"
    소녀 "「これが、あの日話しきれなかった物語の後半です。」"

# game/chapter6.rpy:2512
translate japanese ecg14_label_3b4d7aa7:

    # voice ""
    # 나 "“그날이라면…….”"
    voice ""
    나 "「あの日っていうのは……」"

# game/chapter6.rpy:2515
translate japanese ecg14_label_a382fc81:

    # voice "voices/gf65.ogg"
    # 소녀 "“맞아요. 화재 장소를 보러 갔던 그 날. 그곳에서 누군가가 저에게 속삭이는 듯한 목소리가 들렸어요.”"
    voice "voices/gf65.ogg"
    소녀 "「そうです。火災現場を見に行ったあの日。あそこで誰かが私にささやくような声が聞こえたんです。」"

# game/chapter6.rpy:2519
translate japanese ecg14_label_44ced7ea:

    # voice "voices/gf66.ogg"
    # 소녀 "“그 목소리가 그리는 선을 따라 밖으로 나왔을 땐, 실이 이어진 끝에 당신이 서 있었어요.”"
    voice "voices/gf66.ogg"
    소녀 "「その声が描く線を辿って外に出たとき、糸の先にあなたが立っていました。」"

# game/chapter6.rpy:2522
translate japanese ecg14_label_846f5575:

    # voice ""
    # "나를 바라보고선 홱 고개를 돌리던 소녀의 모습이, 머릿속에 떠올랐다. "
    voice ""
    "俺を見てとっさに顔を背けた少女の姿が、頭に浮かんだ。"

# game/chapter6.rpy:2525
translate japanese ecg14_label_cf33a857:

    # voice "voices/gf67.ogg"
    # 소녀 "“그 목소리엔, 제 기억이 담겨있었어요. 죽음의 색을 보고도 떠오르지 않던, 마치 어딘가에 숨겨 놓으려던 기억들이요.”"
    voice "voices/gf67.ogg"
    소녀 "「その声には、私の記憶が宿っていたんです。死の色を見ても思い出せなかった、まるでどこかに隠そうとしていた記憶が。」"

# game/chapter6.rpy:2527
translate japanese ecg14_label_9d5f448c:

    # voice ""
    # "퍼즐 조각이, 하나둘씩 맞춰지기 시작했다. "
    voice ""
    "パズルのピースが、一つまた一つと嵌まり始めた。"

# game/chapter6.rpy:2534
translate japanese ecg14_label_9b1e8774:

    # voice "voices/gf68.ogg"
    # 소녀 "“그리고 저는 그날부터, 그런 제 모습을 드러내기 무서워서 도망쳐버린 거고요.”"
    voice "voices/gf68.ogg"
    소녀 "「それで私はあの日から、そんな自分をさらけ出すのが怖くて逃げてしまったんです。」"

# game/chapter6.rpy:2536
translate japanese ecg14_label_60be048e:

    # voice ""
    # 나 "“죽지 못했다는 건, 그런 이야기였구나.”"
    voice ""
    나 "「死ねなかったっていうのは、そういう話だったんだな。」"

# game/chapter6.rpy:2539
translate japanese ecg14_label_00c53602:

    # voice "voices/gf69.ogg"
    # 소녀 "“무의식중에 드러난 진심이었어요.”"
    voice "voices/gf69.ogg"
    소녀 "「無意識のうちに出た本音でした。」"

# game/chapter6.rpy:2541
translate japanese ecg14_label_0dd58b7f:

    # voice ""
    # 나 "“자기를 살인마라고 그렇게 빨리 단정 지을 수 있었던 것도…….”"
    voice ""
    나 "「自分を人殺しだとあんなにすぐ決めつけられたのも……」"

# game/chapter6.rpy:2544
translate japanese ecg14_label_ff6950a9:

    # voice "voices/gf70.ogg"
    # 소녀 "“한심한 제 모습을, 누구보다 잘 알고 있었으니까요.”"
    voice "voices/gf70.ogg"
    소녀 "「情けない自分の姿を、誰よりもよく分かっていたからです。」"

# game/chapter6.rpy:2546
translate japanese ecg14_label_f4ae74cd:

    # voice ""
    # "소녀가 숨을 골랐다. "
    voice ""
    "少女が息を整えた。"

# game/chapter6.rpy:2552
translate japanese ecg14_label_1eb82fe4:

    # "따뜻하다는 단어를 떠올리고 싶었지만, 목덜미는 거짓말을 하지 못했다. "
    "温かいという言葉を思い浮かべたかったが、うなじは嘘をつけなかった。"

# game/chapter6.rpy:2554
translate japanese ecg14_label_117228f4:

    # voice "voices/gf71_1.ogg"
    # 소녀 "“안 그런 척하면서도, 미움받고 싶지 않았어요.”"
    voice "voices/gf71_1.ogg"
    소녀 "「そうじゃないふりをしながらも、嫌われたくなかったんです。」"

# game/chapter6.rpy:2558
translate japanese ecg14_label_fb0a2b60:

    # voice "voices/gf71_2.ogg"
    # 소녀 "“이런 이야기를 해버리면 정말 저를 혐오스러운 시선으로 바라볼까 봐, 겁났던 거예요.”"
    voice "voices/gf71_2.ogg"
    소녀 "「こんな話をしてしまったら本当に嫌悪の目で見られるんじゃないかって、怖かったんです。」"

# game/chapter6.rpy:2562
translate japanese ecg14_label_07540860:

    # voice "voices/gf71_3.ogg"
    # 소녀 "“언젠가 제 기억이 모두 돌아와 사라질 수 있게 되는 날, 그전까지만 잠시 거짓말을 하자.”"
    voice "voices/gf71_3.ogg"
    소녀 "「いつか記憶が全部戻って消えられる日が来るなら、それまでだけ少しの間嘘をつこう。」"

# game/chapter6.rpy:2565
translate japanese ecg14_label_4df4c7cc:

    # voice "voices/gf71_4.ogg"
    # 소녀 "“사라지게 되는 순간 모든 걸 털어놓고 볼품없이 사라져버리자.”"
    voice "voices/gf71_4.ogg"
    소녀 "「消えるその瞬間にすべてを打ち明けて、みっともなく消えてしまおう。」"

# game/chapter6.rpy:2567
translate japanese ecg14_label_4328dfdd:

    # voice "voices/gf71_5.ogg"
    # 소녀 "“그렇게 마음먹었는데……”"
    voice "voices/gf71_5.ogg"
    소녀 "「そう決めたのに……」"

# game/chapter6.rpy:2569
translate japanese ecg14_label_fc1ccfe6:

    # voice "voices/gf71_6.ogg"
    # 소녀 "“여태껏 당신이 준 따스함이 너무 기분 좋아서. 그래서 이런 짓을 해 버린 거라고 한다면, 너무 변명 같네요.”"
    voice "voices/gf71_6.ogg"
    소녀 "「今まであなたがくれた温もりがあまりに心地よくて。だからこんなことをしてしまったと言ったら、言い訳にしか聞こえませんよね。」"

# game/chapter6.rpy:2572
translate japanese ecg14_label_6ffce39c:

    # voice ""
    # 나 "“…… 학교 옥상에서는, 어떤 기억이 났었어?”"
    voice ""
    나 "「……学校の屋上では、どんな記憶が蘇ったの？」"

# game/chapter6.rpy:2575
translate japanese ecg14_label_04c8f36c:

    # "밤하늘을 바라보며 생각에 잠기는 소녀. "
    "夜空を見つめながら物思いに沈む少女。"

# game/chapter6.rpy:2576
translate japanese ecg14_label_9220bfc2:

    # "그날의 밤하늘과 오늘의 밤하늘은 닮은 구석이 많았던지, 소녀는 금세 떠올랐다는 듯 이야기를 이어갔다. "
    "あの日の夜空と今夜の夜空はよく似ていたのか、少女はすぐに思い出したように話を続けた。"

# game/chapter6.rpy:2578
translate japanese ecg14_label_11de66c4:

    # voice "voices/gf72.ogg"
    # 소녀 "“그날 보았던 여학생과 같은 말을, 저는 같은 곳에서 했던 모양이에요.”"
    voice "voices/gf72.ogg"
    소녀 "「あの日見た女の子生徒と同じ言葉を、私は同じ場所で言っていたみたいなんです。」"

# game/chapter6.rpy:2580
translate japanese ecg14_label_39f38ee5:

    # voice ""
    # 나 "“신기한 우연이네.”"
    voice ""
    나 "「不思議な偶然だな。」"

# game/chapter6.rpy:2582
translate japanese ecg14_label_a854b467:

    # voice "voices/gf73.ogg"
    # 소녀 "“…… 그러게요.”"
    voice "voices/gf73.ogg"
    소녀 "「……そうですね。」"

# game/chapter6.rpy:2584
translate japanese ecg14_label_fbc34029:

    # voice ""
    # 나 "“…… 그래서, 죽고 싶다는 생각을 옥상에서 했던 거야?”"
    voice ""
    나 "「……それで、死にたいって思って屋上に？」"

# game/chapter6.rpy:2586
translate japanese ecg14_label_559d236f:

    # voice "voices/gf74.ogg"
    # 소녀 "“누군가에게, 그곳에서 ‘죽고 싶어’라는 말을 했나 봐요.”"
    voice "voices/gf74.ogg"
    소녀 "「誰かに、あそこで「死にたい」って言ったみたいなんです。」"

# game/chapter6.rpy:2588
translate japanese ecg14_label_1fbf0303:

    # voice ""
    # 나 "“…….”"
    voice ""
    나 "「……」"

# game/chapter6.rpy:2591
translate japanese ecg14_label_84d9fa4c:

    # "무슨 이야기를 꺼내야 할까. "
    "何を言えばいいのだろう。"

# game/chapter6.rpy:2592
translate japanese ecg14_label_eec68830:

    # "갈피를 잡지 못하고 현관 앞에 멈춰 서서는 멀뚱히 숨을 죽이고 있는데, 등 뒤에서 중얼대는 소리가 들려왔다. "
    "見当がつかないまま玄関の前で立ち止まり、ぼんやりと息を殺していると、背中から小さくつぶやく声が聞こえた。"

# game/chapter6.rpy:2594
translate japanese ecg14_label_6a411ea6:

    # voice "voices/gf75.ogg"
    # 소녀 "“죽고 싶지 않아.”"
    voice "voices/gf75.ogg"
    소녀 "「死にたくない。」"

# game/chapter6.rpy:2596
translate japanese ecg14_label_510dc83a:

    # voice ""
    # "소녀의 목소리에, 희미한 색이 돈다. "
    voice ""
    "少女の声に、かすかな色が灯る。"

# game/chapter6.rpy:2599
translate japanese ecg14_label_73af3932:

    # voice "voices/gf76.ogg"
    # 소녀 "“…… 라고, 마지막엔 겁쟁이처럼 그렇게 이야기했지만요.”"
    voice "voices/gf76.ogg"
    소녀 "「……と、最後には臆病者みたいにそう言いましたけどね。」"

# game/chapter6.rpy:2602
translate japanese ecg14_label_f5a1de7b:

    # voice ""
    # "도어락에 손을 올려 문을 열고선 집 안으로 들어선다. "
    voice ""
    "ドアロックに手を乗せて扉を開け、家の中へ足を踏み入れる。"

# game/chapter6.rpy:2605
translate japanese ecg14_label_e81e8f0f:

    # voice "voices/gf77.ogg"
    # 소녀 "“따뜻한 목소리였어요.”"
    voice "voices/gf77.ogg"
    소녀 "「温かい声でした。」"

# game/chapter6.rpy:2607
translate japanese ecg14_label_8686440f:

    # voice ""
    # "집에 도착한 뒤였지만, 소녀는 나의 등에서 내려올 생각이 여전히 없어 보였다. "
    voice ""
    "家に着いた後だったが、少女は俺の背中から降りるつもりがまだないようだった。"

# game/chapter6.rpy:2610
translate japanese ecg14_label_a9bc36b2:

    # voice "voices/gf78.ogg"
    # 소녀 "“아마 저는, 그 따스한 목소리 덕분에 ‘살아 있어서 다행이다’라고 느꼈던 걸 거예요.”"
    voice "voices/gf78.ogg"
    소녀 "「たぶん私は、あの温かい声のおかげで「生きていてよかった」と感じたんだと思います。」"

# game/chapter6.rpy:2612
translate japanese ecg14_label_c37c73a3:

    # voice ""
    # 나 "“…… 다행이다.”"
    voice ""
    나 "「……よかった。」"

# game/chapter6.rpy:2615
translate japanese ecg14_label_49f4c909:

    # "소녀에게 들리지 않을 정도의 자그마한 목소리로, 나는 그녀가 했던 말을 중얼거렸다. "
    "少女には聞こえないほどの小さな声で、俺は彼女が言った言葉をつぶやいた。"

# game/chapter6.rpy:2616
translate japanese ecg14_label_256f6675:

    # "그러고는 그런 소녀를 응시했다. "
    "そうして、そんな少女を見つめた。"

# game/chapter6.rpy:2620
translate japanese ecg14_label_f233eb61:

    # voice "voices/gf79.ogg"
    # 소녀 "“지금은 이렇게, 죽어버리고 말았지만요.”"
    voice "voices/gf79.ogg"
    소녀 "「今はこうして、死んでしまいましたけどね。」"

# game/chapter6.rpy:2622
translate japanese ecg14_label_8096c2d3:

    # voice ""
    # 나 "“그랬구나.”"
    voice ""
    나 "「そうだったのか。」"

# game/chapter6.rpy:2624
translate japanese ecg14_label_0507d10f:

    # voice "voices/gf80.ogg"
    # 소녀 "“이런 제 모습, 되게 흉하고 한심하게 보이겠죠.”"
    voice "voices/gf80.ogg"
    소녀 "「こんな私の姿、すごく醜くて情けなく見えますよね。」"

# game/chapter6.rpy:2626
translate japanese ecg14_label_911ae337:

    # voice ""
    # "대답 대신, 나는 소녀에게 익숙한 웃음을 흘려 보일 뿐이었다. "
    voice ""
    "答えの代わりに、俺は少女にいつもの笑みを向けるだけだった。"

# game/chapter6.rpy:2629
translate japanese ecg14_label_d85fe289:

    # voice "voices/gf81.ogg"
    # 소녀 "“어쩌면 경멸할지도 모른다고 생각했어요. 당신의 등 위가 아니었다면, 이런 이야기 못 했을 거예요.”"
    voice "voices/gf81.ogg"
    소녀 "「軽蔑されるかもしれないと思っていました。あなたの背中の上じゃなかったら、こんな話できなかったと思います。」"

# game/chapter6.rpy:2631
translate japanese ecg14_label_d24fc5d0:

    # voice ""
    # "그런 한 마디와 함께, 소녀는 나의 등에서 스르륵 몸을 빼냈다. "
    voice ""
    "そんな一言とともに、少女は俺の背中からするりと体を離した。"

# game/chapter6.rpy:2638
translate japanese ecg14_label_c57a10c4:

    # 나 "“다행이야.”"
    나 "「よかった。」"

# game/chapter6.rpy:2639
translate japanese ecg14_label_fa2ef543:

    # 소녀 "“…….”"
    소녀 "「……」"

# game/chapter6.rpy:2640
translate japanese ecg14_label_d0bd782d:

    # 나 "“곁으로 돌아와 줘서.”"
    나 "「そばに、戻ってきてくれて。」"

# game/chapter6.rpy:2642
translate japanese ecg14_label_7d51f0c9:

    # "갈대가 쓰러지듯, 소녀는 나에게로 넘어지듯 안겨버려서는 엉켜있던 감정의 실을 몇 분에 걸쳐 풀어냈다. "
    "葦が倒れるように、少女は俺の方へ倒れ込むように抱きついて、絡まっていた感情の糸を数分かけてほどいていった。"

# game/chapter6.rpy:2643
translate japanese ecg14_label_eebc3d7b:

    # "소녀는 여전히 울지 않았다. "
    "少女はやはり泣かなかった。"

# game/chapter6.rpy:2644
translate japanese ecg14_label_51595c67:

    # "다만, 메마른 흐느낌만을 쏟아낼 뿐이었다. "
    "ただ、乾いたすすり泣きだけをこぼすのみだった。"

# game/chapter6.rpy:2645
translate japanese ecg14_label_6421ee8f:

    # "그리고 그런 소녀를 보며, 나는 무언가 기시감을 느끼고 있었던 건지도 모르겠다. "
    "そしてそんな少女を見ながら、俺は何かデジャヴを感じていたのかもしれない。"

# game/chapter6.rpy:2651
translate japanese ecg14_label_b44dc5e8:

    # "오랜만에 방 안에 산뜻한 향이 감돌기 시작했다. "
    "久しぶりに部屋の中にさわやかな香りが漂い始めた。"

# game/chapter6.rpy:2652
translate japanese ecg14_label_70606d83:

    # "샤워를 끝마치고 침대에 걸터앉은 소녀에게선 익숙한 향기가 새어 나오고 있었다. "
    "シャワーを終えてベッドの端に腰掛けた少女からは、馴染みのある香りがほのかにこぼれていた。"

# game/chapter6.rpy:2656
translate japanese ecg14_label_bbd5876e:

    # "먼저 침대 한편에 누워 천장을 바라보고 있던 나의 위로, 소녀의 시선이 덮였다. "
    "先にベッドの片側に横になって天井を見上げていた俺の上に、少女の視線が降りてきた。"

# game/chapter6.rpy:2660
translate japanese ecg14_label_9e81f599:

    # voice "voices/gf82.ogg"
    # 소녀 "“무슨 생각 하고 있었나요?”"
    voice "voices/gf82.ogg"
    소녀 "「何を考えていたんですか？」"

# game/chapter6.rpy:2662
translate japanese ecg14_label_683c04a1:

    # voice ""
    # 나 "“그냥. 이젠 어떻게 하면 좋을지에 관한 생각.”"
    voice ""
    나 "「別に。これからどうすればいいかってことを。」"

# game/chapter6.rpy:2665
translate japanese ecg14_label_c99c5a5d:

    # "수건으로 머릿결의 물기를 닦아내는 소녀. "
    "タオルで髪の水気を拭き取る少女。"

# game/chapter6.rpy:2666
translate japanese ecg14_label_b31f76cf:

    # "소녀는 자신에게로 나의 시선이 머무르고 있다는 것을 느꼈는지, 몸을 눕혀서는 나와 시선의 높이를 맞췄다. "
    "少女は自分に俺の視線が留まっていることに気づいたのか、体を横たえて俺と目線の高さを合わせた。"

# game/chapter6.rpy:2668
translate japanese ecg14_label_8ac1d11b:

    # voice "voices/gf83.ogg"
    # 소녀 "“저기, 과거로 돌아가야 한다고 했죠?”"
    voice "voices/gf83.ogg"
    소녀 "「あの、過去に帰らなきゃいけないって言ってましたよね？」"

# game/chapter6.rpy:2670
translate japanese ecg14_label_8b1256d2:

    # voice ""
    # 나 "“그렇게 급한 일은 아냐. 신경 쓰고 있던 건 다른 일.”"
    voice ""
    나 "「そんなに急ぎの話じゃないよ。気にしてたのは別のことだから。」"

# game/chapter6.rpy:2673
translate japanese ecg14_label_e02632fb:

    # voice "voices/gf84.ogg"
    # 소녀 "“저는 그렇게 신경 쓰지 않아도 괜찮아요.”"
    voice "voices/gf84.ogg"
    소녀 "「私のことはそんなに気にしなくても大丈夫ですよ。」"

# game/chapter6.rpy:2675
translate japanese ecg14_label_8c1a71af:

    # voice ""
    # 나 "“으음…….”"
    voice ""
    나 "「うーん……」"

# game/chapter6.rpy:2681
translate japanese ecg14_label_b978b76c:

    # "와닿지 않는 충고였다. "
    "心に響かない忠告だった。"

# game/chapter6.rpy:2682
translate japanese ecg14_label_82e34beb:

    # "몸을 돌려, 다시금 시선을 천장으로 옮겼다. "
    "体を返して、再び視線を天井へと移した。"

# game/chapter6.rpy:2683
translate japanese ecg14_label_c59bf3ba:

    # "오늘따라 새하얀 벽지로 도배된 천장이 훨씬 더 멀게만 느껴졌다. "
    "今日に限って真っ白な壁紙で覆われた天井がずっと遠くに感じられた。"

# game/chapter6.rpy:2689
translate japanese ecg14_label_0588b59e:

    # voice "voices/gf85.ogg"
    # 소녀 "“과거의 당신은 어떤 사람이었나요?”"
    voice "voices/gf85.ogg"
    소녀 "「過去のあなたはどんな人だったんですか？」"

# game/chapter6.rpy:2691
translate japanese ecg14_label_05fbe457:

    # voice ""
    # 나 "“으음…… 갑자기 그건 왜?”"
    voice ""
    나 "「うーん……急になんでそんなことを？」"

# game/chapter6.rpy:2694
translate japanese ecg14_label_684b0b9e:

    # voice "voices/gf86.ogg"
    # 소녀 "“…… 궁금해요.”"
    voice "voices/gf86.ogg"
    소녀 "「……知りたいんです。」"

# game/chapter6.rpy:2697
translate japanese ecg14_label_7a313bc7:

    # voice ""
    # "어렵다는 생각이 곧장 드는 물음이었다. "
    voice ""
    "すごく難しいと感じる問いだった。"

# game/chapter6.rpy:2700
translate japanese ecg14_label_b12f2a3a:

    # 나 "“확실히 말하긴 어렵지만, 그리 자랑할만한 사람은 아니지 않았을까.”"
    나 "「はっきりとは言いにくいけど、そんなに自慢できるような人間じゃなかったんじゃないかな。」"

# game/chapter6.rpy:2702
translate japanese ecg14_label_22ca7b50:

    # voice "voices/gf87.ogg"
    # 소녀 "“왜요?”"
    voice "voices/gf87.ogg"
    소녀 "「どうしてですか？」"

# game/chapter6.rpy:2704
translate japanese ecg14_label_5d1e2f78:

    # voice ""
    # "‘왜요’라니, 질문의 난이도가 한 층 더 높아진 느낌이었다. "
    voice ""
    "「どうして」とは、質問の難度がもう一段上がった気がした。"

# game/chapter6.rpy:2707
translate japanese ecg14_label_67463ddb:

    # 나 "“뭐라고 할까, 사실 나도 기억이 잘 안 나. 과거의 내가 정확히 어떤 사람이었는지. 나에 대해서 기억이 모호한 부분이 있다고나 할까.”"
    나 "「何て言うか、実は俺もよく覚えてないんだ。過去の自分が正確にどんな人間だったか。自分について記憶が曖昧な部分があるっていうか。」"

# game/chapter6.rpy:2708
translate japanese ecg14_label_0e0e899e:

    # 나 "“가족 관계라거나, 이름이라거나, 나이 같은 기본적으로 드러나는 나에 대한 것들은 기억나지만. 그런 내가 아닌, 내면의 내 모습은 기억 속에서 사라져버렸거든.”"
    나 "「家族関係とか、名前とか、年齢みたいな基本的に分かることは覚えてるけど。そういう表面的な自分じゃなく、内面の自分の姿は記憶から消えてしまったんだ。」"

# game/chapter6.rpy:2709
translate japanese ecg14_label_02108254:

    # 나 "“어쩌면 무의식중에서 들려온 목소리가 나에게 과거로 돌아가야 한다고 말한 것도, 과거의 나를 잃어버릴지도 모른다는 생각에 그랬던 게 아니었을까 하는 생각도 들어.”"
    나 "「もしかしたら無意識から聞こえてきた声が俺に過去へ帰れと言ったのも、過去の自分を失ってしまうかもしれないという恐怖からだったんじゃないかという気もする。」"

# game/chapter6.rpy:2711
translate japanese ecg14_label_42a00d72:

    # voice "voices/gf88.ogg"
    # 소녀 "“그렇군요…….”"
    voice "voices/gf88.ogg"
    소녀 "「そうなんですか……」"

# game/chapter6.rpy:2714
translate japanese ecg14_label_29eadd68:

    # voice ""
    # "만족스러운 대답은 아니었겠지만, 더 이상의 질문이 이어지지는 않았다. "
    voice ""
    "満足のいく答えではなかっただろうが、それ以上の質問は続かなかった。"

# game/chapter6.rpy:2717
translate japanese ecg14_label_71b324e6:

    # "어색한 자세를 되돌려, 다시 시선을 소녀에게로 향했다. "
    "ぎこちない姿勢を直して、再び視線を少女に向けた。"

# game/chapter6.rpy:2718
translate japanese ecg14_label_b9d52594:

    # "어째서인지 나의 눈치를 보고 있던 소녀는 무언가 덧붙이고 싶어 하는 듯해 보였다. "
    "なぜか俺の顔色をうかがっていた少女は、何か付け足したそうに見えた。"

# game/chapter6.rpy:2719
translate japanese ecg14_label_eb345e0a:

    # "얼마 지나지 않아, 소녀가 조심스레 말문을 열었다. "
    "間もなく、少女がおそるおそる口を開いた。"

# game/chapter6.rpy:2729
translate japanese ecg14_label_0931f821:

    # voice "voices/gf89.ogg"
    # 소녀 "“저, 만약 돌아가지 않는 이유가 저 때문이라면. 그러지 않아도 돼요.”"
    voice "voices/gf89.ogg"
    소녀 "「あの、もし帰らない理由が私のためだとしたら。そうしなくていいんですよ。」"

# game/chapter6.rpy:2731
translate japanese ecg14_label_380c6d91:

    # voice ""
    # "소녀가 하고 싶었던 이야기는 바로 이것이었을까. "
    voice ""
    "少女が言いたかったのは、このことだったのだろうか。"

# game/chapter6.rpy:2734
translate japanese ecg14_label_dc8c1c94:

    # voice "voices/gf90.ogg"
    # 소녀 "“너, 너무 주제넘은 이야기였나요.”"
    voice "voices/gf90.ogg"
    소녀 "「す、すごく出しゃばったこと言っちゃいましたかね。」"

# game/chapter6.rpy:2736
translate japanese ecg14_label_64dea53f:

    # voice ""
    # 나 "“만약 과거로 돌아가게 되면, 나는 이곳에서 있었던 일들을 잊게 될지도 몰라.”"
    voice ""
    나 "「もし過去に帰ることになったら、俺はここであったことを忘れてしまうかもしれない。」"

# game/chapter6.rpy:2739
translate japanese ecg14_label_15d39176:

    # voice "voices/gf91.ogg"
    # 소녀 "“어쩔 수 없잖아요. 시간이 지나면, 그리고 다른 일을 겪다 보면 과거의 기억은 희미해지는 게 당연한 거고…….”"
    voice "voices/gf91.ogg"
    소녀 "「仕方ないじゃないですか。時は経つし、他のことを経験していけば過去の記憶が薄れていくのは当然のことで……」"

# game/chapter6.rpy:2742
translate japanese ecg14_label_c7d7a489:

    # voice ""
    # 나 "“그런 차원의 이야기가 아니야.”"
    voice ""
    나 "「そういう次元の話じゃないんだ。」"

# game/chapter6.rpy:2747
translate japanese ecg14_label_1ba63b58:

    # "소녀의 표정에 의아함이 감돈다. "
    "少女の表情に怪訝さが漂う。"

# game/chapter6.rpy:2756
translate japanese ecg14_label_bb1355fa:

    # 나 "“텔레이도스코프를 통해 과거로 돌아간 순간, 다른 차원에서의 기억은 거의 나지 않을 거래. 어쩌면 내가 그곳에 존재했다는 것 정도만, 머릿속에 남을지도 몰라.”"
    나 "「テレイドスコープを使って過去に帰った瞬間、別の次元での記憶はほとんど残らないらしい。もしかしたら俺がそこに存在したということくらいしか、頭に残らないかもしれない。」"

# game/chapter6.rpy:2757
translate japanese ecg14_label_90ea17f8:

    # voice "voices/gf92.ogg"
    # 소녀 "“마치 기억을 잃은 저처럼 말인가요.”"
    voice "voices/gf92.ogg"
    소녀 "「まるで記憶を失った私みたいですね。」"

# game/chapter6.rpy:2760
translate japanese ecg14_label_ebcc4391:

    # voice ""
    # 나 "“그러니까, 과거로 돌아가기 전에 네 소원을 들어주고 싶어.”"
    voice ""
    나 "「だから、過去に帰る前にお前の願いを叶えてあげたいんだ。」"

# game/chapter6.rpy:2763
translate japanese ecg14_label_037cdd61:

    # voice "voices/gf93.ogg"
    # 소녀 "“…… 과한 친절이에요.”"
    voice "voices/gf93.ogg"
    소녀 "「……おせっかいです。」"

# game/chapter6.rpy:2769
translate japanese ecg14_label_e15eaa12:

    # voice ""
    # "소녀에게서 흘러나오는 편안한 향에 취해, 나는 이야기를 이어간다. "
    voice ""
    "少女から漂う穏やかな香りに酔いながら、俺は話を続ける。"

# game/chapter6.rpy:2775
translate japanese ecg14_label_668dc9a7:

    # 나 "“돌아가는 게 급한 일은 아니라고 했지만, 실은 언제까지일지는 나도 잘 모르겠어. 어쩌면, 올해 안일지도 모르고.”"
    나 "「帰るのは急ぎじゃないとは言ったけど、実はいつまでなのか俺にもよく分からない。もしかしたら、今年中かもしれないし。」"

# game/chapter6.rpy:2777
translate japanese ecg14_label_826402e2:

    # voice "voices/gf94_1.ogg"
    # 소녀 "“그럼, 남은 시간을 차라리 다른 행복한 일에 쓰는 게 낫지 않을까요.”"
    voice "voices/gf94_1.ogg"
    소녀 "「だったら、残りの時間をむしろ他の楽しいことに使ったほうがいいんじゃないですか。」"

# game/chapter6.rpy:2780
translate japanese ecg14_label_f4a2fa33:

    # voice "voices/gf94_2.ogg"
    # 소녀 "“여기서 만든 친구라거나, 그때 봤던 같은 동아리의 여학생이라거나…….”"
    voice "voices/gf94_2.ogg"
    소녀 "「ここでできた友達とか、あのとき見かけた同じ部活の女の子とか……」"

# game/chapter6.rpy:2782
translate japanese ecg14_label_00b99ef3:

    # voice ""
    # 나 "“그렇지만, 내가 사라지고 나면 너는 사라질 수 없게 되잖아.”"
    voice ""
    나 "「でも、俺がいなくなったらお前は成仏できなくなるじゃないか。」"

# game/chapter6.rpy:2785
translate japanese ecg14_label_6662669c:

    # voice "voices/gf95.ogg"
    # 소녀 "“그렇겠죠.”"
    voice "voices/gf95.ogg"
    소녀 "「そうでしょうね。」"

# game/chapter6.rpy:2787
translate japanese ecg14_label_ca115794:

    # voice ""
    # 나 "“너를 불행하게 내버려 둔 채 돌아갈 수는 없는걸.”"
    voice ""
    나 "「お前を不幸なまま放り出して帰るわけにはいかないよ。」"

# game/chapter6.rpy:2790
translate japanese ecg14_label_a179b0e4:

    # voice "voices/gf96.ogg"
    # 소녀 "“저는 신경 쓰지 않아도 된다는 이야기, 귓등으로도 안 들었군요.”"
    voice "voices/gf96.ogg"
    소녀 "「私のことは気にしなくていいって話、まるっきり聞いてなかったんですね。」"

# game/chapter6.rpy:2792
translate japanese ecg14_label_1fbf0303_1:

    # voice ""
    # 나 "“…….”"
    voice ""
    나 "「……」"

# game/chapter6.rpy:2795
translate japanese ecg14_label_1e9f62de:

    # "침대에 누워 기울어진 시선으로 바라본 세상에는, 나와 같은 방향으로 기대어 있는 소녀만이 유일하게 정방향을 향한다. "
    "ベッドに横たわり傾いた視線から見た世界では、俺と同じ方向にもたれている少女だけが唯一まっすぐを向いている。"

# game/chapter6.rpy:2796
translate japanese ecg14_label_3ffbbbb9:

    # "그런 것이다. "
    "そういうことなのだ。"

# game/chapter6.rpy:2797
translate japanese ecg14_label_e6022c36:

    # "인생도, 가치관도, 내가 해야 할 일도. "
    "人生も、価値観も、俺がやるべきことも。"

# game/chapter6.rpy:2799
translate japanese ecg14_label_059b6181:

    # voice "voices/gf97.ogg"
    # 소녀 "“있죠, 저는 괜찮아요. 설령 사라지지 못한다고 하더라도요.”"
    voice "voices/gf97.ogg"
    소녀 "「あのですね、私は大丈夫ですよ。たとえ消えられなかったとしても。」"

# game/chapter6.rpy:2804
translate japanese ecg14_label_b9b44c88:

    # voice ""
    # "코앞에서 소녀가 말을 꺼내기 시작했다. "
    voice ""
    "目と鼻の先で少女が語り始めた。"

# game/chapter6.rpy:2807
translate japanese ecg14_label_491f031b:

    # voice "voices/gf98.ogg"
    # 소녀 "“앞으로 이곳에 남겨져 영원히 세상을 떠돌더라도, 가끔씩 당신과 있었던 일을 생각하며 웃을 수 있을 테니까요. 그럼…… 행복할 거예요.”"
    voice "voices/gf98.ogg"
    소녀 "「これからここに残されて永遠に世界をさまようことになっても、ときどきあなたといたことを思い出して笑えるでしょうから。それなら……幸せですよ。」"

# game/chapter6.rpy:2809
translate japanese ecg14_label_fa6ea105:

    # voice ""
    # 나 "“거짓말.”"
    voice ""
    나 "「嘘だ。」"

# game/chapter6.rpy:2812
translate japanese ecg14_label_89f34e09:

    # voice "voices/gf99.ogg"
    # 소녀 "“맞아요. 거짓말이에요.”"
    voice "voices/gf99.ogg"
    소녀 "「そうですね。嘘です。」"

# game/chapter6.rpy:2814
translate japanese ecg14_label_1fbf0303_2:

    # voice ""
    # 나 "“…….”"
    voice ""
    나 "「……」"

# game/chapter6.rpy:2817
translate japanese ecg14_label_92ef18b4:

    # "너무나도 간단히 나의 부정을 긍정한 소녀가, 조금 더 떨리는 목소리로 말했다. "
    "あまりにもあっさりと俺の否定を肯定した少女が、もう少し震える声で言った。"

# game/chapter6.rpy:2821
translate japanese ecg14_label_69eb08c0:

    # voice "voices/gf100.ogg"
    # 소녀 "“실은, 자주 떠올릴 거예요. 어쩌면 한시도 빼놓지 않고 떠올릴지도 모르죠……. 그러니까, 제게 행복했던 기억을 아주 조금만 더 만들어 줄 수 있을까요?”"
    voice "voices/gf100.ogg"
    소녀 "「本当は、しょっちゅう思い出しますよ。もしかしたら一秒も欠かさず思い出すかもしれません……だから、私に幸せだった記憶をもうほんの少しだけ作ってもらえませんか？」"

# game/chapter6.rpy:2823
translate japanese ecg14_label_afb50867:

    # voice ""
    # 나 "“그런 일방적인 기억, 너무 잔인하지 않아?”"
    voice ""
    나 "「そんな一方的な記憶、残酷すぎないか？」"

# game/chapter6.rpy:2826
translate japanese ecg14_label_41a83c7a:

    # voice "voices/gf101_1.ogg"
    # 소녀 "“괜찮아요. 이건, 죗값이니까요. 살아생전에 큰 죄를 지었던, 제게 주어진 죗값.”"
    voice "voices/gf101_1.ogg"
    소녀 "「大丈夫です。これは、罰ですから。生前に大きな罪を犯した、私に与えられた罰。」"

# game/chapter6.rpy:2829
translate japanese ecg14_label_910b3950:

    # voice "voices/gf101_2.ogg"
    # 소녀 "“그렇지만, 달게 받을 수 있으니, 그걸로 괜찮아요.”"
    voice "voices/gf101_2.ogg"
    소녀 "「けれど、甘んじて受け入れられますから。それでいいんです。」"

# game/chapter6.rpy:2831
translate japanese ecg14_label_67a954fc:

    # voice ""
    # "이제 소녀의 말에는, 한 치의 거짓도 묻어있지 않겠지. "
    voice ""
    "もう少女の言葉には、一片の嘘も含まれてはいないだろう。"

# game/chapter6.rpy:2833
translate japanese ecg14_label_a966f54b:

    # "그렇지만 순수하기 그지없는 소녀의 진심에는, 어찌할 수 없는 쌉싸름함이 잔뜩 담겨 있었다. "
    "けれどこの上なく純粋な少女の本心には、どうしようもないほろ苦さがたっぷりと込められていた。"

# game/chapter6.rpy:2835
translate japanese ecg14_label_3a454e81:

    # voice "voices/gf102.ogg"
    # 소녀 "“그리고 설령 저를 신경 쓴다더라도, 뭔가 할 수 있는 일도 없잖아요.”"
    voice "voices/gf102.ogg"
    소녀 "「それに、たとえ私のことを気にかけてくれたとしても、何かできることなんてないでしょう。」"

# game/chapter6.rpy:2837
translate japanese ecg14_label_35fa705e:

    # voice ""
    # "그리고 그 쌉싸름함 속에서, 나는 한 가지 실마리를 떠올린다. "
    voice ""
    "そしてそのほろ苦さの中で、俺は一つの手がかりを思い浮かべる。"

# game/chapter6.rpy:2840
translate japanese ecg14_label_07595cae:

    # 나 "“…… 하나, 있어.”"
    나 "「……一つ、ある。」"

# game/chapter6.rpy:2844
translate japanese ecg14_label_d09d983c:

    # voice "voices/gf103.ogg"
    # 소녀 "“네에……?”"
    voice "voices/gf103.ogg"
    소녀 "「え……？」"

# game/chapter6.rpy:2846
translate japanese ecg14_label_74ecf3db:

    # voice ""
    # "소녀에게 이어져야 했던 마지막 목소리. "
    voice ""
    "少女に繋がるはずだった最後の声。"

# game/chapter6.rpy:2853
translate japanese ecg14_label_09a49620:

    # 나 "“우리가 마지막으로 헤어졌던 곳, 거기에 가자.”"
    나 "「俺たちが最後に別れた場所、あそこに行こう。」"

# game/chapter6.rpy:2854
translate japanese ecg14_label_7868422e:

    # voice "voices/gf104.ogg"
    # 소녀 "“거긴…… 왜요?”"
    voice "voices/gf104.ogg"
    소녀 "「あそこに……どうして？」"

# game/chapter6.rpy:2856
translate japanese ecg14_label_a304a3f0:

    # voice ""
    # 나 "“너와 이어지지 못한 목소리가 있었어. 어쩌면 그 목소리에, 정답이 담겨 있었을지도 몰라.”"
    voice ""
    나 "「お前と繋がれなかった声があったんだ。もしかしたらその声に、答えが宿っていたのかもしれない。」"

# game/chapter6.rpy:2859
translate japanese ecg14_label_272b5c51:

    # "어째서 그런 생각을 한 건지는 나도 잘 모르겠다. "
    "なぜそんなことを思ったのかは俺にもよく分からない。"

# game/chapter6.rpy:2860
translate japanese ecg14_label_bc249c36:

    # "하지만, 그런 기분이 든다는 이유에서의 실없는 추측은 나의 머릿속에서 빠른 속도로 신뢰감을 얻고 있었다. "
    "だが、そんな気がするという理由だけの根拠のない推測は、俺の頭の中で急速に信憑性を帯びていた。"

# game/chapter6.rpy:2862
translate japanese ecg14_label_b08f5610:

    # voice "voices/gf105.ogg"
    # 소녀 "“…… 저, 졸려요.”"
    voice "voices/gf105.ogg"
    소녀 "「……私、眠いです。」"

# game/chapter6.rpy:2865
translate japanese ecg14_label_a6ad38db:

    # voice ""
    # 나 "“알겠어.”"
    voice ""
    나 "「分かった。」"

# game/chapter6.rpy:2868
translate japanese ecg14_label_8c594c5b:

    # "그 말을 신호로, 방 안의 조명이 차츰 희미하게 변해갔다. "
    "その言葉を合図に、部屋の照明が次第にほのかに変わっていった。"

# game/chapter6.rpy:2872
translate japanese ecg14_label_01f10060:

    # "적당한 밝기의 수면 유도등만이 남아 나와 소녀를 비추고, 소녀는 그대로 그 자리에서 움직이지 않은 채 눈을 감아버렸다. "
    "適度な明るさの常夜灯だけが残って俺と少女を照らし、少女はそのまま動かずに目を閉じてしまった。"

# game/chapter6.rpy:2873
translate japanese ecg14_label_7edff0df:

    # "숨소리가 맞닿을 정도의 거리. "
    "息遣いが触れ合うほどの距離。"

# game/chapter6.rpy:2875
translate japanese ecg14_label_96819e4e:

    # "더는 가까워질 수 없는 거리에서, 나 역시 잠을 청했다. "
    "これ以上近づけない距離で、俺もまた眠りについた。"

